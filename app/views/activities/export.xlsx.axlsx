wb = xlsx_package.workbook
wb.add_worksheet(name: "Site Assets") do |sheet|
 sheet.add_row [
          "ID", "Asset ", "Checklist", "Start Time", "End Time", 
          "Status", "Assigned To", "Created At", "Updated At", 
          "Soft Service ", "Patrolling ID"
        ]

        # Add data rows
        @activities.each do |activity|
          sheet.add_row [
            activity.id, activity.site_asset.try(:name), activity.checklist.try(:name), activity.start_time, activity.end_time,
            activity.status, activity.user&.full_name || activity.checklist_users.map { |u| u.user&.full_name}.compact.join(", ") , activity.created_at, activity.updated_at,
            activity.soft_service.try(:name), activity.patrolling_id
          ]
end
end
