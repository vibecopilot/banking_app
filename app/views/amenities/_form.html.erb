    <%= form.number_field :member_charges, id: :amenity_member_charges %>
  </div>

  <div class="field">
    <%= form.label :book_before %>
    <%= form.number_field :book_before, id: :amenity_book_before %>
  </div>

  <div class="field">
    <%= form.label :disclaimer %>
    <%= form.text_area :disclaimer, id: :amenity_disclaimer %>
  </div>

  <div class="field">
