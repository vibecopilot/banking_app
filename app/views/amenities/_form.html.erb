<%= form_with(model: amenity, local: true) do |form| %>
  <% if amenity.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(amenity.errors.count, "error") %> prohibited this amenity from being saved:</h2>

      <ul>
      <% amenity.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :site_id %>
    <%= form.number_field :site_id, id: :amenity_site_id %>
  </div>

  <div class="field">
    <%= form.label :fac_type %>
    <%= form.text_field :fac_type, id: :amenity_fac_type %>
  </div>

