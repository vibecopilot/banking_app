<p id="notice"><%= notice %></p>

<h1>Mom Attendees</h1>

<table>
  <thead>
    <tr>
      <th>Mom detail</th>
      <th>Name</th>
      <th>Organization</th>
      <th>Role</th>
      <th>Email</th>
      <th>Company tag name</th>
      <th>Attendees</th>
      <th>Attendees type</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @mom_attendees.each do |mom_attendee| %>
      <tr>
        <td><%= mom_attendee.mom_detail %></td>
        <td><%= mom_attendee.name %></td>
        <td><%= mom_attendee.organization %></td>
        <td><%= mom_attendee.role %></td>
        <td><%= mom_attendee.email %></td>
        <td><%= mom_attendee.company_tag_name %></td>
        <td><%= mom_attendee.attendees_id %></td>
        <td><%= mom_attendee.attendees_type %></td>
        <td><%= link_to 'Show', mom_attendee %></td>
        <td><%= link_to 'Edit', edit_mom_attendee_path(mom_attendee) %></td>
        <td><%= link_to 'Destroy', mom_attendee, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Mom Attendee', new_mom_attendee_path %>
