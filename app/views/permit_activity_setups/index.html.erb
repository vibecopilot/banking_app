<p id="notice"><%= notice %></p>

<h1>Permit Activity Setups</h1>

<table>
  <thead>
    <tr>
      <th>Permit type</th>
      <th>Name</th>
      <th>Site</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @permit_activity_setups.each do |permit_activity_setup| %>
      <tr>
        <td><%= permit_activity_setup.permit_type_id %></td>
        <td><%= permit_activity_setup.name %></td>
        <td><%= permit_activity_setup.site_id %></td>
        <td><%= link_to 'Show', permit_activity_setup %></td>
        <td><%= link_to 'Edit', edit_permit_activity_setup_path(permit_activity_setup) %></td>
        <td><%= link_to 'Destroy', permit_activity_setup, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Permit Activity Setup', new_permit_activity_setup_path %>
