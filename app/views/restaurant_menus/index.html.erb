<p id="notice"><%= notice %></p>

<h1>Restaurant Menus</h1>

<table>
  <thead>
    <tr>
      <th>Restaurant</th>
      <th>Name</th>
      <th>Sku</th>
      <th>Price</th>
      <th>Active</th>
      <th>Category</th>
      <th>Sub category</th>
      <th>Description</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @restaurant_menus.each do |restaurant_menu| %>
      <tr>
        <td><%= restaurant_menu.restaurant_id %></td>
        <td><%= restaurant_menu.name %></td>
        <td><%= restaurant_menu.sku %></td>
        <td><%= restaurant_menu.price %></td>
        <td><%= restaurant_menu.active %></td>
        <td><%= restaurant_menu.category_id %></td>
        <td><%= restaurant_menu.sub_category_id %></td>
        <td><%= restaurant_menu.description %></td>
        <td><%= link_to 'Show', restaurant_menu %></td>
        <td><%= link_to 'Edit', edit_restaurant_menu_path(restaurant_menu) %></td>
        <td><%= link_to 'Destroy', restaurant_menu, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Restaurant Menu', new_restaurant_menu_path %>
