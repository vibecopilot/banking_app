<p id="notice"><%= notice %></p>

<h1>User Devices</h1>

<table>
  <thead>
    <tr>
      <th>User</th>
      <th>Device</th>
      <th>Device type</th>
      <th>Gcm key</th>
      <th>Device name</th>
      <th>Device os version</th>
      <th>App</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @user_devices.each do |user_device| %>
      <tr>
        <td><%= user_device.user_id %></td>
        <td><%= user_device.device_id %></td>
        <td><%= user_device.device_type %></td>
        <td><%= user_device.gcm_key %></td>
        <td><%= user_device.device_name %></td>
        <td><%= user_device.device_os_version %></td>
        <td><%= user_device.app_id %></td>
        <td><%= link_to 'Show', user_device %></td>
        <td><%= link_to 'Edit', edit_user_device_path(user_device) %></td>
        <td><%= link_to 'Destroy', user_device, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New User Device', new_user_device_path %>
