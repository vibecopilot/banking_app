<p id="notice"><%= notice %></p>

<h1>Permits</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Contact number</th>
      <th>Site</th>
      <th>Unit</th>
      <th>Permit for</th>
      <th>Building</th>
      <th>Floor</th>
      <th>Room</th>
      <th>Client specific</th>
      <th>Entity</th>
      <th>Copy to string</th>
      <th>Permit type</th>
      <th>Vendor</th>
      <th>Issue date and time</th>
      <th>Expiry date and time</th>
      <th>Comment</th>
      <th>Permit status</th>
      <th>Extention status</th>
      <th>Created by</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @permits.each do |permit| %>
      <tr>
        <td><%= permit.name %></td>
        <td><%= permit.contact_number %></td>
        <td><%= permit.site_id %></td>
        <td><%= permit.unit_id %></td>
        <td><%= permit.permit_for %></td>
        <td><%= permit.building_id %></td>
        <td><%= permit.floor_id %></td>
        <td><%= permit.room_id %></td>
        <td><%= permit.client_specific %></td>
        <td><%= permit.entity %></td>
        <td><%= permit.copy_to_string %></td>
        <td><%= permit.permit_type %></td>
        <td><%= permit.vendor_id %></td>
        <td><%= permit.issue_date_and_time %></td>
        <td><%= permit.expiry_date_and_time %></td>
        <td><%= permit.comment %></td>
        <td><%= permit.permit_status %></td>
        <td><%= permit.extention_status %></td>
        <td><%= permit.created_by_id %></td>
        <td><%= link_to 'Show', permit %></td>
        <td><%= link_to 'Edit', edit_permit_path(permit) %></td>
        <td><%= link_to 'Destroy', permit, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Permit', new_permit_path %>
