<!DOCTYPE html>
<html>
<head>
<title>OTP Verification</title>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>

body{
background-color:#f4f4f4;
margin:0;
padding:0;
font-family:Arial, Helvetica, sans-serif;
font-size:13px;
}

table{
border-collapse:collapse;
}

.btn{
background:#28a745;
color:white;
padding:10px 20px;
border-radius:4px;
text-decoration:none;
}

</style>

</head>

<body>

<table width="100%">

<tr>
<td align="center">

<table width="600" bgcolor="#ffffff">

<tr>
<td style="padding:20px;font-size:18px;font-weight:bold;">
OTP Verification
</td>
</tr>

<tr>
<td style="padding:10px 30px;font-size:16px;font-weight:600;">
Dear <%= @user.firstname %> <%= @user.try(:lastname) %>,
</td>
</tr>

<tr>
<td style="padding:10px 30px;">
We received a request to verify your account for the
<b><%= @user.site.try(:name) %></b>.
</td>
</tr>

<tr>
<td style="padding:10px 30px;">
Use the OTP below to continue:
</td>
</tr>

<tr>
<td align="center" style="padding:20px;">

<div style="
font-size:28px;
font-weight:bold;
letter-spacing:6px;
background:#f4f4f4;
padding:15px 30px;
display:inline-block;
border-radius:6px;
">

<%= @otp %>

</div>

</td>
</tr>

<tr>
<td style="padding:10px 30px;">
This OTP is valid for <b>10 minutes</b>.
</td>
</tr>

<tr>
<td style="padding:10px 30px;">
If you did not request this OTP, please ignore this email.
</td>
</tr>

<tr>
<td style="padding:20px 30px;">
Best regards,
<br>
<b>Myciti.life</b>
</td>
</tr>

</table>

</td>
</tr>

</table>

</body>
</html>