<%= form_with(model: qr_verification, local: true) do |form| %>
  <% if qr_verification.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(qr_verification.errors.count, "error") %> prohibited this qr_verification from being saved:</h2>

      <ul>
      <% qr_verification.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :code %>
    <%= form.text_field :code %>
  </div>

  <div class="field">
    <%= form.label :expected_time %>
    <%= form.datetime_select :expected_time %>
  </div>

  <div class="field">
    <%= form.label :valid_till %>
