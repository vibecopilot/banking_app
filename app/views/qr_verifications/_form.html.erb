  </div>

  <div class="field">
    <%= form.label :generated_by_id %>
    <%= form.number_field :generated_by_id %>
  </div>

  <div class="field">
    <%= form.label :checked_in %>
    <%= form.check_box :checked_in %>
  </div>

  <div class="field">
    <%= form.label :checked_in_at %>
    <%= form.datetime_select :checked_in_at %>
  </div>

  <div class="field">
    <%= form.label :checked_in_by_id %>
    <%= form.number_field :checked_in_by_id %>
  </div>

  <div class="field">
    <%= form.label :site_id %>
    <%= form.number_field :site_id %>
  </div>

  <div class="field">
    <%= form.label :purpose %>
    <%= form.text_field :purpose %>
  </div>

  <div class="field">
    <%= form.label :notes %>
