<p id="notice"><%= notice %></p>

<h1>Qr Verifications</h1>

<table>
  <thead>
    <tr>
      <th>Code</th>
      <th>Expected time</th>
      <th>Valid till</th>
      <th>Generated by</th>
      <th>Checked in</th>
      <th>Checked in at</th>
      <th>Checked in by</th>
      <th>Site</th>
      <th>Purpose</th>
      <th>Notes</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @qr_verifications.each do |qr_verification| %>
      <tr>
        <td><%= qr_verification.code %></td>
        <td><%= qr_verification.expected_time %></td>
        <td><%= qr_verification.valid_till %></td>
        <td><%= qr_verification.generated_by_id %></td>
        <td><%= qr_verification.checked_in %></td>
        <td><%= qr_verification.checked_in_at %></td>
        <td><%= qr_verification.checked_in_by_id %></td>
        <td><%= qr_verification.site_id %></td>
        <td><%= qr_verification.purpose %></td>
        <td><%= qr_verification.notes %></td>
        <td><%= link_to 'Show', qr_verification %></td>
        <td><%= link_to 'Edit', edit_qr_verification_path(qr_verification) %></td>
        <td><%= link_to 'Destroy', qr_verification, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Qr Verification', new_qr_verification_path %>
