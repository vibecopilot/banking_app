<h3>Restaurant Schedule</h3>
<table border="1" cellpadding="5" cellspacing="0" style="width: 100%; margin: 0 auto;">
  <thead>
    <tr>
      <th style="text-align: center;">Operational Days</th>
      <th style="text-align: center;">Select</th>
      <th style="text-align: center;">Start Time</th>
      <th style="text-align: center;">End Time</th>
      <th style="text-align: center;">Booking Allowed</th>
      <th style="text-align: center;">Order Allowed</th>
    </tr>
  </thead>
  <tbody>
    <% Date::DAYNAMES.each do |day| %>
      <tr>
        <td><%= day %></td>
        <td>
          <%= form.check_box "restaurant_schedule[#{day}][selected]", checked: food_and_beverage.restaurant_schedule.dig(day, 'selected') %>
        </td>
        <td>
          <%= form.time_field "restaurant_schedule[#{day}][start_time]", value: food_and_beverage.restaurant_schedule.dig(day, 'start_time') %>
        </td>
        <td>
          <%= form.time_field "restaurant_schedule[#{day}][end_time]", value: food_and_beverage.restaurant_schedule.dig(day, 'end_time') %>
        </td>
        <td>
          <%= form.check_box "restaurant_schedule[#{day}][booking_allowed]", checked: food_and_beverage.restaurant_schedule.dig(day, 'booking_allowed') %>
        </td>
        <td>
          <%= form.check_box "restaurant_schedule[#{day}][order_allowed]", checked: food_and_beverage.restaurant_schedule.dig(day, 'order_allowed') %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>


  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
