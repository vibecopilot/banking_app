wb = xlsx_package.workbook
wb.add_worksheet(name: "Food And Beverage") do |sheet|
  # Add the header row
  sheet.add_row ["Restaurant Name", "Cost For Two", "Mobile Number", "Alternate Mobile Number", "Landline Number", "Delivery Time", "Start Time", "End Time", "Order Not Allowed Text", "Cuisines", "Serves Alcohol", "Wheelchair Accessible", "Cash On Delivery", "Pure Veg", "Address", "Start Time", "End Time", "Booking Allowed", "Order Allowed", "Terms And Conditions", "Last Booking Time", "Disclaimer", "Closing Message", "Minimum Person", "Maximum Person", "Cancel Before", "GST", "Delivery Charges", "Minimum Order", "Status", "Created By", "Table Booking Start Date", "Table Number", "Table Booking End Date", "Table Booking Start Time", "Table Booking End Time", "Booking Capacity", "Waiting Capacity", "Booking Not Available Text", "Food And Beverages Availability"]

  
  # Add the data rows
  @food_and_beverages.each do |food_and_beverage|
    sheet.add_row [food_and_beverage.restaurant_name, food_and_beverage.cost_for_two, food_and_beverage.mobile_number, food_and_beverage.alternate_mobile_number, food_and_beverage.landline_number, food_and_beverage.delivery_time, food_and_beverage.start_time, food_and_beverage.end_time, food_and_beverage.order_not_allowed_text, food_and_beverage.cuisines, food_and_beverage.serves_alcohols, food_and_beverage.wheelchair_accessible, food_and_beverage.cash_on_delivery, food_and_beverage.pure_veg, food_and_beverage.address, food_and_beverage.start_time, food_and_beverage.end_time, food_and_beverage.booking_allowed.nil? ? '' : (food_and_beverage.booking_allowed ? 'Yes' : 'No'), food_and_beverage.order_allowed.nil? ? '' : (food_and_beverage.order_allowed ? 'Yes' : 'No'), food_and_beverage.terms_and_conditions, food_and_beverage.last_booking_time, food_and_beverage.disclaimer, food_and_beverage.closing_message, food_and_beverage.minimum_person, food_and_beverage.maximum_person, food_and_beverage.cancel_before, food_and_beverage.gst, food_and_beverage.delivery_charges, food_and_beverage.minimum_order, food_and_beverage.status, food_and_beverage.user&.full_name, food_and_beverage.table_booking_start_date, food_and_beverage.table_number, food_and_beverage.table_booking_end_date, food_and_beverage.table_booking_start_time, food_and_beverage.table_booking_end_time, food_and_beverage.booking_capacity, food_and_beverage.waiting_capacity, food_and_beverage.booking_not_available_text, food_and_beverage.food_and_beverages_availability]
  end
end