<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  @page { size: A4 landscape; margin: 0; }
  body, html { margin: 0; padding: 0; width: 297mm; height: 210mm; }
  .cert-container {
    width: 297mm; height: 210mm; padding: 12mm;
    box-sizing: border-box; background-color: #f5f0e8;
    font-family: Georgia, 'Times New Roman', serif;
    text-align: center; color: #2d3a2d;
    position: relative; overflow: hidden;
  }
  .cert-container::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(45,58,45,0.02) 20px, rgba(45,58,45,0.02) 40px);
  }
  .border-frame {
    position: absolute; top: 8mm; left: 8mm; right: 8mm; bottom: 8mm;
    border: 3px double #8b7d5e; pointer-events: none;
    box-shadow: inset 0 0 30px rgba(139,125,94,0.1);
  }
  .inner-frame {
    position: absolute; top: 12mm; left: 12mm; right: 12mm; bottom: 12mm;
    border: 1px solid #c4b89a; pointer-events: none;
  }
  .corner { position: absolute; width: 20mm; height: 20mm; }
  .corner-tl { top: 6mm; left: 6mm; border-top: 4px solid #8b7d5e; border-left: 4px solid #8b7d5e; }
  .corner-tr { top: 6mm; right: 6mm; border-top: 4px solid #8b7d5e; border-right: 4px solid #8b7d5e; }
  .corner-bl { bottom: 6mm; left: 6mm; border-bottom: 4px solid #8b7d5e; border-left: 4px solid #8b7d5e; }
  .corner-br { bottom: 6mm; right: 6mm; border-bottom: 4px solid #8b7d5e; border-right: 4px solid #8b7d5e; }
  .seal {
    position: absolute; right: 20mm; bottom: 20mm;
    width: 36mm; height: 36mm; border-radius: 50%;
    border: 3px solid #8b7d5e;
    display: flex; align-items: center; justify-content: center;
    background: rgba(139,125,94,0.08);
    font-size: 7pt; color: #6b5d3e; text-transform: uppercase;
    letter-spacing: 0.5mm; transform: rotate(-15deg);
  }
  .seal-inner {
    width: 28mm; height: 28mm; border-radius: 50%;
    border: 2px solid #8b7d5e;
    display: flex; align-items: center; justify-content: center;
    text-align: center; line-height: 1.3;
  }
  .content { position: relative; z-index: 1; padding: 15mm 10mm 10mm; }
  .badge {
    width: 28mm; height: 28mm; border-radius: 50%;
    background: #2d3a2d; color: #f5f0e8; margin: 0 auto 6mm;
    display: flex; align-items: center; justify-content: center;
    font-size: 9pt; letter-spacing: 0.3mm; text-transform: uppercase;
  }
  h1 { font-size: 28pt; font-weight: 400; letter-spacing: 2pt; color: #2d3a2d; margin-bottom: 3mm; }
  .subtitle { font-size: 11pt; color: #6b5d3e; letter-spacing: 1pt; margin-bottom: 6mm; }
  .divider { width: 60mm; height: 1px; background: #c4b89a; margin: 4mm auto; }
  .body-text { font-size: 12pt; line-height: 1.8; color: #3d4a3d; }
  .body-text strong { color: #2d3a2d; }
  .cert-id { font-size: 9pt; color: #8b7d5e; margin-top: 4mm; font-family: 'Courier New', monospace; }
  .details-table { width: 80%; margin: 5mm auto 0; border-collapse: collapse; }
  .details-table td { padding: 2mm 3mm; text-align: left; font-size: 11pt; border-bottom: 1px dashed #d4c8aa; }
  .details-table td:first-child { font-weight: 600; color: #6b5d3e; width: 40%; }
  .details-table td:last-child { text-align: right; }
  .footer { position: absolute; bottom: 15mm; left: 0; right: 0; text-align: center; font-size: 8pt; color: #8b7d5e; }
</style>

<div class="cert-container">
  <div class="border-frame"></div>
  <div class="inner-frame"></div>
  <div class="corner corner-tl"></div>
  <div class="corner corner-tr"></div>
  <div class="corner corner-bl"></div>
  <div class="corner corner-br"></div>
  <div class="seal"><div class="seal-inner">Authorised<br>Signatory</div></div>

  <div class="content">
    <div class="badge">&#10003;</div>
    <h1>Completion Certificate</h1>
    <div class="subtitle">&#8212; Service Work Completion &#8212;</div>
    <div class="divider"></div>

    <p class="body-text">
      This is to certify that the service work for<br>
      <strong><%= quotation.notes.presence || "Quotation ##{quotation.id}" %></strong><br>
      has been duly completed.
    </p>

    <table class="details-table">
      <tr><td>Certificate No.</td><td><%= certificate.certificate_number %></td></tr>
      <tr><td>Quotation Ref</td><td>QT-<%= quotation.id.to_s.rjust(4, '0') %></td></tr>
      <tr><td>Ticket Ref</td><td><%= quotation.ticket_id %></td></tr>
      <tr><td>Date of Completion</td><td><%= quotation.work_completed_at&.strftime('%d %B %Y') || 'N/A' %></td></tr>
      <tr><td>Issued On</td><td><%= certificate.issued_at&.strftime('%d %B %Y') %></td></tr>
    </table>

    <div class="cert-id"><%= certificate.certificate_number %></div>
  </div>

  <div class="footer">This is a system-generated certificate. Generated on <%= Time.current.strftime('%d %B %Y at %I:%M %p') %></div>
</div>
