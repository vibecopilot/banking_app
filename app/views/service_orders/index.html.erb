<p id="notice"><%= notice %></p>

<h1>Service Orders</h1>

<table>
  <thead>
    <tr>
      <th>Service order date</th>
      <th>Billing address</th>
      <th>Retention</th>
      <th>Tds</th>
      <th>Qc</th>
      <th>Payment tenure</th>
      <th>Advance amount</th>
      <th>Related to</th>
      <th>Kind Attention</th>
      <th>Subject</th>
      <th>Description</th>
      <th>Terms & Conditions</th>
      <th>Site</th>
      <th>Vendor</th>
      <th>Created by</th>
      <th>Reference</th>
      <th>Active</th>
      <th>Approved status</th>
      <th>Total amount</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @service_orders.each do |service_order| %>
      <tr>
        <td><%= service_order.service_order_date %></td>
        <td><%= service_order.billing_address_id %></td>
        <td><%= service_order.retention %></td>
        <td><%= service_order.tds %></td>
        <td><%= service_order.qc %></td>
        <td><%= service_order.payment_tenure %></td>
        <td><%= service_order.advance_amount %></td>
        <td><%= service_order.related_to %></td>
        <td><%= service_order.kind_attention %></td>
        <td><%= service_order.subject %></td>
        <td><%= service_order.description %></td>
        <td><%= service_order.terms_and_conditions %></td>
        <td><%= service_order.site_id %></td>
        <td><%= service_order.vendor_id %></td>
        <td><%= service_order.created_by_id %></td>
        <td><%= service_order.reference %></td>
        <td><%= service_order.active %></td>
        <td><%= service_order.approved_status %></td>
        <td><%= service_order.total_amount %></td>
        <td><%= link_to 'Show', service_order %></td>
        <td><%= link_to 'Edit', edit_service_order_path(service_order) %></td>
        <td><%= link_to 'Destroy', service_order, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Service Order', new_service_order_path %>
