<p id="notice"><%= notice %></p>

<h1>Addresses</h1>

<table>
  <thead>
    <tr>
      <th>Address title</th>
      <th>Building name</th>
      <th>Street name</th>
      <th>Email address</th>
      <th>State</th>
      <th>City</th>
      <th>Address</th>
      <th>Phone number</th>
      <th>Pin code</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @addresses.each do |address| %>
      <tr>
        <td><%= address.address_title %></td>
        <td><%= address.building_name %></td>
        <td><%= address.street_name %></td>
        <td><%= address.email_address %></td>
        <td><%= address.state %></td>
        <td><%= address.city %></td>
        <td><%= address.address %></td>
        <td><%= address.phone_number %></td>
        <td><%= address.pin_code %></td>
        <td><%= link_to 'Show', address %></td>
        <td><%= link_to 'Edit', edit_address_path(address) %></td>
        <td><%= link_to 'Destroy', address, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Address', new_address_path %>
