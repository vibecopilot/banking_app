
    <div class="wrapper wrapper-content">
      <section class="content">
        <div class="ibox">
          <div class="ibox-content">
            <div class="row">
              <div class="col-sm-12">
                <div class="header-title movein-border">
                  <h2 class="movein-bg">Edit</h2>
                </div>
                <div class="col-xs-6">                                    	
                  <% @complaint_log = ComplaintLog.new %>
								  <%= form_for(@complaint_log, url: "/complaint_logs") do |f| %>
                  <%= f.hidden_field :complaint_id, :value => @complaint.id %>
								  <%= f.hidden_field :society_staff_type, :value => "User" %>
								  <%= hidden_field_tag "custom_redirect" ,value = "/pms/complaints/#{@complaint.id}"%>
								  	<input type="hidden" name="complaint_comment[docs][]" id="complaint_image">
                    <div class="form-group">
                    	<% @ss= ComplaintStatus.pms.active.where(society_id: @user.company_id).order(:position).collect{ |p| [p.name,p.id] }%>
                      <label class="col-sm-3 control-label">Status</label>
                      <div class="col-sm-9">
                        <%= f.select :complaint_status_id, options_for_select(@ss, :selected => @complaint.issue_status),{:include_blank=>"Select Status"},{:class => 'form-control'}%>
                      </div>
                    </div>
                      <% @helpdesk_categories = HelpdeskCategory.pms.where(society_id: @user.company_id).active.collect{ |h| [h.name, h.id] } %>        
                    <div class="form-group">
                      <label class="col-sm-3 control-label">Category Type</label>
                      <div class="col-sm-9">                         
                        <%= select_tag 'complaint[catgory_type_id]', options_for_select(@helpdesk_categories , {:selected => @complaint.category_type, :include_blank=>"Select Category Type"}),{:class => 'form-control selectpicker'}%>
                      </div>
                    </div>                    
                    <div class="form-group" style="display: none">
                      <label class="col-sm-3 control-label">Complaint Location </label>
                      <div class="col-sm-9">
                        <div class="col-sm-4">
                  				<%= select_tag "complaint[society_location_id]", options_for_select(@society_locations.collect{|p| [p.name, p.id] },:selected => @complaint.society_location_id), :include_blank=> "Select Level 1", :class => "form-control pull-right",:id => 'location_level1' %>
                				</div>
				                <div class="col-sm-4">
				                  <%= select_tag "complaint[wing_id]", options_for_select(@complaint.wing_id.present? ? Pms::Wing.where(id: @complaint.wing_id).collect{|p| [p.name, p.id]} : [  ],:selected => @complaint.wing_id), :include_blank=> "Select Level 2", :class => "form-control pull-right",:id => 'location_level2' %>
				                </div>
				                <div class="col-sm-4">
				                  <%= select_tag "complaint[area_id]", options_for_select(@complaint.area_id.present? ? Pms::Area.where(id: @complaint.area_id).collect{|p| [p.name, p.id]} : [  ],:selected => @complaint.area_id), :include_blank=> "Select Level 3", :class => "form-control pull-right",:id => 'location_level3' %>
				                </div>
                      </div>
                    </div>
                    <div class="form-group" style="display: none;">
                      <label class="col-sm-3 control-label">Root Cause </label>
                      <div class="col-sm-9">
                        <input type="text" name="complaint[root_cause]" value="<%=@complaint.root_cause%>" class="form-control" id="root_cause">
                      </div>
                    </div>
                    <div class="form-group" style="display: none;">
                      <label class="col-sm-3 control-label">Impact </label>
                      <div class="col-sm-9">
                        <input type="text" name="complaint[impact]" value="<%=@complaint.impact%>" class="form-control" id="impact">
                      </div>
                    </div>
                    <div class="form-group" style="display: none;">
                      <label class="col-sm-3 control-label">Correction </label>
                      <div class="col-sm-9">
                      	<input type="text" name="complaint[correction]" value="<%=@complaint.correction%>" class="form-control" id="correction">
                      </div>
                    </div>
                    <div class="form-group" style="display: none;">
                      <label class="col-sm-3 control-label">Corrective Action </label>
                      <div class="col-sm-9">
                        <input type="text" name="complaint[corrective_action]" value="<%=@complaint.corrective_action%>" class="form-control" id="corrective_action">
                      </div>
                    </div>

                    <div class="form-group" style="display: none;">
                      <label class="col-sm-3 control-label">Issue Related To </label>
                      <div class="col-sm-9">
                      	<label class="radio-inline">
      										<input type="radio" name="complaint[issue_related_to]" <%= @complaint.issue_related_to == "Project" ? 'checked' : '' %> value="Project">Project
    										</label> 
										    <label class="radio-inline">
										      <input type="radio" name="complaint[issue_related_to]" <%= @complaint.issue_related_to == "FM" ? 'checked' : '' %> value="FM">FM
										    </label>
                      </div>
                    </div>
                </div>
                <div class="col-xs-6">
                  <div class="form-group" style="display: none;">
                    <label class="col-sm-3 control-label">Preventive Action </label>
                    <div class="col-sm-9">
                    	<input type="text" name="complaint[preventive_action]" value="<%=@complaint.preventive_action%>" class="form-control" id="preventive_action">
                    </div>
                  </div>
                  <div class="form-group" style="display: none;">
                    <label class="col-sm-3 control-label">Responsible Person Name </label>
                    <div class="col-sm-9">
                      <%= select_tag "complaint[person_id]", options_for_select(@user_society_admin.collect{|p| [p.user.full_name,p.user.id] },:selected => @complaint.person_id), :include_blank=> "Select Responsible Person Name", :class => "form-control pull-right",:id => 'person_id' %>
                    </div>
                  </div>
                  <div class="form-group" style="display: none;">
                    <label class="col-sm-3 control-label">Review (Tracking) </label>
                    <div class="col-sm-9">
                      <div class="ui calendar review">
                        <div class="ui input left icon"> <i class="calendar icon"></i>
                        	<input type="text" name="complaint[review_tracking_date]" id="review_tracking" data-provide="datepicker" data-date-format="dd/mm/yyyy" class="form-control complaint_datepicker" placeholder="Review Date" value="<%=@complaint.review_tracking_date%>">
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="form-group" style="display: none;">
                    <label class="col-sm-3 control-label">Agency </label>
                    <div class="col-sm-9">
                      <%= select_tag "complaint[supplier_id]", options_for_select(@pms_suppliers.collect{|p| [p.name, p.id] },:selected => @complaint.supplier_id), :include_blank=> "Select Agency", :class => "form-control pull-right",:id => 'supplier_id' %>
                    </div>
                  </div>
                  <div class="form-group" style="display: none;">
                    <label class="col-sm-3 control-label">Proactive/Reactive </label>
                    <div class="col-sm-9">
                      <%= select_tag "complaint[proactive_reactive]", options_for_select([['Proactive','Proactive'],['Reactive','Reactive']],:selected => @complaint.proactive_reactive), :include_blank=> "Select Proactive/Reactive", :class => "form-control pull-right",:id => 'proactive_reactive' %>
                    </div>
                  </div>

                  <% @ws = User.active_lups(current_user.company_id).fm_users.allowed_site_users_for([@user.selected_site_id]) %>
                  <div class="form-group">
                    <label class="col-sm-3 control-label">Assigned to</label>
                    <div class="col-sm-9">
                      <%= f.select :assigned_to, options_for_select(@ws.map {|s| [(s.full_name), s.id]}, :selected => @complaint.assigned_to),{:include_blank=>"Select Assignee"},{:class => 'form-control'} %>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="col-sm-3 control-label">Comment</label>
                      <div class="col-sm-9">
			                  <!-- <textarea class="form-control" rows="3">Comments</textarea>-->
	                      <div class="comment-box">
			                    <div class="well">
			                      <textarea class="form-control border pad10" id="" name="complaint_log[comment]" placeholder="Add Comment" rows="1"></textarea>
			                      <div class="text-right margin-t-10">
			                      
			                        <input type="file" name="complaint_comment[doc]" id="comment_doc" class="inputfile inputfile-2" data-multiple-caption="{count} files selected" multiple>
							                <label for="comment_doc"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="17" viewBox="0 0 20 17">
							                  <path d="M10 0l-5.2 4.9h3.3v5.1h3.8v-5.1h3.3l-5.2-4.9zm9.3 11.5l-3.2-2.1h-2l3.4 2.6h-3.5c-.1 0-.2.1-.2.1l-.8 2.3h-6l-.8-2.2c-.1-.1-.1-.2-.2-.2h-3.6l3.4-2.6h-2l-3.2 2.1c-.4.3-.7 1-.6 1.5l.6 3.1c.1.5.7.9 1.2.9h16.3c.6 0 1.1-.4 1.3-.9l.6-3.1c.1-.5-.2-1.2-.7-1.5z"></path>
							                  </svg> <span>Choose a file…</span></label>
			 
			                      </div>
			                    </div>
		                  	</div>
                      </div>
                    </div>
                </div>
              </div>
              <div class="col-sm-12 text-center">
                <div class="hr-line-dashed"></div>
                <button type='submit' id="submitbtn" class="btn btn-success btn-sm"/>Submit & Show Detail</button>
              </div>
            <%end%>
            </div>
          </div>
        </div>
      </section >
    </div >

  <script>
	  $(document).ready(function(){
	    $('.bxslider').bxSlider();
	  });
	  var workers = '<%= @jn.to_json %>';
	  var wos = JSON.parse(workers.replace(/&quot;/g,'"'));

	  $("#location_level1").change(function(){
    	location_level2_from_level1($(this), $("#location_level2")) 
  	});

	  $("#location_level2").change(function(){
	    pms_area_from_wing($(this), $("#location_level3")) 
	  });

    $("#submitbtn").click(function(){
      if($("#root_cause").val() == "" || $("#impact").val() == "" || $("#correction").val() == "" || $("#corrective_action").val() == "" || $("#preventive_action").val() == "" || $("#person_id").val() == "" || $("#review_tracking").val() == "" || $("#supplier_id").val() == "" || $("#proactive_reactive").val() == "" ){
        if(confirm("You have not updated all the fields, are you sure you want to submit ?")){
          $("#new_complaint_log").submit();
        }
        else{
          return false;
        }
      }
    });

	  $(function () {
	    //Date picker
	    var nowDate = new Date();
	    var today = new Date(nowDate.getFullYear(), nowDate.getMonth(), 
	      nowDate.getDate(), 0, 0, 0, 0);

	    $(".complaint_datepicker").datepicker({
	      // dateFormat: 'dd/mm/yy',
	      autoclose: true,
	      startDate : today
	    });
	  });

	  jQuery(document).ready(function(){
	  jQuery("#assigned_to").val(location.pathname)
	  });


	  /* Initialize the gallery */
	  jQuery("#thumbGallery").thumbGallery();

	  /* customizer */
	  jQuery("#effect").on("change",function(){
	      var x = $(this).val();
	      jQuery("#thumbGallery").data("nav_effect", x);
	  });

	  jQuery("#delay").on("change",function(){
	      var x = parseFloat($(this).val());
	      jQuery("#thumbGallery").data("nav_delay", x);
	  });

	  jQuery("#timing").on("change",function(){
	      var x = parseFloat($(this).val());
	      jQuery("#thumbGallery").data("nav_timing", x);
	  });

	  if(jQuery.isMobile){
	      jQuery("body").css({marginBottom: 140})
	  }

	  $('.ui.dropdown').dropdown();
	  $(document).ready(function() {
	     var readURL2 = function(input) {
	        if (input.files && input.files[0]) {
	          var reader = new FileReader();
	          reader.onload = function (e) {
	            $('.well').append($('<div class="attach-img"><i class="fa fa-times remove-img" aria-hidden="true" ></i><img src="' + e.target.result + '" alt="img" class="img-thumbnail"></div>'));

	            $(".remove-img").off("click");
	            $(".remove-img").click(function(){ $(this).parent().remove(); });
	           [i.fa.fa-times.remove-img, i.fa.fa-times.remove-img, i.fa.fa-times.remove-img]
	          }
	          reader.readAsDataURL(input.files[0]);
	        }
	    }    
	    $("#comment_doc").on('change', function(){
	      readURL2(this);
	    });
	  });

	 $("#submitbtn").click(function(e){
	   $('.well img').each(function(){
	    pres = $(this).attr('src');
	    pres = pres.replace('data:image/png;base64,', "")
	    pres = pres.replace('data:image/jpg;base64,', "")
	    pres = pres.replace('data:image/jpeg;base64,', "")
	    $("#complaint_image").parents("form").append($('<input type="hidden" name="complaint_comment[docs][]" value='+ pres +' > '))
	  });
	  $(this).parents("form").submit();
	 });
</script>