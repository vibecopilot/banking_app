<style>
  .project-title {
    max-width: 255px !important;
  }
</style>

<%= csrf_meta_tag %>
<div class="data-table-area mg-b-15">
    <div class="container">
      <div class="row">

        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12" style="width: 90%;">
          <div class="sparkline13-list">
            <div class="sparkline13-graph">
              <div class="datatable-dashv1-list custom-datatable-overright">
                <div id="toolbar">
                  <div style="display:flex; justify-content: space-between;">
                    <button class="btn btn-primary btn-md custom-button" >
                      <a href="/pms/admin/complaints/new">
                        <i class="fa fa-plus margin-r-2" aria-hidden="true"></i>Add
                      </a>
                    </button>

                    <div style="width: 703px;">
                      <%= form_tag pms_manage_complaints_path, :method => 'get' do %>
                      <div>
                        <div style="display: flex; margin-left: 1%;">
                          <div style="padding-left: 0px;">
                            <input type="text" class="form-control all-search" name="q[heading_or_ticket_number_cont]" style="height: 30px; width: 266px;" placeholder="Search using number or Description" autocomplete="off" value="<%= params[:q].present? && params[:q][:heading_or_ticket_number_cont].present? ? "#{params[:q][:heading_or_ticket_number_cont]}" : "" %>">
                            <button type="submit" class="btn btn-sm btn-success custom-button" style="float: right;margin-top: -11.5%;margin-right: -58px; width:  35px;"> <i class="fa fa-arrow-right "></i></button>
                          </div>
                        </div>
                      </div>
                      <% end %>
                    </div>
                  </div>
                </div>       

                <% @category= HelpdeskCategory.pms.where(society_id: @user.current_site_id) %>
                <% @ty= ComplaintStatus.pms.active.where(society_id: @user.current_site_id).collect{|s| [s.name, s.id] }%>
                <% params[:q] = params[:q] || {} %>
                <div class="row" id="myDiv" style="display: block;">
                  <%= form_tag pms_manage_complaints_path, :method => 'get', :id=>"filters" do %>
 
                    
                    <div class="col-sm-12" style="padding-left: 0px;">
                      <div class="col-sm-2 form-group helpdesk-filter">
                        <%= select_tag 'q[category_type_id_eq]',options_for_select(@category.pluck(:name, :id), :selected => params[:q][:category_type_id_eq]),:class=>"form-control",:include_blank =>"Select Category Type",:id => 'category' %>
                      </div>

               
                      <div class="form-group col-sm-2 helpdesk-filter" >
                        <div class="input-group">
                          <div class="input-group-addon"> <i class="fa fa-calendar"></i> </div>
                          <input type="text" name='q[date_range]' id ="date_range" class="reservation form-control pull-right" placeholder="Select Date Range" value="<%= params[:q][:date_range] %>">
                        </div>
                      </div>

                       <div class="col-sm-2 form-group helpdesk-filter">
                        <%= select_tag 'q[issue_status_eq]',options_for_select(@ty, :selected => params[:q][:issue_status_eq]),:class=>"form-control",:include_blank =>"Select Status" %>
                      </div> 

                       <div class="col-sm-2 form-group helpdesk-filter">
                        <%= select_tag 'q[priority_eq]',options_for_select(['P1','P2','P3','P4','P5'], :selected => params[:q][:priority_eq]),:class=>"form-control",:include_blank =>"Select Admin Priority" %>
                      </div> 

                      <div class="col-md-2 form-group" style="float: right; margin-right: -50px;">
                        <button type="button" class="applyfilter btn btn-success btn-sm"> Apply</button>
                        <a href="<%= pms_manage_complaints_path %>"><button type="button" id="" class="btn btn-info btn-sm"> Reset</button></a>
                      </div>
                    </div>
                
                  <% end %>
                </div>
         
                <div id="applied_filters_container"></div>

                <table class="table table-striped table-responsive " id="table" data-toggle="table" data-search="false" data-pagination="false" data-trim-on-search="false" data-show-columns="true" data-show-refresh="true" data-sortable="true" data-key-events="true" data-show-toggle="true" data-resizable="true" data-cookie="true" data-cookie-id-table="saveId" data-show-export="true" data-click-to-select="true" scrollX="true" data-toolbar="#toolbar" style="min-width: 600px; sc;">

                  <thead>
                    <tr class="table-row" data-href="#">
                      <th colspan="2">Action</th>
                      <th>Number</th>
                      <th>Description</th>
                      <th>Category</th>
                      <th>Status</th>
                      <th>Priority</th>
                      <th>Created By</th>
                      <th>Created On</th>
                      <th>Assigned To</th>
                    </tr>
                  </thead>  

                  <tbody>
                    <% @complaints.each do |complaint| %>
                      <tr class="table-row" data-href="#">
                          <% img = Attachfile.where("relation = 'Complaint' and relation_id = ?" , complaint.id )%>
                        <td>
                          <a href="/pms/admin/complaints/<%= complaint.id%>" class="btn btn-xs"><i class="fa fa-eye text-info" aria-hidden="true"></i></a>
                          <td><%= link_to 'Destroy', pms_manage_complaint_path(complaint), method: :delete, data: { confirm: 'Are you sure?' } %></td>
                        </td>
                        <td><%= complaint.ticket_number %></td>
                        <td class="project-title"><a href="/pms/admin/complaints/<%= complaint.id%>"><span title="<%= complaint.heading %>"><%= complaint.heading %></span></a></td>
                        <td>
                         <%= complaint.category_type.try(:name).to_s + ( complaint.sub_category.present? ? " / " + complaint.sub_category.try(:name).to_s : "" ) %>
                        </td>
                        <td>
                          <% stat = complaint.issue_status.present? ? (ComplaintStatus.find_by_id(complaint.issue_status).try(:name) || complaint.issue_status ) : "pending" %>
                          <label  style="border-left: 3px solid <%= complaint.complaint_status.try(:color_code) ? complaint.complaint_status.try(:color_code) : "#00c0ef";  %>;padding-left: 4px;"><%= stat %></label>
                        </td>
                        <td><%= complaint.try(:priority) %></td>
                        <td><%= complaint.user.present? ? complaint.user.full_name : "" %></td>
                        <td><%= complaint.try(:created_at).strftime('%d/%m/%Y %H:%M %p') %></td>
                        <td>
                          <% user = User.find_by_id(complaint.try(:assigned_to)) %>
                          <% if user.present? %>
                            <%= user.fullname %>
                          <% end %>
                        </td>
                      </tr>                    
                    <% end %>
                  </tbody>
                </table>
                <%= will_paginate @complaints %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <%= link_to 'Back', setup_path %>

<script>
var config = {
  '.chosen-select'           : {},
  '.chosen-select-deselect'  : { allow_single_deselect: true },
  '.chosen-select-no-single' : { disable_search_threshold: 10 },
  '.chosen-select-no-results': { no_results_text: 'Oops, nothing found!' },
  '.chosen-select-rtl'       : { rtl: true },
  '.chosen-select-width'     : { width: '95%' }
}
for (var selector in config) {
  // $(selector).chosen(config[selector]);
}



    
    $("#updatecomplaintmul").click(function(){

      var complaint_log_ids = [] 
      var _element =  $(".update-multi");     
      for(i = 0; i < _element.length; i++ ){
        if($(_element[i]).prop("checked")){
          complaint_log_ids.push($(_element[i]).data("id"));
        }
      }

      var params = {
        assigned_to: $("#assigned_to").val(),
        priority: $("#priority").val(),
        external_priority: $("#external_priority").val(),
        complaint_mode_id: $("#complaint_mode_id").val(),
        issue_status: $("#complaint_status_id").val(),
        complaint_log_ids: complaint_log_ids      
      };


      var url = "/pms/admin/update_complaint_logs";
      var success = function(response){
        if(response.status){
          toastr.success("Updated successfully");
          window.location.href= "/pms/admin/complaints";  
        } else {
          toastr.error("Please select any option");
        }
      }

      $.ajax({
        type: "POST",
        url: url,
        beforeSend: function(xhr) {xhr.setRequestHeader('X-CSRF-Token', $('meta[name="csrf-token"]').attr('content'))},
        data: params,
        success: success
      });


       //$(".updateall").submit();
    });
</script>


   
<script type="text/javascript">
    

$(function () {
    $(document).on('click', ".update-multi",function () {
        if ($(".update-multi:checked").length > 0) {
            $("#complaint_horizontal").show();
        } else {
            $("#complaint_horizontal").hide();
        }
    });

    $(document).on("click",".all_complaint_checkbox",function(e) {
        e.stopPropagation();
        if ($(this).is(":checked")) {
            $('.update-multi').prop('checked', true);
            $("#complaint_horizontal").show();
        } else {
            $('.update-multi').prop('checked', false);
            $("#complaint_horizontal").hide();
        }
    });
});

</script>

<script>
$(document).ready(function(){
  $('.reservation').daterangepicker();
  $("#filter_container").click(function(){
    $("#myDiv").toggle();
  });
});
</script>
<script>
    // $(function () {
  
    // $('.reservation').daterangepicker();
    // });

    $(document).on("change","#category", function(){
      pms_helpdesk_subcategory_from_category($(this), $("#sub_category")) 
    });
 </script> 

  <script>
    // $('.ui.dropdown').dropdown();
    $('.applyfilter').click(function(){

      var category_type = $("#q_category_type_id_eq").val();
      var department = $("#q_dept_id_eq").val();
      var date_range = $("#date_range").val();

      var site_id = $("#q_site_id_eq").val();
      var unit_id = $("#q_unit_id_eq").val();
      var sub_category_id = $("#q_sub_category_id_eq").val();

      if(category_type == "" && department == "" && date_range == "" && site_id == "" && unit_id == "" && sub_category_id == ""){
        toastr.error("Please select any one filter");
        return false;
      }

      $("#filters").submit();
    });
  </script>
