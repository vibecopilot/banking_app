<script type="text/javascript">

  jQuery(document).ready(function($) {
    $('#customSort').multiselect({
        sort: false
    });
    $('.helpdesk_reports_picker').daterangepicker({
      opens: 'left',
      locale: {
        format: 'MM/DD/YYYY'
      },
      maxSpan: {
          "days": 92
      },
      // startDate: "<%#= params[:q][:created_at_gteq].to_date.strftime('%m/%d/%Y') %>",
      // endDate: "<%#= params[:q][:created_at_lteq].to_date.strftime('%m/%d/%Y') %>"

      dateLimit: {
         'months': 3
       }
    });
  });
  $('#advanced-filter-link').on("click", function() {
    displayAdvancedFilterForExport()
   });

  function displayAdvancedFilterForExport() {
    var x = document.getElementById("extra-options");
    if (x.style.display === "none") {
        x.style.display = "block";
    } else {
        x.style.display = "none";
    }
  }

  $('.ui.dropdown').dropdown();

  $("#export-btn").click(function(r){
    r.preventDefault();
    a=$("#customSort_to option").length;
    if(a < 1){
      toastr.error("Please select columns to export");
      return false;
    }
    else{
       $("#export-csv-form").submit();
       $(this).attr('disabled', 'disabled');
    }
  });


  // $('#export-btn').attr('disabled', 'disabled');
  $('.export-date-range').change(function(e){
    if($(this).val != ""){
      $('#export-btn').removeAttr('disabled');
    }
    else
    {
      // $('#export-btn').attr('disabled', 'disabled');
    }
  });

  $('.export-date-range').keyup(function() {

      var isEmpty = false;
      $('.export-date-range').each(function() {
          if ($(this).val() == '') {
              isEmpty = true;
          }
      });

      if (isEmpty) {
          $('#export-btn').attr('disabled', 'disabled');
      } else {
          $('#export-btn').removeAttr('disabled');
      }
  });

  $("#pms_zone_headquarter_id").change(function(){
    $("#pms_zone_region_id").html("<option value = ''>Select Region</option>");
    $("#pms_zone_region_id").trigger("chosen:updated");
    var headquarter_id = $(this).val();
    if(headquarter_id != null){
      $.ajax({
        type: 'GET',
        url: '/pms/admin/complaints/'+headquarter_id+'/regions',
        dataType: 'json',
        success: function(data){
          $("#pms_zone_region_id").html("<select class = 'form-control' required = 'required' name = 'q[region_id_in][]' id = 'pms_zone_region_id'>");
          $("#pms_zone_region_id").html("<option value = ''>Select Region</option>");
          for(i=0; i < data.regions.length; i++){
            $("#pms_zone_region_id").append("<option value='" + data.regions[i].id + "' >" + data.regions[i].name +"</option>");
          }
          $("#pms_zone_region_id").append("</select>");
          $("#pms_zone_region_id").trigger("chosen:updated");
        }
      });
    }
    else{
      $("#pms_zone_region_id").html("<option value = ''>Select Region</option>");
      $("#pms_zone_region_id").trigger("chosen:updated");
      $(".sites,.zones,.regions").each(function(){
        $(this).find(".icon").click();
      });
    }
  });

  $("#pms_zone_region_id").change(function(){
    $("#pms_zone_id").html("<option value = ''>Select Zone</option>");
    $("#pms_zone_id").trigger("chosen:updated");
    var region_id = $(this).val();
    if(region_id != null || region_id > 0){
      $.ajax({
        type: 'GET',
        url: '/pms/admin/complaints/'+region_id+'/zones',
        dataType: 'json',
        success: function(data){
          $("#pms_zone_id").html("<select class = 'form-control' required = 'required' name = 'q[zone_id_in][]' id = 'pms_zone_id'>");
          $("#pms_zone_id").html("<option value = ''>Select Zone</option>");
          for(i=0; i < data.zones.length; i++){
            $("#pms_zone_id").append("<option value='" + data.zones[i].id + "' >" + data.zones[i].name +"</option>");
          }
          $("#pms_zone_id").append("</select>");
          $("#pms_zone_id").trigger("chosen:updated");
        }
      });
    }
    else{
      $("#pms_zone_id").html("<option value = ''>Select Zone</option>");
      $("#pms_zone_id").trigger("chosen:updated");
      $(".sites,.zones").each(function(){
        $(this).find(".icon").click();
      });
    }
  });

  $("#pms_zone_id").change(function(){
    $("#pms_site_id").html("<option value = ''>Select Site</option>");
    $("#pms_site_id").trigger("chosen:updated");
    var zone_id = $(this).val();
    if(zone_id != null){
      $.ajax({
        type: 'GET',
        url: '/pms/admin/complaints/'+zone_id+'/sites',
        dataType: 'json',
        success: function(data){
          $("#pms_site_id").html("<select class = 'form-control' required = 'required' name = 'q[pms_site_id_in][]' id = 'pms_site_id'>");
          $("#pms_site_id").html("<option value = ''>Select Site</option>");
          for(i=0; i < data.sites.length; i++){
            $("#pms_site_id").append("<option value='" + data.sites[i].id + "' >" + data.sites[i].name +"</option>");
          }
          $("#pms_site_id").append("</select>");
          $("#pms_site_id").trigger("chosen:updated");
        }
      });
    }
    else{
      $("#pms_site_id").html("<option value = ''>Select Site</option>");
      $("#pms_site_id").trigger("chosen:updated");
      $(".sites").each(function(){
        $(this).find(".icon").click();
      });
    }
  });

  // tail.select(".select", {
  //     search: true
  // });
  $(function() {
      $( "#report-accordion" ).accordion({'collapsible':true,'active':false});
 });
</script>