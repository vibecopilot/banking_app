<style type="text/css">
  .attach-img{
    display: inline-block !important;
  }
  .attach-img img {

    width: 100px !important;
    height: 100px !important;
}
.request-add{
  width: 50px !important;
  height: 25px !important;
}

.file .file-name i{
    position: absolute !important;
    right: 0px !important;
    top: 4px !important;
    font-size: 12px !important;
    color: #555 !important;
}

table {
  border-collapse: collapse;
  width: 100%;
  border: 1px solid #000 !important;
}

table thead tr th, table tbody tr td {
  border: 1px solid #000 !important;
  padding: 1.2rem !important;
}

table thead tr th {
  background: #e4e4e4 !important;
}

.extra-bottom-padding{
  padding-bottom: 100px;
}

.upload {
    padding: 10px;
    border: 2px dashed #eee;
    text-align: center;
    width: 75%;
    display: inline-block;
    border-radius: 5px;
    cursor: pointer;
    margin: 0px 5px !important;
}
</style>    
    <div class="wrapper wrapper-content">
      <section class="content">
        <div class="ibox">
          <div class="ibox-content extra-bottom-padding">
            <div class="row">
              <div class="col-sm-12">
                <div class="header-title movein-border">
                  <h2 class="movein-bg">Edit</h2>
                </div>
                <% @complaint_log = ComplaintLog.new %>
                <%= form_for(@complaint_log, url: "/complaint_logs", html: { multipart: true }) do |f| %>
                <div class="col-xs-6">                                    	
								  <%= f.hidden_field :complaint_id, :value => @complaint.id %>
                  <%= hidden_field_tag :save_and_show_detail, :value => 'true' %> 
                  <%= f.hidden_field :society_staff_type, :value => "Spree::User" %>
								  <%= hidden_field_tag "custom_redirect" ,value = "/pms/admin/complaints/#{@complaint.id}"%>
                    <input type="hidden" name="complaint[complaint_type]" value="<%= @complaint.complaint_type%>">
								  	<input type="hidden" name="complaint_comment[docs][]" id="complaint_image">
                    <div class="row form-group">
                      <label class="col-sm-3 control-label">Title</label>
                      <div class="col-sm-9">
                      <%= text_area_tag "complaint[heading]", @complaint.heading,  :placeholder => "Description", :class => "textbox desc", disabled: true%>
                    </div>
                    </div>
                    <div class="row form-group">
                    	<% @ss= ComplaintStatus.where(society_id: @user.current_site_id).order(:position).collect{ |p| [p.name,p.id] }%>
                      <label class="col-sm-3 control-label">Status</label>
                      <div class="col-sm-9">
                        <%= f.select :complaint_status_id, options_for_select(@ss, :selected => @complaint.issue_status.try(:to_i)),{:include_blank=>"Select Status"},{:class => 'form-control'}%>
                      </div>
                    </div>
                      <% @helpdesk_categories = HelpdeskCategory.pms.where(society_id: @user.current_site_id).active.collect{ |h| [h.name, h.id] } %>        
                    <div class="row form-group">
                      <label class="col-sm-3 control-label">Category Type</label>
                      <div class="col-sm-9">                         
                        <%= select_tag 'complaint[category_type_id]', options_for_select(@helpdesk_categories , {:selected => @complaint.category_type_id, :include_blank=>"Select Category Type"}),{:class => 'form-control selectpicker category-type'}%>
                      </div>
                    </div>
                    <div class="row form-group">
                      <label class="col-sm-3 control-label">Sub Category Type</label>
                      <div class="col-sm-9">
                      <%#= select_tag 'complaint[sub_category_id]', options_for_select(@helpdesk_categories , {:selected => @complaint.sub_category, :include_blank=>"Select Sub Category Type"}),{:class => 'form-control selectpicker'}%>
                      <%# binding.pry %>
                      <% @sbs = @complaint.category_type_id.present? ? HelpdeskCategory.find(@complaint.category_type_id).helpdesk_sub_categories : [] %>
                      <select class="form-control selectpicker sub_category sub-categories" name="complaint[sub_category_id]" id="complaint_log_sub_category_id" value="<%= @complaint.sub_category_id%>">
                        <option value="">Select Sub Category</option>
                        <% @sbs.each do |sc|%>
                          <option data-ht="<%= sc.helpdesk_text %>" value="<%= sc.id%>" <%= @complaint.sub_category_id == sc.id ? 'selected' : '' %>><%= sc.name %></option>
                        <% end %>
                      </select>
                      </div>
                    </div> 
                    <div class="row form-group">
                      <label class="col-sm-3 control-label">Priority</label>
                      <div class="col-sm-9">
                        <%= f.select :priority, options_for_select(['P1','P2','P3','P4','P5'], :selected => @complaint.priority),{:include_blank => "Select Admin Priority"},{:class => 'form-control'}%>
                      </div>
                    </div>               
                </div>
                <div class="col-xs-6">

                  <%# @ws = Spree::User.where(site_id: @user.selected_pms_site.pms_site.id) %>
                  <% @ws = User.where(id: UserSite.where(site_id: @user.current_site_id).pluck(:user_id), user_type: ["pms_technician", "pms_admin"]) %>
                  <div class="row form-group">
                    <label class="col-sm-3 control-label">Assigned To</label>
                    <div class="col-sm-9">
                      <%= f.select :assigned_to, options_for_select(@ws.map {|s| [(s.full_name), s.id]}, :selected => @complaint.assigned_to),{:include_blank=>"Select Assignee"},{:class => 'chosen-select'} %>
                    </div>
                  </div>

                  <% @territorymanager = User.where(user_type: "Tm") %>
                  <div class="row form-group">
                    <label class="col-sm-3 control-label">Approving Authority</label>
                    <div class="col-sm-9">
                      <%= select_tag "complaint[territory_manager_id]", options_for_select(@territorymanager.map {|s| [(s.full_name), s.id]}, :selected => @complaint.try(:territory_manager_id)), :include_blank=>"Select Approving Authority", :class => 'form-control pull-right' %>
                    </div>
                  </div>

                  <div class="row form-group">
                    <label class="col-sm-3 control-label">Comment</label>
                      <div class="col-sm-9">
                        <div class="form-group">
                        <textarea class="form-control border pad10" id="" name="complaint_log[comment]" placeholder="Add Comment" rows="1"></textarea>
                      </div>
			                  <div class="upload">
                        <ul id="media-list" class="clearfix">
                          <li class="myupload"><span><i class="fa fa-plus" aria-hidden="true"></i>
                          <input type="file" name="complaint_comment[attachments][]" click-type="type2" id="picupload2" class="picupload" multiple>
                        </span> </li>
                        </ul>
                      </div>
                      </div>
                    </div>

                </div>
                  <div class="col-xs-12">
                    <!-- <div class="row form-group">
                        <label>
                        Cost Involved
                          <%= check_box_tag 'complaint[cost_involved]', true, @complaint.cost_involved? %>
                      </label>
                    </div> -->
                    <!-- <button class="btn btn-md btn-primary">Add</button> -->
                    <div class="row form-group request-section" style="display: none">
                      <%= fields_for @complaint do |complaint| %>
                        <div class='links col-sm-12' style="padding: 15px">
                            <%= link_to_add_association raw("<button class='btn btn-md btn-primary request-add'>Add</button>"), complaint, :cost_approval_requests, class: "btn btn-xs btn-primary" %>
                        </div>
                        <label> Cost Approval Requests </label>                          
                        <div class="request-fields">
                          <div class="col-sm-12">
                            <div class="form-title" style="padding: 15px;">
                              <div style="width: 100%; overflow-x: auto;">
                              <table>
                                <thead>
                                  <tr>
                                    <th style="width: 8%;">Request Id</th>
                                    <th style="width: 8%;">Amount</th>
                                    <th style="width: 25%;">Comments</th>
                                    <th style="width: 10%;">Created On</th>
                                    <th style="width: 10%;">Created By</th>
                                    <th style="width: 8%;">L1</th>
                                    <th style="width: 8%;">L2</th>
                                    <th style="width: 8%;">L3</th>
                                    <th style="width: 8%;">L4</th>
                                    <th style="width: 8%;">L5</th>
                                    <th>Master Status</th>
                                    <th>Cancelled By</th>
                                    <!-- <th >Action</th> -->
                                    <th>Attachments</th>
                                  </tr>
                                </thead>

                                <tbody>
                              <% @complaint.cost_approval_requests.each do |request| %>

                                  <tr>
                                    <td><%= request.try(:id) %></td>
                                    <td><%= request.try(:cost) %></td>
                                    <td><div><%= request.try(:comment) %></div></td>
                                    <td><%= request.try(:created_at).try(:strftime,'%d/%m/%Y') %></td>
                                    <td><%= Spree::User.find_by(id: request.created_by_id).try(:full_name) %></td>
                                    <% @cost_hist = request.cost_approval_histories %>
                                      <%  if @cost_hist.present? 
                                            level1 = "" 
                                            level2 = "" 
                                            level3 = ""
                                            level4 = ""
                                            level5 = ""
                                            @cost_hist.each do |level|
                                              level_nm = level.cost_approval_level.name
                                              if level_nm.include?("L1")
                                                level1 = level.status
                                              elsif level_nm.include?("L2")
                                                level2 = level.status
                                              elsif level_nm.include?("L3")
                                                level3 = level.status
                                              elsif level_nm.include?("L4")
                                                level4 = level.status
                                              elsif level_nm.include?("L5")
                                                level5 = level.status
                                              end 
                                            end
                                          end
                                      %>
                                    <td><%= level1.present? ? level1.try(:titleize) : "NA" %> </td>
                                    <td><%= level2.present? ? level2.try(:titleize) : "NA" %></td>
                                    <td><%= level3.present? ? level3.try(:titleize) : "NA" %></td>
                                    <td><%= level4.present? ? level4.try(:titleize) : "NA" %></td>
                                    <td><%= level5.present? ? level5.try(:titleize) : "NA" %></td>
                                    <% 
                                      if @cost_hist.present? && @cost_hist.count > 1 && @cost_hist.pluck(:status).include?("pending") 
                                        @master_status = "Partially Approved"
                                      else 
                                        @master_status = request.status.present? ? request.status : "pending"
                                      end                                    
                                    %>
                                    <td><%= @master_status.titleize %></td>
                                    <td><%= request.cost_approval_histories.where(status: "cancelled").try(:last).try(:updated_by).try(:full_name) || "NA" %></td>
<!--                                     <td>
                                      <a href="/costapprequpdate/<%= request.id %>" class="btn btn-xs btn-danger" data-confirm="Are you sure you want to delete?" data-method="delete" style="margin-left: 29px;"><i class="fa fa-times"></i></a> 
                                    </td> -->
                                    <td>
                                      <div data-toggle="modal" data-target="#myModal<%= request.id %>">
                                        <% if request.try(:attachments).try(:count) > 0  %>
                                        <i class="fa fa-paperclip" aria-hidden="true"></i>
                                        <span class="cnt" style="border: 1px solid orange;border-radius: 100%;display: inline-block;width: 20px;height: 20px;padding: 0.2rem;text-align: center;background: orange;color: #fff;">+<%= request.try(:attachments).try(:count) %></span>
                                        <% else %>
                                        <span></span> 
                                        <% end %>       
                                      </div>
                                    </td>
                                  </tr>
                              <% end %>
                                </tbody>

                              </table>
                              </div> 
                            </div>
                          </div>
                          <% end %>
                        </div>
                    </div>
                  </div>
              </div>
              <div class="col-sm-12 text-center">
                <div class="hr-line-dashed"></div>
                <button type='button' id="submitbtn" class="btn btn-success btn-sm"/>Submit & Show Detail</button>
              </div>
            <%end%>
            </div>
          </div>
        </div>
      </section>
    </div>
<% @complaint.cost_approval_requests.each do |request| %>
  <% if request.try(:attachments).try(:count) > 0 %>
    <div class="modal fade" id="myModal<%= request.id %>" role="dialog">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header" style="background: #31b0d5; color: #fff;">
              <button type="button" class="close" data-dismiss="modal">&times;</button>
              <h4 class="modal-title">Attachments</h4>
            </div>
            <div class="modal-body" style="height: 350px; overflow-y: auto;">
              <div style="display: grid; grid-template-columns: repeat(4, 125px); justify-content: center; grid-gap: 10px;">
                <%= render "pms/manage/complaints/documents", object: request.attachments %>
              </div>
            </div>
          </div>
        </div>
    </div>
  <% end %>
<% end %>
  <script>
	  $(document).ready(function(){
	    // $('.bxslider').bxSlider();

      // $('.request-add').click();
	  });
	  var workers = '<%= @jn.to_json %>';
	  var wos = JSON.parse(workers.replace(/&quot;/g,'"'));

	  $("#location_level1").change(function(){
    	location_level2_from_level1($(this), $("#location_level2")) 
  	});

	  $("#location_level2").change(function(){
	    pms_area_from_wing($(this), $("#location_level3")) 
	  });

    if ($('#complaint_cost_involved').prop('checked')){
        $('.request-section').show();
      } else {
        $('.request-section').hide();
      }

    $('#complaint_cost_involved').click(function() {
      if ($(this).prop('checked')){
        $('.request-section').show();
      } else {
        $('.request-section').hide();
      }
    });

    $("#submitbtn").click(function(){
      if ($('.well img').length > 0 && $('[name="complaint_log[comment]"]').val() == "") {
        toastr.error('Please enter comment');
        return false;
      }
      $('.well img').each(function(){
        pres = $(this).attr('src');
        pres = pres.replace('data:image/png;base64,', "")
        pres = pres.replace('data:image/jpg;base64,', "")
        pres = pres.replace('data:image/jpeg;base64,', "")
        $("#complaint_image").parents("form").append($('<input type="hidden" name="complaint_comment[docs][]" value='+ pres +' > '))
      });
      $('[name="complaint_comment[doc]"]').val("");

      if($("#complaint_cost_involved").prop("checked")){
        var a =[];
        $('.request-fields .nested-fields:visible').each(function() {
          if($(this).find(".cost").val() == ""){
            a.push('true');
          }
        });
        if (a.length > 0){
          toastr.error('Please Enter Cost');
          return false;
        }
      }
      if($("#root_cause").val() == "" || $("#impact").val() == "" || $("#correction").val() == "" || $("#corrective_action").val() == "" || $("#preventive_action").val() == "" || $("#person_id").val() == "" || $("#review_tracking").val() == "" || $("#supplier_id").val() == "" || $("#proactive_reactive").val() == "" ){
        if(confirm("You have not updated all the fields, are you sure you want to submit ?")){
          $("#new_complaint_log").submit();
        }
        else{
          return false;
        }
      }
      else{
          $("#new_complaint_log").submit();
        }
    });

	  $(function () {
	    //Date picker
	    var nowDate = new Date();
	    var today = new Date(nowDate.getFullYear(), nowDate.getMonth(), 
	      nowDate.getDate(), 0, 0, 0, 0);

	    $(".complaint_datepicker").datepicker({
	      // dateFormat: 'dd/mm/yy',
	      autoclose: true,
	      startDate : today
	    });
	  });

	  jQuery(document).ready(function(){
	  jQuery("#assigned_to").val(location.pathname)
	  });


	  /* Initialize the gallery */
	  // jQuery("#thumbGallery").thumbGallery();

	  /* customizer */
	  jQuery("#effect").on("change",function(){
	      var x = $(this).val();
	      jQuery("#thumbGallery").data("nav_effect", x);
	  });

	  jQuery("#delay").on("change",function(){
	      var x = parseFloat($(this).val());
	      jQuery("#thumbGallery").data("nav_delay", x);
	  });

	  jQuery("#timing").on("change",function(){
	      var x = parseFloat($(this).val());
	      jQuery("#thumbGallery").data("nav_timing", x);
	  });

	  if(jQuery.isMobile){
	      jQuery("body").css({marginBottom: 140})
	  }

	  $('.ui.dropdown').dropdown();
    var selefile;
	  $(document).ready(function() {
	     var readURL2 = function(input) {
	        if (input.files.length > 0) {
            for (i = 0; f=input.files[i]; i++) {
  	          var reader = new FileReader();
  	          reader.onload = (function(f) {
                return function(e) {
                selefile = f;
                if(selefile.type == "image/jpeg" || selefile.type == "image/png" || selefile.type == "image/jpg"){
                  $('.well').append($('<div class="attach-img"><i class="fa fa-times remove-img" aria-hidden="true" ></i><img src="' + e.target.result + '" alt="" class="img-thumbnail"></div>'));
                }else{
                  $('.well').append($('<div class="attach-img"><i class="fa fa-times remove-img" aria-hidden="true" ></i><img src="/assets/default_file_image.png" title="' + selefile.name + '" class="img-thumbnail"></div>'));
                }

    	            $(".remove-img").off("click");
    	            $(".remove-img").click(function(){ $(this).parent().remove(); });
    	          };
              })(f);
  	          reader.readAsDataURL(f);
          }
	     }
	    }    
	    $("#comment_doc").on('change', function(){
	      readURL2(this);
	    });
	  });




    $('.category-type').change(function() {
      var category_type_id = $(this).val();
      var url = "/pms/admin/get_sub_categories.json?category_type_id=" + category_type_id + "&token=" + gon.token;
      var success = function(response){

        var sub_categories_options = "<option value=''>Select Sub Category</option>";
          
        if(response.sub_categories.length > 0){
          for (var i = 0; i < response.sub_categories.length; i++) {
            var sub_category = response.sub_categories[i];
            sub_categories_options += "<option data-ht='"+sub_category.helpdesk_text +"'  value='"+sub_category.id+"'>"+sub_category.name+"</option>"
          }
        }

        $(".sub-categories").html(sub_categories_options);
        $('#complaint_log_assigned_to').val(response.assigned_to);
      }

      $.ajax({
        type: "GET",
        url: url,
        success: success
      });
  });
  $(function () {
    $("[name=checklist_type]").click(function(){
      if($("#asset").prop("checked")){
        $('.asset-list').show();
        $('.service-list').hide();
        $("#service_id").val("").trigger("chosen:updated");
      }
      else if($("#service").prop("checked")){
        $('.asset-list').hide();
        $("#asset_id").val("").trigger("chosen:updated");
        $('.service-list').show()
      }
    });
    if($("#asset").prop("checked")){
      $('.asset-list').show();
      $('.service-list').hide();
      $("#service_id").val("").trigger("chosen:updated");
    }
    else if($("#service").prop("checked")){
      $('.asset-list').hide();
      $("#asset_id").val("").trigger("chosen:updated");
      $('.service-list').show()
    }
    $('.ui.dropdown').dropdown();
  });
</script>