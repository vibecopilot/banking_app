                      <div class="divTableCell">
                        <%= select_tag 'escalation_matrix[e3][escalate_to_users][]', options_for_select( @usmapped, :selected => e3.try(:escalate_to_users)), :class=>" ui fluid search dropdown multiple", :multiple =>true %>
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e3][p1]" class="form-control" value="<%= e3.try(:p1) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e3][p2]" class="form-control"  value="<%= e3.try(:p2) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e3][p3]" class="form-control" value="<%= e3.try(:p3) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e3][p4]" class="form-control" value="<%= e3.try(:p4) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e3][p5]" class="form-control" value="<%= e3.try(:p5) %>">
                      </div>
                    </div>
                    <div class="divTableRow">
                    <% e4 = @complaint_worker.escalations.where(name: "E4").try(:last) %>
                      <div class="divTableCell">E4<input type="hidden" name="escalation_matrix[e4][name]" value="E4"></div>
                      <div class="divTableCell">
                        <%= select_tag 'escalation_matrix[e4][escalate_to_users][]', options_for_select( @usmapped, :selected => e4.try(:escalate_to_users)), :class=>" ui fluid search dropdown multiple", :multiple =>true %>
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e4][p1]" class="form-control" value="<%= e4.try(:p1) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e4][p2]" class="form-control"  value="<%= e4.try(:p2) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e4][p3]" class="form-control" value="<%= e4.try(:p3) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e4][p4]" class="form-control" value="<%= e4.try(:p4) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e4][p5]" class="form-control" value="<%= e4.try(:p5) %>">
                      </div>
                    </div>
                    <div class="divTableRow">
                    <% e5 = @complaint_worker.escalations.where(name: "E5").try(:last) %>
                      <div class="divTableCell">E5<input type="hidden" name="escalation_matrix[e5][name]" value="E5"></div>
                      <div class="divTableCell">
                        <%= select_tag 'escalation_matrix[e5][escalate_to_users][]', options_for_select( @usmapped, :selected => e5.try(:escalate_to_users)), :class=>" ui fluid search dropdown multiple", :multiple =>true %>
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e5][p1]" class="form-control" value="<%= e5.try(:p1) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e5][p2]" class="form-control"  value="<%= e5.try(:p2) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e5][p3]" class="form-control" value="<%= e5.try(:p3) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e5][p4]" class="form-control" value="<%= e5.try(:p4) %>">
                      </div>
                      <div class="divTableCell">
                        <input type="text" name="escalation_matrix[e5][p5]" class="form-control" value="<%= e5.try(:p5) %>">
                      </div>
                    </div>
                  </div>
                </div>
                
              </div>
      </div>
      <div class="modal-footer">
        <button type="submit" class="btn btn-primary">Update</button>
      </div>
    </div>
    <% end %>
  </div>
</div>