<script>
var compare_chart1 = false;
var compare_chart2 = false;
  $(function () {
    $('#helpdesk-report-table').DataTable({
      "paging": true,
      "lengthChange": true,
      "searching": true,
      "ordering": true,
      "info": true,
      "autoWidth": true
    });
  });


  reselect_flats_options =function(value){
    $.ajax({
      type: "GET",
      url: "/crm/admin/society_flats.json?q[society_block_id_eq]=" + value,
      success: function(datas){
       var sfs = datas["society_flats"];
       var str = "<option value=''> Select flat </option>";
       for(var x=0; x< sfs.length; x++){
         str += "<option value='"+sfs[x]["flat_no"]+"'>" + sfs[x]["flat_no"] + "</option>";
       }
       $('[name="q[user_society_user_flat_society_flat_flat_no_eq]"]').html("").html($(str));
      }
    });
  }

  $('[name="q[user_society_user_flat_society_flat_society_block_id_eq]"]').change(function(e){
    reselect_flats_options($(this).val());
  });

jQuery(document).ready(function($) {
  $('#customSort').multiselect({
      sort: false
  });

   $('.helpdesk_reports_picker').daterangepicker({
      locale: {
        format: 'DD/MMM/YYYY'
      }
    });

  $('.ui.dropdown').dropdown();
  
  $("#export-btn").click(function(r){
    r.preventDefault();
    a=$("#customSort_to option").length;
    if(a < 1){
      toastr.error("Please select columns to export");
      return false;
    }
    else{
       $("#export-csv-form").submit();
    }
  });


  $('#export-btn').attr('disabled', 'disabled');
  $('.export-date-range').change(function(e){
    if($(this).val != ""){
      $('#export-btn').removeAttr('disabled');
    }
    else
    {
      $('#export-btn').attr('disabled', 'disabled');
    }
  });

  $('.export-date-range').keyup(function() {

      var isEmpty = false;
      $('.export-date-range').each(function() {
          if ($(this).val() == '') {
              isEmpty = true;
          }
      });

      if (isEmpty) {
          $('#export-btn').attr('disabled', 'disabled');
      } else {
          $('#export-btn').removeAttr('disabled');
      }
  });


  $('#compare-button').attr('disabled', 'disabled');

  $('.compare-date-range').keyup(function() {

      var isEmpty = false;
      $('.compare-date-range').each(function() {
          if ($(this).val() == '') {
              isEmpty = true;
          }
      });

