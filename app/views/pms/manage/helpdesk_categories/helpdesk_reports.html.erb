            <div class="row">
              <div class="col-sm-12">
                <button type="button" id="export-btnn" class="btn btn-info btn-sm" data-toggle="modal" data-target="#export"><i class="fa fa-download margin-r-5" aria-hidden="true"></i> Export</button>
              </div>
            </div>
            <div class="hr-line-dashed"></div>
            <div class="row">
              <div class="col-sm-12">
                <center><h5>Showing Records From: <%= DateTime.now.beginning_of_month.strftime('%d/%m/%Y') %> To: <%= DateTime.now.strftime('%d/%m/%Y') %></h5></center>
                <table id="helpdesk-report-table" class="ui celled structured table hover text-left" style="width:100%">
                  <thead>
                    <tr>
                      <th>Id</th>
                      <th>Ticket Number</th>
                      <th>Title</th>
                      <th>Flat</th>
                      <th>Issue Type</th>
                      <th>Category</th>
                      <th>Assign To</th>
                      <th>Comment</th>
                      <th>Rating</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @complaints.each do |complaint| %> 

                      <tr>
                        <td><%= complaint.id %></td>
                        <td><%= complaint.ticket_number %></td>
                        
                        <td class="project-title"><a href="<%= manage_complaint_path(complaint)%>">
                          <%= complaint.heading %> </a> 
                          <small class="link-black">Created - 
                          <%= complaint.created_at.strftime('%d/%m/%Y')%></small><br>
                          
                          <%if complaint.complaint_type == "Complaint" %>
                            <span class="label label-danger margin-r-10">
                            <%= complaint.complaint_type  %>
                            </span>
                          <%elsif complaint.complaint_type == "Suggestion" %>
                            <span class="label label-info margin-r-10"><%= complaint.complaint_type  %></span>
                          <% elsif complaint.complaint_type == "Request" %> <span class="label 
                            label-warning margin-r-10">
                            <%= complaint.complaint_type  %>
                            </span>
                            
                          <% end %> 

                          <% if complaint.priority.present? %> 
                            <span class="label label-danger">
                             <%=  complaint.try(:priority) %>
                            </span>
                          <% end %>
                        
                        </td>
                        

                        <td>
                          <% if complaint.user_society.present? %>
                            <%= complaint.user_society.user_flat.try(:block) %>-<%= complaint.user_society.user_flat.try(:flat) %>
                          <% end %> 
                        </td>
                        
                        <td>
                          <%= complaint.issue_type.present? ? 
                          complaint.issue_type.try(:name): " " %>
                        </td>
                        
                        <td>
                         <%= complaint.category_type.try(:name) %>
                        </td>
                        
                        <td>
                          <%= complaint.society_staff.try(:full_name)%>
                          <% eh = EscHistory.where(complaint_id: complaint.id)
                          %>
                          <% if eh.present? %>
                          <% esc = EscalationMatrix.find(eh.last.esc_id)%>
                          <span class="label label-border"><%= esc.name %></span> <span class="font12"><%= UserSociety.where(id: esc.escalate_to_users).last.try(:user_full_name) %></span><br>
                          <% end %>
                          
                          
                            <span class="label label-info margin-r-5"> 
                            <%= complaint.issue_status.present? ? (ComplaintStatus.find_by_id(complaint.issue_status).try(:name) || complaint.issue_status ) : "pending" %>
                            </span>
                          

                          <% if complaint.urgency == 1 %> 
                            <span class="label label-danger">High</span>
                           
                          <% elsif complaint.urgency == 2 %>
                           <span class="label label-default">Medium</span>
                          <% elsif complaint.urgency == 3 %>
                           <span class="label label-success">Low
                           </span>
                          <% elsif complaint.is_urgent == true  %>
                           <span class="label label-danger">High
                           </span>
                          <% elsif !complaint.is_urgent == true %>
                           <span class="label label-success">Low
                           </span>
                          <% end%> 
                        
                         </td>
                        
                        <% @complaint_comments = ComplaintComment.where(complaint_id: complaint.id)
                          %>

                        <td>
                          <% if complaint.complaint_comments.present? %>
                          <span class="comment-text">
                            <%= complaint.complaint_comments.last. comment %></span>
                           <small class="text-muted"><%= complaint.complaint_comments.last.user.try(:full_name) %> <%= complaint.complaint_comments.last.created_at.strftime('%d %m %Y/ %l: %M %p')%>
                            </small>
                          <% end %>  
                        </td>

                        <td>
                          <% if complaint.feedbacks.present? %>
                            <%if complaint.feedbacks.last.rating == 1 %>
                              Terrible
                            <% elsif complaint.feedbacks.last.rating == 2 %>
                              Bad
                            <% elsif complaint.feedbacks.last.rating == 3 %>
                              Okay
                            <% elsif complaint.feedbacks.last.rating == 4 %>
                              Good
                            <% elsif complaint.feedbacks.last.rating == 5 %>
                              Great
                            <%end%>
                          <%end%>
                        </td>
                        
                        
                        <td><a href="<%= manage_complaint_path(complaint)%>"><i class="fa fa-eye view" 
                          aria-hidden="true"></i></a>
                        </td>
                      

                      </tr>
                     
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>

<% if @complaints.blank? %>
