<div class="modal fade" id="esc_edit_response<%= @complaint_worker.id %>" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" style="display: none;">
  <div class="modal-dialog modal-lg" role="document">
  <%= form_for(ComplaintWorker.new,  :url => "/pms/admin/update_complaint_worker" ) do |f| %>
  <%= f.hidden_field "id", :name => "id", :value => @complaint_worker.id %>
    <%= f.hidden_field "custom_redirect", :name => "custom_redirect", :value =>  "/pms/admin/helpdesk_categories"  %>
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">×</span></button>
        <h4 class="modal-title" id="myModalLabel">Edit</h4>
      </div>
      <div class="modal-body">
       <div class="row">
          <div class="form-group col-sm-4">
            <label>Category Type</label>
            <%= select_tag 'complaint_worker[category_id]', options_for_select( @helpdesk_categories_mapped, :selected => @complaint_worker.category_id), :class=>"form-control" %>
          </div>

          <div class="clearfix"></div>
             <hr> 
            <div class="divTable">
                  <div class="divTableHeading">
                    <div class="divTableRow">
                      <div class="divTableCell width10">Levels</div>
                      <div class="divTableCell width22">Escalation To</div>
                    </div>
                  </div>
                <div class="divTableBody">
                      <% (1..5).each do  |e|  %>
                        <div class="divTableRow">
                          <% ea = @complaint_worker.escalations.where(name: "E#{e}").try(:last) %>
                            <div class="divTableCell">E<%= e%></div>
                          <div class="divTableCell">
                            <input type="hidden" name="escalation_matrix[e<%= e %>]][name]" value="E<%= e %>">

                            <%= select_tag "escalation_matrix[e#{e}][escalate_to_users][]", options_for_select(@usmapped, :selected => ea.try(:escalate_to_users)), :class=>" ui fluid search dropdown multiple", :multiple =>true %>
                          </div>
                        </div>
                      <% end %>
                </div>
            </div>

      
    </div>
      </div>
      <div class="modal-footer">
        <button type="submit" class="btn btn-primary updateesc">Update</button>
      </div>
    </div>
    <% end %>
  </div>
</div>
