<div class="wrapper wrapper-content">
  <section class="content">
    <div class="row help">
      <div class="col-sm-12">
        <div class="tabs tabs-style-flip extra-bottom-padding">
          <nav>
            <ul>
              <li><a href="#section-linemove-1" class="icon icon-home section-check"><span>Setup</span></a></li>
              <li><a href="#section-linemove-2" class="icon icon-box section-check"><span>Escalation Setup</span></a></li>
              <!-- <li><a href="#section-linemove-3" class="icon icon-box section-check"><span>Cost Approval</span></a></li>  -->
            </ul>
          </nav>      
          <%  @us = User.where('user_type IN (?)',  ["admin", "pms_admin"]).ransack(sites_id_eq: @user.current_site_id).result
            @staff = User.where('user_type IN (?)',  ["pms_technician"]).ransack(sites_id_eq: @user.current_site_id).result 
            @helpdesk_categories_mapped = @helpdesk_categories.map {|s| [s.name, s.id]}
            @sstaff = @staff.map {|s| [s.full_name, s.id]}
            admin_users = User.where(id: @us.pluck(:id)).ransack(params[:q]).result
            @usmapped =  admin_users.map {|s| [s.full_name, s.id]}
          %>

          <div class="content-wrap">
            <section id="section-linemove-1">
              <div class="col-sm-12">
                <div class='tabsholder3'>
                
                  <div data-tab="Category Type">
                    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 category-tab-container">
                      <div class="col-lg-2 col-md-2 col-sm-2 col-xs-2 category-tab-menu">
                        <div class="list-group"> <a href="#" class="list-group-item active text-center"> Category</a> <a href="#" class="list-group-item text-center"> Sub Category</a> </div>
                      </div>
                      <div class="col-lg-10 col-md-10 col-sm-10 col-xs-10 category-tab">
                        <div class="category-tab-content active", style="padding: 15px 0px;">
                          <div class="content-wrap">
                            <div class="row help">

                            <%= form_for([:manage, HelpdeskCategory.new], :url => "/pms/admin/helpdesk_categories") do |f| %>
                              <div class="col-sm-12">
                                  <%= f.hidden_field :society_id, :value => @user.current_site_id %>
                                  <%= f.hidden_field :of_phase, :value => "pms" %>
                                  <%= f.hidden_field "custom_redirect",:value =>  "/pms/admin/helpdesk_categories"  %>
                                  <div class="col-sm-3">
                                    <input type="text" class="form-control" name="helpdesk_category[name]" placeholder="Enter Category" required=true>
                                  </div>
                                  <div class="col-sm-3">
                                    <%= select_tag 'complaint_worker[assign_to][]', options_for_select(@sstaff),:include_blank => "Select Engineer", :class=>"form-control" %>
                                  </div>
                                  <div class="col-sm-3">
                                    <input type="text" class="form-control" name="helpdesk_category[tat]" required=true maxlength= 4 onkeypress='return event.charCode >= 48 && event.charCode <= 57' placeholder="Response Time(min)">
                                  </div>
                              </div>
                              <div class="col-sm-11" style="float: left; margin-left: -32%; margin-bottom: 12px;margin-top: 10px;">
                                  <button type="submit" class="btn btn-success btn-sm add-category pull-right " style="width: 125px;"> <i class="fa fa-plus" aria-hidden="true" id="submitemail"></i> Add</button>
                              </div>
                            <% end %>
                              
                              <div class="col-sm-12">
                                <table class="ui celled striped table" id="category-table"> 
                                  <thead>
                                    <tr>
                                      <th width="5%"> S.No. </th>
                                      <th width="20%"> Category Type </th>
                                      <th width="20%"> Assignee </th>
                                      <th width="20%"> Response Time (Min)</th>
                                      <th width="15%"> Action </th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    <% @helpdesk_categories.each_with_index do |helpdesk_category, index| %>
                                      <tr>
                                        <td class="collapsing">  <%= index + 1 %>  </td>
                                        <td class="collapsing">
                                          <%=helpdesk_category.name%>
                                        </td>
                                        <td class="collapsing"><% cw = ComplaintWorker.where(category_id: helpdesk_category.id).try(:assign_to).try(:last) %>
                                          <%= Spree::User.find_by(id: cw).try(:full_name)%></td>
                                        <td class="collapsing">
                                          <div class="text-center"><%=helpdesk_category.tat %></div>
                                        </td>
                                        <td>
                                           <%= form_for([:manage, helpdesk_category],:url => "/pms/admin/modify_helpdesk_category/#{helpdesk_category.id}") do |f| %>
                                           <%= f.hidden_field "custom_redirect", { :name => "custom_redirect", :value =>  "/pms/admin/helpdesk_categories" } %>
                                            <%= f.hidden_field "active", { :value => helpdesk_category.active } %>
                                          <a href="#" data-toggle="modal" data-target="#edit_category<%=helpdesk_category.id %>"><i class="fa fa-edit text-orange"></i> </a> <i class="fa fa-trash-o fa-times-circle delete_issue_type "></i><% end %>
                                        </td>
                                      </tr>
                                    <% end %>
                                  </tbody>
                                </table>
                              </div>
                            </div>
                          </div>
                        </div>
                        <div class="category-tab-content">
                          <div class="content-wrap">
                            <div class="row help">
                              <div class="col-sm-12">
                                <%= form_for(HelpdeskSubCategory.new,url: "/pms/admin/create_helpdesk_sub_category",id: "helpdesk-sub-category-form") do |f| %>
                                <%= f.hidden_field "custom_redirect",:value =>  "/pms/admin/helpdesk_categories"  %>
                                  
                                  <div class="form-group col-sm-4">
                                    <%= select_tag "helpdesk_sub_category[helpdesk_category_id]", options_for_select(@helpdesk_categories.collect{|p| [p.name,p.id] }), :include_blank=> "Select Category", :class => "form-control pull-right",:id => 'helpdesk_category', required: true %>
                                  </div>
                                  <div class="form-group col-sm-4">
                                    <%= text_area_tag 'sub_category_tags[]', nil, placeholder: "Enter Sub Category", class: 'form-control', id: 'subcategory', data: {role: 'tagsinput'} %>
                                  </div>
                                  <div class="col-sm-4">
                                    <button type="submit" class="btn btn-success btn-sm pull-right "> <i class="fa fa-plus" aria-hidden="true"></i> Add</button>
                                  </div>
                                <%end%>
                              </div>
                              <div class="col-sm-12">
                                <table class="ui celled striped table" id="category-table">
                                  <thead>
                                    <tr>
                                      <th width="5%"> S.No. </th>
                                      <th width="20%"> Category Type </th>
                                      <th width="40%"> Sub Category</th>
                                      <th width="10%"> </th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    <% @sr = 1 %>
                                    <% @helpdesk_sub_categories.each do |helpdesk_sub_category| %>
                                      <tr>
                                        <td class="collapsing">  <%= @sr %>  </td>
                                        <td><%= select_tag 'helpdesk_sub_category[helpdesk_category_id]', options_for_select(@helpdesk_categories.collect{|p| [p.name,p.id] }, :selected => helpdesk_sub_category.helpdesk_category_id), :include_blank => "Select Category", :class=>"form-control",:id => 'helpdesk_category' %></td>
                                        <td><input type="text" class="form-control" name="name" value="<%= helpdesk_sub_category.name %>" readonly></td>
                                        <td class="collapsing">
                                          <span class="tools">
                                          <%= form_for(HelpdeskSubCategory.new, url: "/pms/admin/modify_helpdesk_sub_category") do |f| %>
                                          <%= f.hidden_field "id", { name: "id", :value => helpdesk_sub_category.id } %>
                                          <%= f.hidden_field "name", { name: "name", :value => helpdesk_sub_category.name } %>
                                          <%= f.hidden_field "helpdesk_category_id", { name: "helpdesk_category_id", :value => helpdesk_sub_category.helpdesk_category_id } %>
                                          <%= f.hidden_field "active", { name: "active", :value => helpdesk_sub_category.active } %>
                                          <%= f.hidden_field "custom_redirect", { name: "custom_redirect", :value =>  "/pms/admin/helpdesk_categories"}  %><span class="tools"> <i class="fa fa-edit text-warning edit_sub_category"></i> <i class="fa fa-check-square text-success submit_subcat" style="display: none;" aria-hidden="true"></i> <i class="fa fa-times-circle delete_subcat"></i> 
                                        </span><% end %></span>
                                        </td>
                                      </tr>
                                      <% @sr = @sr + 1 %>
                                    <% end %>
                                  </tbody>
                                </table>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div data-tab="Status" class="innersection-check">
                    <div class="row help">
                    <%= form_for(ComplaintStatus.new, :url =>  "/pms/admin/create_complaint_statuses" ) do |f| %>
                    <%= f.hidden_field :of_phase, :value => "pms" %>
                    <%= f.hidden_field :society_id, :value => @user.current_site_id %>
                      <%= f.hidden_field :custom_redirect,:value =>  "/pms/admin/helpdesk_categories"  %>
                      <div class="col-sm-3">
                        <div class="form-group">
                          <input type="text" class="form-control" name="complaint_status[name]" placeholder="Enter status">
                        </div>
                      </div>
                      <div class="col-sm-3">
                        <div class="form-group">
                          <select class="form-control" name="complaint_status[fixed_state]">  
                            <option value="">Select Fixed State</option>
                            <option value="closed">Closed</option>
                          </select>
                        </div>
                      </div>
                      <div class="col-sm-2">
                        <div class="form-group attachcolor">
                          <input type="text" name="complaint_status[color_code]"  class="form-control" data-palette='["#D50000","#304FFE","#00B8D4","#00C853","#eb5768","#FF1744","#6F0564","#FFCC00","#AF4FA2","#800000","#248108","#0033CC"]' value="" placeholder="no color">
                        </div>
                      </div>
                      <div class="col-sm-2">
                        <div class="form-group">
                          <input type="number" class="form-control" name="complaint_status[position]" placeholder="Enter order" min="1">
                        </div>
                      </div>
                      <div class="form-group col-sm-2 pull-right">
                       <button type="submit" class="btn btn-success btn-xs add-complaint"> <i class="fa fa-plus" aria-hidden="true"></i> Add</button>
                      </div>
                      <% end %>
                    </div>
                    <table class="ui celled structured table">
                      <thead>
                        <tr>
                          <th width="10%"> Order </th>
                          <th width="30%"> Status </th>
                          <th width="30%"> Fixed State </th>
                          <th width="20%"> Color</th>
                          <th width="10%"> </th>
                        </tr>
                      </thead>
                      <tbody>
                      <% @sr = 1 %>
                      <% @statuses.each do |escalation| %>
                        <tr>
                          <td class="collapsing"><input type="text" class="form-control tabs-input" name="position" value="<%= escalation.position %>" readonly> </td>
                          <td><input type="text" class="form-control tabs-input" name="name" value="<%= escalation.name %>" readonly></td>
                          <td><select class="form-control" name="complaint_status[fixed_state]" readonly>  
                            <option value="">Select Fixed State</option>
                            <option value="closed" <%= escalation.fixed_state == "closed" ? 'selected' : '' %>>Closed</option>
                            <option value="reopen" <%= escalation.fixed_state == "reopen" ? 'selected' : '' %>>Reopen</option>
                            <option value="complete" <%= escalation.fixed_state == "complete" ? 'selected' : '' %>>Complete</option>
                          </select></td>
                          <td class=" collapsing"><div class="attachcolor">
                          <input type="text" name="color_code" class="form-control" data-palette='["#D50000","#304FFE","#00B8D4","#00C853","#eb5768","#FF1744","#6F0564","#FFCC00","#AF4FA2","#800000","#248108","#0033CC"]' value="<%= escalation.color_code %>" readonly> </div> </td>
                          <td class="  collapsing"><%= form_for(ComplaintStatus.new, url: "/pms/admin/modify_complaint_status") do |f| %>
                              <%= f.hidden_field "id", { name: "id", :value => escalation.id } %>
                              <%= f.hidden_field "position", { name: "position", :value => escalation.position } %>
                              <%= f.hidden_field "name", { name: "name", :value => escalation.name } %>
                              <%= f.hidden_field "active", { name: "active", :value => escalation.active } %>
                              <%= f.hidden_field "color_code", { name: "color_code", :value => escalation.active } %>  
                               <%= f.hidden_field "fixed_state", { name: "fixed_state", :value => escalation.fixed_state } %>  
                              <%= f.hidden_field "custom_redirect", { name: "custom_redirect", :value =>  "/pms/admin/helpdesk_categories"}  %><span class="tools"> <i class="fa fa-edit text-warning cat-edit edit_issue_type"></i> <i class="fa fa-check-square text-success submit-i-form" style="display: none;" aria-hidden="true"></i> <i class="fa fa-trash-o fa-times-circle delete_issue_type "></i><% end %> </span></td>
                        </tr>
                        <% @sr = @sr + 1 %>
                        <% end %>
                      </tbody>
                    </table>
                  </div>

                  <div data-tab="Operational Days">
                    <div class="row help">
                    <% @soc = @user.site %>
                         <% 
                          @helpdesk_operations = HelpdeskOperation.where(op_of_id: @user.current_site_id)
                         %>
                      <% @days = ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"]  %>
                      <%= form_for(@soc) do |f| %>
                        <div class="col-sm-12">
                          <table class="ui celled structured table">
                            <thead>
                              <tr>
                                <th><%= check_box_tag :selall, false, class: 'selall' %></th>
                                <th>Operational Days</th>
                                <th>Start Time</th>
                                <th>End Time</th>
                              </tr>
                            </thead>
                            <tbody>
                              <% @days.each do |day|
                                @ro = @helpdesk_operations.where(dayofweek: day).try(:last) || HelpdeskOperation.new(dayofweek: day)
                              %>
                                <%= f.fields_for :helpdesk_operations, @ro do |ro| %> 
                                  <% @phase = "pms" %>
                                  <%= render 'operations_form.html' , :f => ro, :locals => {:f => ro } %>
                                <% end %>
                              <% end %>
                            </tbody>
                          </table>
                        </div>
                        <input type="hidden" name="redirect_url" value="/pms/admin/helpdesk_categories">
                        <div class="col-sm-12">
                          <button type="submit" class="btn btn-success btn-sm">Submit</button>
                        </div>
                      <% end %>
                    </div>   
                  </div>



                </div>
              </div>
       
              <div class="clearfix"></div>
            </section>
            <!-- escalation starts -->
            <%= render "escalation" %>
          </div>
        </div>
      </div>
    </div>
  </section>
  <% @helpdesk_categories.each do |helpdesk_category| %>
  <div class="modal fade" id="<%= "edit_category" + helpdesk_category.id.to_s %>" role="dialog">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <button type="button" class="close" data-dismiss="modal">&times;</button>
          <h4 class="modal-title">Edit Category</h4>
        </div>
        <%= form_for([:manage, helpdesk_category],:url => "/pms/admin/modify_helpdesk_category/#{helpdesk_category.id}") do |f| %>
         <%= f.hidden_field "custom_redirect", { :name => "custom_redirect", :value =>  "/pms/admin/helpdesk_categories" } %> 
          <div class="modal-body">
            <div class='row'>
              <div class='col-sm-12'>
                <div class="form-group col-sm-6">
                  <label>Category </label>
                  <%= f.text_field :name, class: 'form-control', required: true %>
                </div>
                <div class="form-group col-sm-6">
                   <label>Engineer</label>
                  <%= select_tag 'complaint_worker[assign_to][]', options_for_select(@sstaff, :selected => ComplaintWorker.pms.where(category_id: helpdesk_category.id).try(:assign_to).try(:last)),:include_blank => "Select Engineer", :class=>"form-control" %>
                </div>
                <div class="form-group col-sm-6">
                        <% if @user.available_site.try(:complaint_urgency_enabled?) %>
                           <div class="divTable">
                            <div class="divTableHeading">
                              <div class="divTableRow">
                                <div class="divTableCell width5">Urgency</div>
                                <div class="divTableCell width40">Response Time(min)</div>
                              </div>
                            </div>
                            <div class="divTableBody">
                              <div class="divTableRow">
                                <div class="divTableCell">High</div>
                                <div class="divTableCell">
                                  <input type="text" class="form-control response_tat" name="response_tat[high]" required=true maxlength= 4 onkeypress='return event.charCode >= 48 && event.charCode <= 57' value="<%= helpdesk_category.resp_tat('high') %>" >
                                </div>
                                
                              </div>
                              <div class="divTableRow">
                                <div class="divTableCell">Medium</div>
                                <div class="divTableCell">
                                  <input type="text" class="form-control response_tat" name="response_tat[medium]" required=true maxlength= 4 onkeypress='return event.charCode >= 48 && event.charCode <= 57' value="<%= helpdesk_category.resp_tat('medium') %>" >
                                </div>
                                
                              </div>
                              <div class="divTableRow">
                                <div class="divTableCell">Low</div>
                                <div class="divTableCell">
                                  <input type="text" class="form-control response_tat" name="response_tat[low]" required=true maxlength= 4 onkeypress='return event.charCode >= 48 && event.charCode <= 57' value="<%= helpdesk_category.resp_tat('low') %>" >
                                </div>
                                
                              </div>
                                
                              </div>
                          </div>
                        <% else %>
                          <label>Response Time(min)</label>
                          <%= f.text_field :tat, class: 'form-control', required: true %>
                        <% end %>
                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <%= f.submit "Submit", class: "btn btn-success update-category" %>
          </div>
        <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
