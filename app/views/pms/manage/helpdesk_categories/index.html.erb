  $("#time").change(function(){
    
    if($("#time").val() == "days"){
      $("#exp-value").attr("min",1)
      $("#exp-value").attr("max",31)
      if ( parseInt($("#exp-value").val()) > 31){
        $("#exp-value").val(31)
      }
    }
    if($("#time").val() == "hours"){
      $("#exp-value").attr("min",1)
      $("#exp-value").attr("max",24)
      if ( parseInt($("#exp-value").val()) > 24){
        $("#exp-value").val(24)
      }
    }
    if($("#time").val() == "minutes"){
      $("#exp-value").attr("min",1)
      $("#exp-value").attr("max",60)
      if ( parseInt($("#exp-value").val()) > 60){
        $("#exp-value").val(60)
      }
    }
    if($("#time").val() == ""){
      $("#exp-value").removeAttr("min",null)
      $("#exp-value").attr("max",null)
      $("#exp-value").val("")
    }
  });
    </script>