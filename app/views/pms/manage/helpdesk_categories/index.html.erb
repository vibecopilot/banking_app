<script type='text/javascript'>
  (function() {
    [].slice.call( document.querySelectorAll( '.tabs' ) ).forEach( function( el ) {
      new CBPFWTabs( el );
    });
  })();
  $('.tabsholder3').cardTabs({theme: 'graygreen'});
  $('.menu .item').tab();
  $('.inline.label').popup({ inline: true });
  $(function () {
    $('.attachcolor [name="complaint_status[color_code]"]').paletteColorPicker({
          clear_btn: 'last',
          close_all_but_this: true
        });
    $('.attachcolor [name="color_code"]').paletteColorPicker({
          clear_btn: 'last',
          close_all_but_this: true 
        });
  });

  $(document).ready(function() {
    $("div.solutions-tab-menu>div.list-group>a").click(function(e) {
        e.preventDefault();
        $(this).siblings('a.active').removeClass("active");
        $(this).addClass("active");
        var index = $(this).index();
        $("div.solutions-tab>div.solutions-tab-content").removeClass("active");
        $("div.solutions-tab>div.solutions-tab-content").eq(index).addClass("active");
    });
  });

  $(document).ready(function() {
    $("div.category-tab-menu>div.list-group>a").click(function(e) {
        e.preventDefault();
        $(this).siblings('a.active').removeClass("active");
        $(this).addClass("active");
        var index = $(this).index();
        $("div.category-tab>div.category-tab-content").removeClass("active");
        $("div.category-tab>div.category-tab-content").eq(index).addClass("active");
    });

    $("#selall").click(function(e){
      if($(this).is(':checked') ){
        $(this).parents("table").find('.operational-days').each(function() {
            $(this).prop("checked", true);
        });
      } else{
        $(this).parents("table").find('.operational-days').each(function() {
          $(this).prop("checked", false);
        });
      }
     });

    $(".operational-days").click(function(e){
      if(!$(this).is(':checked')){
        var selall = $(this).parents("table").find('#selall');
        if (selall.is(':checked')){
          selall.prop("checked", false);
        }
      }
    });
  });

  $(".rule_unit").change(function(){
    // alert("aaaaaaaaaaaaaaaaaaaaaa")
    $(".from_value").val("")   
    $(".to_value").val("")   
    $(".value").val("")
    if($(".rule_unit").val() == "between"){
      $(".between-div").show()
      $('.other-div').hide()
    }
    else{
      $(".between-div").hide()
      $('.other-div').show()
    }
  });

  // $("#helpdesk-sub-category-form").onkeypress = function(e) {
  //   var key = e.charCode || e.keyCode || 0;     
  //   if (key == 13) {
  //     alert("I told you not to, why did you do it?");
  //     e.preventDefault();
  //     return false
  //   }
  // }
  
  function stopRKey(evt) {
  var evt = (evt) ? evt : ((event) ? event : null);
  var node = (evt.target) ? evt.target : ((evt.srcElement) ? evt.srcElement : null);
  if ((evt.which == 13) && (node.type == "text")) {
    return false;
  }
}

document.onkeypress = stopRKey;



  $('#subcategory').tagsinput({
    // tagClass: 'big'
  });


//   $.each(obj, function(index, value) {
//     $('#looking_for_job_titles').tagsinput('add', value);
//     console.log(value);
// });


  // $("#location_tower").change(function(){
  //   pms_wings_from_tower($(this), $("#location_wings")) 
  // });

  $("#location_level1").change(function(){
    location_level2_from_level1($(this), $("#location_level2")) 
  });

 
  $(".add-category").click(function(e){
    e.preventDefault();
    frm = $(this).parents("form");
    submitCategory(frm);
  });

  $(".update-category").click(function(e){
    e.preventDefault();
    frm = $(this).parents("form");
    submitCategory(frm);
    
  });

  function submitCategory(form){

    vl = frm.find('[name="helpdesk_category[name]"]').val();
      if(vl == "")
      {
        toastr.error("Please enter category type");
        return;
      }
      var a =[]
      frm.find('.response_tat').each(function() {
        if($(this).val() == ""){
          a.push(1);
        }
      });
      if (a.length > 2){
        toastr.error("Please Provide Response Time");
        return false;
      }
      tat = frm.find('[name="helpdesk_category[tat]"]').val();
      if(tat == "")
      {
        toastr.error("Please enter Response Time");
        return;
      }
      form.submit();
  }
  $(".add-complaint").click(function(e){
    e.preventDefault();
    frm = $(this).parents("form");
    vl = frm.find('[name="complaint_status[name]"]').val();
      if(vl == "")
      {
        alert("Please enter status");
