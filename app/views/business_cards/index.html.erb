<p id="notice"><%= notice %></p>

<h1>Business Cards</h1>

<table>
  <thead>
    <tr>
      <th>Full name</th>
      <th>Profession</th>
      <th>Contact number</th>
      <th>Email</th>
      <th>Website url</th>
      <th>Address</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @business_cards.each do |business_card| %>
      <tr>
        <td><%= business_card.full_name %></td>
        <td><%= business_card.profession %></td>
        <td><%= business_card.contact_number %></td>
        <td><%= business_card.email_id %></td>
        <td><%= business_card.website_url %></td>
        <td><%= business_card.address %></td>
        <td><%= link_to 'Show', business_card %></td>
        <td><%= link_to 'Edit', edit_business_card_path(business_card) %></td>
        <td><%= link_to 'Destroy', business_card, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Business Card', new_business_card_path %>
