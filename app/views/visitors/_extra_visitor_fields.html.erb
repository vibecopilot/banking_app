<div class="nested-fields">
  <div class="field">
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>
  <div class="field">
    <%= f.label :contact_no %>
    <%= f.number_field :contact_no %>
  </div>
  <%= f.hidden_field :_destroy %>
  <%= link_to_remove_association "Remove Extra Visitor", f %>
</div>
