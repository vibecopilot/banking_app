<style>
  .popup-form {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: 20px;
    background: white;
    border: 1px solid #ccc;
    box-shadow: 0 0 10px rgba(0,0,0,0.2);
    z-index: 1000;
  }
  .popup-form .field {
    margin-bottom: 15px;
  }
  .popup-form .actions {
    text-align: right;
  }
  .popup-form .btn-close-popup {
    margin-left: 10px;
  }
  .overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    z-index: 999;
  }
</style>

<div class="overlay"></div>

<%= form_with(model: @visitor, local: true, html: { multipart: true }) do |form| %>

  <div class="field">
    <%= form.label :profile_pic %>
    <%= form.file_field :profile_pic, accept: 'image/png,image/jpeg' %>
  </div>

  <div class="field">
    <%= form.label :name %>
    <%= form.text_field :name, id: :visitor_name %>
  </div>

  <div class="field">
    <%= form.label :contact_no %>
    <%= form.number_field :contact_no, id: :visitor_contact_no, maxlength: 10, pattern: "[0-9]*", required: true %>
    <% if @visitor.errors.has_key?(:contact_no) %>
      <p class="error"><%= @visitor.errors[:contact_no].join(', ') %></p>
    <% end %>
  </div>

  <div class="field">
    <%= form.label :purpose %>
    <%= form.text_area :purpose, id: :visitor_purpose %>
  </div>

  <div class="field">
    <%= form.label :site_id %>
    <%= form.collection_select :site_id, Site.all, :id, :name, { prompt: 'Select Site' }, { id: :visitor_site_id } %>
  </div>

  <div class="field">
    <%= form.label :visitor_staff_category_id, "Visitor Staff Category" %>
    <%= form.collection_select :visitor_staff_category_id, @visitor_staff_categories, :id, :name, { prompt: 'Select Visitor Staff Category' }, { id: :visitor_visitor_staff_category_id, class: 'category-select' } %>
    <button type="button" class="btn-add-category">Add</button>
    <button type="button" class="btn-edit-category">Edit</button>
    <button type="button" class="btn-delete-category">Delete</button>
  </div>

  <!-- New fields -->
  <div class="field">
    <%= form.label :coming_from %>
    <%= form.text_field :coming_from, id: :visitor_coming_from %>
  </div>

  <div class="field">
    <%= form.label :vehicle_number %>
    <%= form.text_field :vehicle_number, id: :visitor_vehicle_number %>
  </div>

  <div class="field">
    <%= form.label :parking_slot, "Parking Slot" %>
    <%= form.collection_select :parking_slot, ParkingConfiguration.all, :id, :name, { prompt: 'Select Parking Slot' }, id: :visitor_parking_slot %>
  </div>

  <div class="field">
    <%= form.label :visitor_in_out %>
    <%= form.text_field :visitor_in_out %>
  </div>

  <div class="field">
    <%= form.label :expected_date %>
    <%= form.date_field :expected_date, id: :visitor_expected_date %>
  </div>

  <div class="field">
    <%= form.label :expected_time %>
    <%= form.time_field :expected_time, id: :visitor_expected_time %>
  </div>

  <div class="field">
    <%= form.label :host_approval %>
    <% if current_user.user_type == 'security_guard' %>
      <%= form.check_box :skip_host_approval, id: :visitor_skip_host_approval, checked: false, disabled: true %>
    <% else %>
      <%= form.check_box :skip_host_approval, id: :visitor_skip_host_approval %>
    <% end %>
  </div>

  <div class="field">
    <%= form.label :goods_inwards %>
    <%= form.check_box :goods_inwards, id: :visitor_goods_inwards %>
  </div>

  <div class="field">
    <%= form.label :pass_number %>
    <%= form.text_field :pass_number, id: :visitor_pass_number %>
  </div>

  <div class="field">
    <%= form.label :visit_type %>
    <%= form.select :visit_type, ['Guest', 'Support Staff'], { prompt: 'Select Visit Type' }, { id: :visitor_visit_type } %>
  </div>

  <div class="field">
    <%= form.label :frequency %>
    <%= form.select :frequency, ['Frequently', 'Once'], { prompt: 'Select Frequency' }, { id: :visitor_frequency } %>
  </div>

  <div class="field">
    <%= form.label :working_days %>
    <%= form.collection_check_boxes :working_days, ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'], :to_s, :to_s %>
  </div>

  <div class="field" style="display: none;">
    <%= form.label :status %>
    <%= form.check_box :status, { checked: true, value: 'approved' }, 'approved', nil %>
  </div>

  <div class="field">
    <%= form.label :created_by_id, "Host" %>
    <%= form.select :created_by_id, options_for_select([]), {}, { class: 'host-select' } %>
  </div>

  <div class="field start-pass-field">
    <%= form.label :start_pass %>
    <%= form.datetime_select :start_pass, id: :visitor_start_pass %>
  </div>

  <div class="field end-pass-field">
    <%= form.label :end_pass %>
    <%= form.datetime_select :end_pass, id: :visitor_end_pass %>
  </div>

  <div class="field">
    <%= form.label :visitor_files, "Attach files" %>
    <%= file_field_tag "visitor_files[]", multiple: true, id: :visitor_files %>
  </div>

  <h3>Extra Visitors</h3>
  <div id="extra_visitors">
    <%= form.fields_for :extra_visitors do |extra_visitor_form| %>
      <%= render 'extra_visitor_fields', f: extra_visitor_form %>
      <%= extra_visitor_form.check_box :_destroy, class: 'extra-visitor-checkbox' %>
      <%= extra_visitor_form.label :_destroy, 'Remove' %>
    <% end %>
    <%= link_to_add_association 'Add Extra Visitor', form, :extra_visitors, partial: 'extra_visitor_fields', class: 'btn btn-primary' %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>

<!-- Add Category Popup -->
<div id="add-category-popup" class="popup-form">
  <h3>Add Category</h3>
  <form id="add-category-form">
    <div class="field">
      <label for="new_category_name">Category Name</label>
      <input type="text" id="new_category_name" name="name" required>
    </div>
    <div class="actions">
      <input type="submit" value="Add Category">
      <button type="button" class="btn-close-popup">Cancel</button>
    </div>
  </form>
</div>

<!-- Edit Category Popup -->
<div id="edit-category-popup" class="popup-form">
  <h3>Edit Category</h3>
  <form id="edit-category-form">
    <input type="hidden" id="edit_category_id" name="id">
    <div class="field">
      <label for="edit_category_name">Category Name</label>
      <input type="text" id="edit_category_name" name="name" required>
    </div>
    <div class="actions">
      <input type="submit" value="Save Changes">
      <button type="button" class="btn-close-popup">Cancel</button>
    </div>
  </form>
</div>

<script type="text/javascript">
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.querySelector('.overlay');
    const addCategoryPopup = document.getElementById('add-category-popup');
    const editCategoryPopup = document.getElementById('edit-category-popup');
    const categorySelect = document.querySelector('.category-select');
    const addCategoryButton = document.querySelector('.btn-add-category');
    const editCategoryButton = document.querySelector('.btn-edit-category');
    const deleteCategoryButton = document.querySelector('.btn-delete-category');

    // Show popup function
    function showPopup(popup) {
      overlay.style.display = 'block';
      popup.style.display = 'block';
    }

    // Hide popup function
    function hidePopup() {
      overlay.style.display = 'none';
      addCategoryPopup.style.display = 'none';
      editCategoryPopup.style.display = 'none';
    }

    // Add category
    addCategoryButton.addEventListener('click', () => {
      showPopup(addCategoryPopup);
    });

    document.querySelector('#add-category-form').addEventListener('submit', (event) => {
      event.preventDefault();
      const formData = new FormData(event.target);
      fetch('/visitor_staff_categories', {
        method: 'POST',
        body: formData,
      }).then(response => response.json()).then(data => {
        if (data.id) {
          const option = document.createElement('option');
          option.value = data.id;
          option.textContent = data.name;
          categorySelect.appendChild(option);
          hidePopup();
        }
      });
    });

    // Edit category
    editCategoryButton.addEventListener('click', () => {
      const selectedOption = categorySelect.options[categorySelect.selectedIndex];
      if (selectedOption.value) {
        showPopup(editCategoryPopup);
        document.getElementById('edit_category_id').value = selectedOption.value;
        document.getElementById('edit_category_name').value = selectedOption.textContent;
      }
    });

    document.querySelector('#edit-category-form').addEventListener('submit', (event) => {
      event.preventDefault();
      const formData = new FormData(event.target);
      fetch(`/visitor_staff_categories/${document.getElementById('edit_category_id').value}`, {
        method: 'PATCH',
        body: formData,
      }).then(response => response.json()).then(data => {
        if (data.id) {
          const selectedOption = categorySelect.options[categorySelect.selectedIndex];
          selectedOption.textContent = data.name;
          hidePopup();
        }
      });
    });

    // Delete category
    deleteCategoryButton.addEventListener('click', () => {
      const selectedOption = categorySelect.options[categorySelect.selectedIndex];
      if (selectedOption.value) {
        if (confirm('Are you sure you want to delete this category?')) {
          fetch(`/visitor_staff_categories/${selectedOption.value}`, {
            method: 'DELETE',
          }).then(response => response.json()).then(data => {
            if (data.success) {
              categorySelect.removeChild(selectedOption);
            }
          });
        }
      }
    });

    // Close popups
    document.querySelectorAll('.btn-close-popup').forEach(button => {
      button.addEventListener('click', hidePopup);
    });

    // Hide overlay when clicking outside popups
    overlay.addEventListener('click', hidePopup);
  });
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const hostSelect = document.querySelector('.host-select');
  const siteSelect = document.querySelector('#visitor_site_id'); // Ensure this ID matches your form field
  const categorySelect = document.querySelector('.category-select');

  function updateHostOptions(siteId) {
    fetch(`/visitors/fetch_potential_hosts?site_id=${siteId}`)
      .then(response => response.json())
      .then(data => {
        if (Array.isArray(data.hosts)) {
          hostSelect.innerHTML = ''; // Clear existing options
          data.hosts.forEach(host => {
            const option = new Option(`${host.name} (${host.email})`, host.id);
            hostSelect.add(option);
          });
        } else {
          console.error('Expected data format: { hosts: [...] }');
        }
      })
      .catch(error => {
        console.error('Error fetching hosts:', error);
      });
  }

  if (siteSelect) {
    siteSelect.addEventListener('change', function() {
      const siteId = this.value;
      if (siteId) {
        updateHostOptions(siteId);
      } else {
        hostSelect.innerHTML = ''; // Clear options if no site is selected
      }
    });
  }
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const frequencyField = document.getElementById('visitor_frequency');
  const startPassField = document.querySelector('.start-pass-field');
  const endPassField = document.querySelector('.end-pass-field');
  const startPassInput = document.getElementById('visitor_start_pass');
  const endPassInput = document.getElementById('visitor_end_pass');

  function updateEndPass() {
    const selectedFrequency = frequencyField.value;
    if (selectedFrequency === 'Once') {
      const startPassDate = new Date(startPassInput.value);
      const endPassDate = new Date(startPassDate.getTime() + 24 * 60 * 60 * 1000); // Add 24 hours
      endPassInput.value = endPassDate.toISOString().slice(0, 16); // Set the end pass field
      endPassField.style.display = 'none'; // Hide the field from user input
    } else {
      endPassField.style.display = 'block'; // Show the field if frequency is not 'Once'
    }
  }

  frequencyField.addEventListener('change', updateEndPass);
  startPassInput.addEventListener('change', updateEndPass);

  // Initial check
  updateEndPass();
});
</script>

