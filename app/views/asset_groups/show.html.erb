<p id="notice"><%= notice %></p>

<p>
  <strong>Name:</strong>
  <%= @asset_group.name %>
</p>

<p>
  <strong>Description:</strong>
  <%= @asset_group.description %>
</p>

<h5>Asset Group Params</h5>

<table class="table table-striped table-responsive " id="table" data-toggle="table" data-pagination="true" data-search="true" data-trim-on-search="false" data-show-columns="true" data-show-refresh="true" data-sortable="true" data-key-events="true" data-show-toggle="true" data-resizable="true" data-cookie="true" data-cookie-id-table="saveId" data-show-export="true" data-click-to-select="true" data-toolbar="#toolbar">
  <thead>
    <tr>
      <th>Name</th>
      <th>Order</th>
      <th>Dashboard view</th>
      <th>Consumption view</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @asset_group.asset_group_params.order(:order).each do |asset_group_param| %>
      <tr>
        <td><%= asset_group_param.name %></td>
        <td><%= asset_group_param.order %></td>
        <td><%= asset_group_param.dashboard_view %></td>
        <td><%= asset_group_param.consumption_view %></td>
        <td><%= link_to 'Edit', edit_asset_group_param_path(asset_group_param) %></td>
        <td><%= link_to 'Destroy', asset_group_param, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<br>
<br>
<div class="col-sm-12" style="border: 1px solid; padding: 5px">
  <h6>Add Parameter</h6>
  <% asset_group_param = AssetGroupParam.new %>
  <%= form_with(model: asset_group_param, local: true) do |form| %>
  <% if asset_group_param.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(asset_group_param.errors.count, "error") %> prohibited this asset_group_param from being saved:</h2>

      <ul>
      <% asset_group_param.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>
  <%= form.hidden_field :asset_group_id, value: @asset_group.id %>
  <div class="col-sm-2">
    <%= form.label :name %>
    <%= form.text_field :name, id: :asset_group_param_name %>
  </div>

  <div class="col-sm-2">
    <%= form.label :order %>
    <%= form.number_field :order, id: :asset_group_param_order %>
  </div>

  <div class="col-sm-2">
    <%= form.label :dashboard_view %>
    <%= form.check_box :dashboard_view, id: :asset_group_param_dashboard_view %>
  </div>

  <div class="col-sm-2">
    <%= form.label :consumption_view %>
    <%= form.check_box :consumption_view, id: :asset_group_param_consumption_view %>
  </div>

  <div class="actions col-sm-2">
    <%= form.submit %>
  </div>
<% end %>

</div>