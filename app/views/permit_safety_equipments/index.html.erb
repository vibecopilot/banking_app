<p id="notice"><%= notice %></p>

<h1>Permit Safety Equipments</h1>

<table>
  <thead>
    <tr>
      <th>Safety equipment name</th>
      <th>Permit type</th>
      <th>Activity</th>
      <th>Sub activity</th>
      <th>Hazard category</th>
      <th>Permit risk</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @permit_safety_equipments.each do |permit_safety_equipment| %>
      <tr>
        <td><%= permit_safety_equipment.safety_equipment_name %></td>
        <td><%= permit_safety_equipment.permit_type_id %></td>
        <td><%= permit_safety_equipment.activity_id %></td>
        <td><%= permit_safety_equipment.sub_activity_id %></td>
        <td><%= permit_safety_equipment.hazard_category_id %></td>
        <td><%= permit_safety_equipment.permit_risk_id %></td>
        <td><%= link_to 'Show', permit_safety_equipment %></td>
        <td><%= link_to 'Edit', edit_permit_safety_equipment_path(permit_safety_equipment) %></td>
        <td><%= link_to 'Destroy', permit_safety_equipment, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Permit Safety Equipment', new_permit_safety_equipment_path %>
