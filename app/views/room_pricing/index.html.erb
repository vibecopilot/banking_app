<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h4 class="card-title mb-0">
            <i class="fas fa-tags mr-2"></i>
            Pricing Management: <%= @room.display_name %>
          </h4>
          <div>
            <%= link_to "Add Pricing", new_room_room_pricing_path(@room), class: "btn btn-primary" %>
            <%= link_to "View Room", room_path(@room), class: "btn btn-outline-secondary" %>
          </div>
        </div>
        
        <div class="card-body">
          <!-- Room Base Pricing Info -->
          <div class="row mb-4">
            <div class="col-md-12">
              <div class="alert alert-info">
                <h6><i class="fas fa-info-circle mr-2"></i>Base Room Information</h6>
                <div class="row">
                  <div class="col-md-3">
                    <strong>Room:</strong> <%= @room.display_name %>
                  </div>
                  <div class="col-md-3">
                    <strong>Type:</strong> <%= @room.room_type.humanize %>
                  </div>
                  <div class="col-md-3">
                    <strong>Base Price:</strong> $<%= @room.base_price_per_night %>/night
                  </div>
                  <div class="col-md-3">
                    <strong>Tax Rate:</strong> <%= @room.tax_percentage %>%
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Quick Actions -->
          <div class="row mb-4">
            <div class="col-md-12">
              <div class="btn-group" role="group">
                <%= link_to "Calendar View", calendar_room_room_pricing_path(@room), 
                            class: "btn btn-outline-info" %>
                <button type="button" class="btn btn-outline-success" data-toggle="modal" data-target="#bulkCreateModal">
                  Bulk Create
                </button>
              </div>
            </div>
          </div>

          <!-- Pricing Records Table -->
          <% if @room_pricing.any? %>
            <div class="table-responsive">
              <table class="table table-hover">
                <thead class="thead-light">
                  <tr>
                    <th>Period</th>
                    <th>Price per Night</th>
                    <th>Type</th>
                    <th>Reason</th>
                    <th>Price Change</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @room_pricing.each do |pricing| %>
                    <tr class="<%= 'table-success' if pricing.active? %>
                               <%= 'table-secondary' unless pricing.active? %>">
                      <td>
                        <strong><%= pricing.display_period %></strong>
                        <br><small class="text-muted"><%= pricing.duration_days %> day<%= 's' if pricing.duration_days > 1 %></small>
                      </td>
                      <td>
                        <strong class="<%= 'text-success' if pricing.price_per_night > @room.base_price_per_night %>
                                        <%= 'text-danger' if pricing.price_per_night < @room.base_price_per_night %>
                                        <%= 'text-dark' if pricing.price_per_night == @room.base_price_per_night %>">
                          $<%= pricing.price_per_night %>
                        </strong>
                      </td>
                      <td>
                        <span class="badge <%= case pricing.pricing_type
                                              when 'seasonal' then 'badge-primary'
                                              when 'promotional' then 'badge-success'
                                              when 'event_based' then 'badge-warning'
                                              when 'weekend' then 'badge-info'
                                              when 'holiday' then 'badge-danger'
                                              else 'badge-secondary'
                                              end %>">
                          <%= pricing.pricing_type.humanize %>
                        </span>
                      </td>
                      <td><%= truncate(pricing.reason, length: 40) %></td>
                      <td>
                        <% if pricing.price_difference != 0 %>
                          <span class="<%= 'text-success' if pricing.is_premium? %>
                                        <%= 'text-danger' if pricing.is_discount? %>">
                            <%= pricing.is_premium? ? '+' : '' %>$<%= pricing.price_difference %>
                            (<%= pricing.is_premium? ? '+' : '' %><%= pricing.price_difference_percentage %>%)
                          </span>
                          <br><small class="text-muted">
                            <%= pricing.is_premium? ? 'Premium' : 'Discount' %>
                          </small>
                        <% else %>
                          <span class="text-muted">No change</span>
                        <% end %>
                      </td>
                      <td>
                        <% if pricing.active? %>
                          <span class="badge badge-success">Active</span>
                        <% else %>
                          <span class="badge badge-secondary">Inactive</span>
                        <% end %>
                      </td>
                      <td>
                        <div class="btn-group" role="group">
                          <%= link_to "View", room_room_pricing_path(@room, pricing), 
                                      class: "btn btn-sm btn-outline-primary" %>
                          <%= link_to "Edit", edit_room_room_pricing_path(@room, pricing), 
                                      class: "btn btn-sm btn-outline-secondary" %>
                          <%= link_to "Delete", room_room_pricing_path(@room, pricing), 
                                      method: :delete,
                                      confirm: "Are you sure you want to delete this pricing record?",
                                      class: "btn btn-sm btn-outline-danger" %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-5">
              <i class="fas fa-tags fa-3x text-muted mb-3"></i>
              <h5 class="text-muted">No custom pricing configured</h5>
              <p class="text-muted">
                This room uses the base price of $<%= @room.base_price_per_night %>/night for all dates.<br>
                <%= link_to "Add custom pricing", new_room_room_pricing_path(@room), class: "btn btn-primary" %>
              </p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Bulk Create Modal -->
<div class="modal fade" id="bulkCreateModal" tabindex="-1" role="dialog">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Bulk Create Pricing</h5>
        <button type="button" class="close" data-dismiss="modal">
          <span>&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <%= form_with url: bulk_create_room_room_pricing_path(@room), method: :post, local: true, id: "bulk_pricing_form" do |f| %>
          <div id="pricing_records">
            <div class="pricing-record border p-3 mb-3">
              <div class="row">
                <div class="col-md-6">
                  <div class="form-group">
                    <label>Start Date</label>
                    <input type="date" name="pricing_records[][start_date]" class="form-control" required>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-group">
                    <label>End Date</label>
                    <input type="date" name="pricing_records[][end_date]" class="form-control" required>
                  </div>
                </div>
              </div>
              <div class="row">
                <div class="col-md-4">
                  <div class="form-group">
                    <label>Price per Night</label>
                    <div class="input-group">
                      <div class="input-group-prepend">
                        <span class="input-group-text">$</span>
                      </div>
                      <input type="number" name="pricing_records[][price_per_night]" 
                             class="form-control" step="0.01" min="0" required>
                    </div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="form-group">
                    <label>Type</label>
                    <select name="pricing_records[][pricing_type]" class="form-control" required>
                      <option value="seasonal">Seasonal</option>
                      <option value="promotional">Promotional</option>
                      <option value="event_based">Event Based</option>
                      <option value="weekend">Weekend</option>
                      <option value="holiday">Holiday</option>
                    </select>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="form-group">
                    <label>&nbsp;</label>
                    <button type="button" class="btn btn-outline-danger btn-block remove-record">
                      Remove
                    </button>
                  </div>
                </div>
              </div>
              <div class="form-group">
                <label>Reason</label>
                <input type="text" name="pricing_records[][reason]" 
                       class="form-control" placeholder="e.g., Summer season pricing" required>
              </div>
            </div>
          </div>
          
          <div class="mb-3">
            <button type="button" class="btn btn-outline-primary" id="add_record">
              <i class="fas fa-plus mr-1"></i> Add Another Record
            </button>
          </div>
        <% end %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
        <button type="submit" form="bulk_pricing_form" class="btn btn-primary">Create Pricing Records</button>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const addButton = document.getElementById('add_record');
  const recordsContainer = document.getElementById('pricing_records');
  
  addButton.addEventListener('click', function() {
    const newRecord = document.querySelector('.pricing-record').cloneNode(true);
    
    // Clear input values
    newRecord.querySelectorAll('input, select').forEach(input => {
      input.value = '';
    });
    
    recordsContainer.appendChild(newRecord);
    updateRemoveButtons();
  });
  
  function updateRemoveButtons() {
    const removeButtons = document.querySelectorAll('.remove-record');
    const records = document.querySelectorAll('.pricing-record');
    
    removeButtons.forEach((button, index) => {
      if (records.length > 1) {
        button.style.display = 'block';
        button.addEventListener('click', function() {
          this.closest('.pricing-record').remove();
          updateRemoveButtons();
        });
      } else {
        button.style.display = 'none';
      }
    });
  }
  
  updateRemoveButtons();
});
</script>

<style>
.pricing-record {
  border-radius: 5px;
  background-color: #f8f9fa;
}

.remove-record {
  display: none;
}
</style>
