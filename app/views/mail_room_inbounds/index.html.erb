<p id="notice"><%= notice %></p>

<h1>Mail Room Inbounds</h1>

<table>
  <thead>
    <tr>
      <th>Vendor</th>
      <th>Receiving date</th>
      <th>Sender</th>
      <th>Mobile number</th>
      <th>Awb number</th>
      <th>Company</th>
      <th>Company address 1</th>
      <th>Company address 2</th>
      <th>State</th>
      <th>City</th>
      <th>Pincode</th>
      <th>Type</th>
      <th>Created by</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @mail_room_inbounds.each do |mail_room_inbound| %>
      <tr>
        <td><%= mail_room_inbound.vendor_id %></td>
        <td><%= mail_room_inbound.receiving_date %></td>
        <td><%= mail_room_inbound.sender %></td>
        <td><%= mail_room_inbound.mobile_number %></td>
        <td><%= mail_room_inbound.awb_number %></td>
        <td><%= mail_room_inbound.company %></td>
        <td><%= mail_room_inbound.company_address_1 %></td>
        <td><%= mail_room_inbound.company_address_2 %></td>
        <td><%= mail_room_inbound.state %></td>
        <td><%= mail_room_inbound.city %></td>
        <td><%= mail_room_inbound.pincode %></td>
        <td><%= mail_room_inbound.mail_inbound_type %></td>
        <td><%= mail_room_inbound.created_by_id %></td>
        <td><%= link_to 'Show', mail_room_inbound %></td>
        <td><%= link_to 'Edit', edit_mail_room_inbound_path(mail_room_inbound) %></td>
        <td><%= link_to 'Destroy', mail_room_inbound, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Mail Room Inbound', new_mail_room_inbound_path %>
