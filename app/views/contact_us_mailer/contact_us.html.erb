<!DOCTYPE html>
<html>
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
  </head>
  <body style="margin:0; padding:0; background-color:#eef6fb; font-family: Arial, Helvetica, sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;">
      <tr>
        <td align="center">

          <!-- Card -->
          <table width="600" cellpadding="0" cellspacing="0"
            style="background:#ffffff; border-radius:16px; padding:32px; box-shadow:0 10px 30px rgba(0,0,0,0.08);">

            <!-- Header -->
            <tr>
              <td style="font-size:22px; font-weight:600; color:#1f2937; padding-bottom:24px;">
                📩 New Contact Us Message
              </td>
            </tr>

            <!-- Name + Email -->
            <tr>
              <td>
                <table width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td width="50%" style="padding-right:10px;">
                      <p style="margin:0 0 6px; font-size:13px; color:#6b7280;">Name</p>
                      <div style="padding:12px; border:1px solid #e5e7eb; border-radius:8px; font-size:14px;">
                        <%= @name %>
                      </div>
                    </td>

                    <td width="50%" style="padding-left:10px;">
                      <p style="margin:0 0 6px; font-size:13px; color:#6b7280;">Email</p>
                      <div style="padding:12px; border:1px solid #e5e7eb; border-radius:8px; font-size:14px;">
                        <%= @email %>
                      </div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Message -->
            <tr>
              <td style="padding-top:20px;">
                <p style="margin:0 0 6px; font-size:13px; color:#6b7280;">Message</p>
                <div style="padding:14px; border:1px solid #e5e7eb; border-radius:10px; font-size:14px; line-height:1.6;">
                  <%= @message %>
                </div>
              </td>
            </tr>

            <!-- Existing Customer -->
            <tr>
              <td style="padding-top:20px;">
                <p style="margin:0 0 6px; font-size:13px; color:#6b7280;">Existing Customer</p>
                <div style="padding:12px; border:1px solid #e5e7eb; border-radius:8px; font-size:14px;">
                  <%= @existing_customer %>
                </div>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding-top:32px; font-size:12px; color:#9ca3af; text-align:center;">
                This email was sent from the Contact Us form.
              </td>
            </tr>

          </table>
          <!-- End Card -->

        </td>
      </tr>
    </table>

  </body>
</html>
