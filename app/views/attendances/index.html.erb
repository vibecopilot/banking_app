<div class="data-table-area mg-b-15">
  <div class="container-fluid">
    <div class="row">
      <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="sparkline13-list">
          <div class="sparkline13-graph">
            <div class="datatable-dashv1-list custom-datatable-overright">
              <div id="toolbar">
                <%#= link_to 'Export', "", data: {toggle: 'modal', target: '#export-data', backdrop: "static",  keyboard: "false"}, class: "btn custom-button btn-sm"%>
                <%= form_tag "/attendances_report.xlsx", method: :get do %>
        <div class="modal-body">
          <div class="row">
            <div class="col-sm-12">
            <div class="col-sm-6 form-group">
              <label>Site</label>
              <%= select_tag 'site_id[]', options_for_select(@sites.pluck(:name, :id)),:class=>"chosen-select", multiple: true %>
            </div>
          </div>
        </div>
          <div class="row">
            <div class="col-sm-12">
            <div class="col-sm-6 form-group">
              <label>Month</label>
              <div class="ui calendar">
                <div class="ui input left icon"> <i class="calendar icon"></i>
                  <input type="text" placeholder="Select Month" class="month-datepicker" name="month">
                </div>
              </div>
            </div>
          </div>
        </div>
        </div>
          <div class='modal-footer'>
           <div class="col-sm-12 text-center">
              <%= submit_tag "Export", class: 'btn btn-success btn-md export-btn' %>
              </div>
          </div>
        <% end %>
                </div>
          
                  <table class="table table-striped table-responsive sortable" id="table" data-toggle="table" data-pagination="true" 
                data-search="true" data-trim-on-search="false" data-show-columns="true" data-show-refresh="true" data-sortable="true" data-key-events="true" data-show-toggle="true"
                 data-resizable="true" data-cookie="true" data-cookie-id-table="saveId" data-show-export="true" data-click-to-select="true" data-toolbar="#toolbar">
                    <thead>
                      <tr>
                      <th> Actions </th>
                      <th> Name</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% @users.each do |user| %>
                      
                      <tr>
                        <td> <%= link_to "/user_attendances/#{user.id}", class: "btn btn-xs" do %>
                                <i class='fa fa-eye text-info' data-toggle='tooltip' title='View' data-placement = 'right'></i>
                              <% end %></td>
                        <td><%= user.full_name%></td>
                    </tr>
                    <% end %>
                    </tbody>
                  </table>


          </div>
        </div>
        </div>
       </div>
      </div>
    </div>
</div>

<div class="modal fade" id="export-data" role="dialog">
  <div class="modal-dialog"> 
    <div class="modal-content">
        <div class="modal-header">
          <i class="fa fa-times modal-hide" aria-hidden="true" data-dismiss="modal"></i>
            <h4 class="modal-title">Export</h4>
        </div>
        <%= form_tag "/attendances_report.xlsx", method: :get do %>
        <div class="modal-body">
          <div class="row">
            <div class="col-sm-12">
            <div class="col-sm-6 form-group">
              <label>Site</label>
              <%= select_tag 'site_id[]', options_for_select(@sites.pluck(:name, :id)),:class=>"chosen-select", multiple: true %>
            </div>
          </div>
        </div>
          <div class="row">
            <div class="col-sm-12">
            <div class="col-sm-6 form-group">
              <label>Month</label>
              <div class="ui calendar">
                <div class="ui input left icon"> <i class="calendar icon"></i>
                  <input type="text" placeholder="Select Month" class="month-datepicker" name="month">
                </div>
              </div>
            </div>
          </div>
        </div>
        </div>
          <div class='modal-footer'>
           <div class="col-sm-12 text-center">
              <%= submit_tag "Export", class: 'btn btn-success btn-md export-btn' %>
              </div>
          </div>
        <% end %>
        </div>
        <%= link_to 'Back', setup_path %>
    </div>
</div>
<%= link_to 'Back', setup_path %>


<script type="text/javascript">


  $(".month-datepicker").datepicker({
      autoclose: true,
      format: "yyyy-mm",
      startView: "months", 
      minViewMode: "months"
  });

 $('.export-btn').click(function(e){
    e.preventDefault();
    form = $(this).parents("form");
    if (form.find('[name="site_id[]"]').length == 1 && form.find('[name="site_id[]"]').val() == null) {
      toastr.error("Please Select at least one Site");
      return false
    }

    if (form.find('[name="month"]').val() == "") {
      toastr.error("Please Select Month");
      return false
    }
    form.submit();
    $('#export-data').modal('hide');
 });

</script>

