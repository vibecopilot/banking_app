  </div>

  <div class="field">
    <%= form.label :fax_number %>
    <%= form.text_field :fax_number, id: :address_setup_fax_number %>
  </div>

  <div class="field">
    <%= form.label :email_address %>
    <%= form.text_field :email_address, id: :address_setup_email_address %>
  </div>

  <div class="field">
    <%= form.label :registration_no %>
