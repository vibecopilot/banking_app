<%= form_with(model: address_setup, local: true) do |form| %>
  <% if address_setup.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(address_setup.errors.count, "error") %> prohibited this address_setup from being saved:</h2>

      <ul>
      <% address_setup.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title %>
