<p id="notice"><%= notice %></p>

<h1>Address Setups</h1>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Address</th>
      <th>Building</th>
      <th>State</th>
      <th>Phone number</th>
      <th>Fax number</th>
      <th>Email address</th>
      <th>Registration no</th>
      <th>Pan number</th>
      <th>Cheque in favour of</th>
      <th>Gst number</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @address_setups.each do |address_setup| %>
      <tr>
        <td><%= address_setup.title %></td>
        <td><%= address_setup.address %></td>
        <td><%= address_setup.building_id %></td>
        <td><%= address_setup.state %></td>
        <td><%= address_setup.phone_number %></td>
        <td><%= address_setup.fax_number %></td>
        <td><%= address_setup.email_address %></td>
        <td><%= address_setup.registration_no %></td>
        <td><%= address_setup.pan_number %></td>
        <td><%= address_setup.cheque_in_favour_of %></td>
        <td><%= address_setup.gst_number %></td>
        <td><%= link_to 'Show', address_setup %></td>
        <td><%= link_to 'Edit', edit_address_setup_path(address_setup) %></td>
        <td><%= link_to 'Destroy', address_setup, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Address Setup', new_address_setup_path %>
