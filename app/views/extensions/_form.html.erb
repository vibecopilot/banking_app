<%= form_with(model: extension, local: true) do |form| %>
  <% if extension.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(extension.errors.count, "error") %> prohibited this extension from being saved:</h2>

      <ul>
      <% extension.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :permit_id %>
    <%= form.number_field :permit_id, id: :extension_permit_id %>
  </div>

  <div class="field">
    <%= form.label :ext_date %>
    <%= form.date_select :ext_date, id: :extension_ext_date %>
  </div>

  <div class="field">
    <%= form.label :ext_time %>
    <%= form.time_select :ext_time, id: :extension_ext_time %>
  </div>

  <div class="field">
    <%= form.label :created_by_id %>
    <%= form.number_field :created_by_id, id: :extension_created_by_id %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
