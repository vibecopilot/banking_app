  <a href="/asset_groups"><span class="nav-link"> Asset Groups </span> </a>
</div>
<div class="col-sm-4 <%= (request.original_url.include? '/items') ? 'active' : '' %>">
  <a href="/items"><span class="nav-link"> Items Setup </span> </a>
</div>
<% end %>
<div class="col-sm-4 <%= (request.original_url.include? '/vendors') ? 'active' : '' %>">
  <a href="/vendors"><span class="nav-link"> Vendors </span> </a>
</div>
<div class="col-sm-4 <%= (request.original_url.include? '/floors') ? 'active' : '' %>">
