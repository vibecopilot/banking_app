<% @site = Site.find_by_id(@user.current_site_id)
features = if @site.present?
                   @site.features.pluck(:feature_name)
                 else
                   [] %>
                  <li style="color: red;background: wheat;"> Please Select Site by clicking on the user icon</li>

                 <% end %>

      <% if features.include? "tickets" %>
<div class="col-sm-4 <%= (request.original_url.include? '/pms/admin/complaints') ? 'active' : '' %>">
  <a href="/pms/admin/complaints"><span class="nav-link"> Tickets </span> </a>
</div>
<% end %>

<% if @user.id == 2 %>
<div class="col-sm-4 <%= (request.original_url.include? '/sites') ? 'active' : '' %>">
