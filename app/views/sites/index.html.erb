<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Modal Example</title>
  <!-- Bootstrap CSS -->
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" rel="stylesheet">
  <!-- jQuery -->
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
  <!-- Bootstrap JavaScript -->
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</head>
<body>
<div class="row ">
  <h4 class="pull-left" style="width: 100%; text-align: left;"> Companies  <hr></h4>
  <div class="col-sm-12 help">
    <%= form_with(model: Company.new, url: "/companies") do |form| %>
      <div class="col-sm-3">
        <%= form.label :name %>
        <%= form.text_field :name, id: :site_name, required: true %>
      </div>

      <div class="col-sm-3">
        <%= form.submit %>
      </div>
    <% end %>
  </div>
</div>
  <br>
<div class="row ">
  <div class="row ml-2 mr-2">
    <table class="table table-striped table-responsive ">
      <thead>
        <th>Name</th>
        <th>Created By</th>
        <th>Created On</th>
      </thead>
      <tbody>
        <% Company.all.each do |site| %>
          <tr>
            <td><%= site.name %></td>
            <td><%= site.created_by_user.try(:full_name) %></td>
            <td><%= site.created_at.strftime("%d/%m/%Y %l/%M %p") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<p id="notice"><%= notice %></p>
  <div class="col-sm-12">
    <h4 class="pull-left" style="width: 100%; text-align: left;"> Sites  <hr></h4>
  </div>
<div class="ml-2 mr-2">
<div id="toolbar">
  <%= link_to 'New Site', new_site_path,  :class => "create_user" %>
  <button type="button" class="create_user mr-2" data-toggle="modal" data-target="#site-bulkupload">
    Import
  </button>
</div>

<table class="table table-striped table-responsive " id="table" data-toggle="table" data-pagination="true" data-search="true" data-trim-on-search="false" data-show-columns="true" data-show-refresh="true" data-sortable="true" data-key-events="true" data-show-toggle="true" data-resizable="true" data-cookie="true" data-cookie-id-table="saveId" data-show-export="true" data-click-to-select="true" data-toolbar="#toolbar">

  <thead>
    <tr>
      <th>Id</th>
      <th>View</th>
      <th>Company</th>
      <th>Name</th>
      <th>Region</th>
      <th>City</th>
      <th>Features</th>
      <th>Edit</th>
      <th>Action</th>
      <th>Delete</th>
    </tr>
  </thead>

  <tbody>
    <% @sites.each do |site| %>
      <tr>
        <td><%= site.id %></td>
        <td><a href="/sites/<%= site.id%>" class="btn btn-xs"><i class="fa fa-eye text-info" aria-hidden="true"></i></a></td>
        <td><%= site&.company&.name %></td>
        <td><%= site.name %></td>
        <td><%= site.region %></td>
        <td><%= site.city %></td>
        <td><%= site.features.pluck(:feature_name) %></td>
        <td><a href="/sites/<%= site.id%>/edit" class="btn btn-xs"><i class="fa fa-pencil text-info" aria-hidden="true"></i></a></td>
        <td>
          <% if site.active %>
            <%= link_to 'Disable', toggle_active_site_path(site), method: :patch, class: 'btn btn-xs btn-warning', data: { confirm: 'Are you sure you want to disable this site?' } %>
          <% else %>
            <%= link_to 'Enable', toggle_active_site_path(site), method: :patch, class: 'btn btn-xs btn-success', data: { confirm: 'Are you sure you want to enable this site?' } %>
          <% end %>
        </td>
        <td><%= link_to 'Destroy', site , method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>

    <% end %>
  </tbody>
</table>
<%= link_to 'Back', setup_path %>
<br>

<div class="modal fade" id="site-bulkupload" tabindex="-2" role="dialog" aria-labelledby="myModalLabel">
  <div class="modal-dialog" role="document"> 
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title" id="myModalLabel">Bulk Upload</h4>
      </div>
      <div class="modal-body">
        <%= form_tag import_sites_path, method: :post, multipart: true do %>
          <div class="form-group">
            <section class="upload-div"> Drag &amp; Drop or <%= file_field_tag :file, required: true %></section>
          </div>
      </div>
      <div class='modal-footer'>
        <div class="form-group">
          <%= link_to "Download Sample Format", "/assets/site_import.xlsx", {download: 'site_import.xlsx', target:"_blank", :class => "create_user mr-2"} %>
          <%= submit_tag "Import", class: 'create_user mr-2' %>
        </div>
      </div>
      <% end %>
    </div>
  </div>
</div>

