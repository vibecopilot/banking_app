<!DOCTYPE html>
<html lang="en">
<head>
  <title>Soft Services QR Codes</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">

  <style>
    body {
      background: #fff;
      margin: 0;
      padding: 0;
    }

    page {
      background: white;
      display: block;
      margin: 0 auto;
      width: 21cm;
      min-height: 29.7cm;
      padding: 20px;
    }

    .cards {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}


    /* CARD STYLE */
    .card {
      border: 1px solid #ccc;
      margin: 20px 0;
      padding: 18px 24px 12px;
       width: 48%;
  margin-bottom: 20px;
      background: #fff;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }

    /* QR */
    .qr {
      width: 100%;
      text-align: center;
      margin-bottom: 12px;
    }

    .qr img {
      width: 120px;
      height: 120px;
      object-fit: contain;
      display: inline-block;
    }

    /* DETAILS */
    .details p {
      margin: 0 0 6px;
      font-size: 15px;
    }

    .details b {
      font-weight: bold;
    }

    /* PRINT SAFE PAGINATION */
    @media print {
      .card {
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .page-break {
        page-break-after: always;
        break-after: page;
      }

      page {
        box-shadow: none;
        margin: 0;
      }
    }
  </style>
</head>

<body>

<page size="A4">
  <div class="cards">

    <% @soft_services.each_with_index do |soft_service, index| %>

      <% if index % 8 == 0 && index != 0 %>
        </div>
        </page>
        <div class="page-break"></div>
        <page size="A4">
        <div class="cards">
      <% end %>

      <div class="card">

        <div class="qr">
          <img src="<%= soft_service.try(:qr_code_image).try(:whole_path).to_s %>" alt="QR Code">
        </div>

        <div class="details">
          <p>
            <b>Name:</b>
            <%= soft_service.name %> (<%= soft_service.id %>)
          </p>

          <p><b>Model Number:</b></p>

          <p>
            <b>Location:</b>
            <%= soft_service.site&.name || "NA" %> /
            <%= soft_service.building&.name || "NA" %> /
            <%= soft_service.floor&.name || "NA" %> /
            <%= soft_service.unit&.name %>
          </p>
        </div>

      </div>

    <% end %>

  </div>
</page>


</body>
</html>
