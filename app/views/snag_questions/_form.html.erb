    <%= form.label :user_id %>
    <%= form.number_field :user_id, id: :snag_question_user_id %>
  </div>

  <div class="field">
    <%= form.label :img_mandatory %>
    <%= form.check_box :img_mandatory, id: :snag_question_img_mandatory %>
  </div>

  <div class="field">
    <%= form.label :quest_mandatory %>
    <%= form.check_box :quest_mandatory, id: :snag_question_quest_mandatory %>
  </div>

  <div class="field">
    <%= form.label :active %>
    <%= form.number_field :active, id: :snag_question_active %>
  </div>

  <div class="field">
    <%= form.label :company_id %>
