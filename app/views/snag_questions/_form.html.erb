<%= form_with(model: snag_question, local: true) do |form| %>
  <% if snag_question.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(snag_question.errors.count, "error") %> prohibited this snag_question from being saved:</h2>

      <ul>
      <% snag_question.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :qtype %>
    <%= form.text_field :qtype, id: :snag_question_qtype %>
