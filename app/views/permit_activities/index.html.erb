<p id="notice"><%= notice %></p>

<h1>Permit Activities</h1>

<table>
  <thead>
    <tr>
      <th>Permit</th>
      <th>Activity</th>
      <th>Sub activity</th>
      <th>Category of hazards</th>
      <th>Risks</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @permit_activities.each do |permit_activity| %>
      <tr>
        <td><%= permit_activity.permit_id %></td>
        <td><%= permit_activity.activity %></td>
        <td><%= permit_activity.sub_activity %></td>
        <td><%= permit_activity.category_of_hazards %></td>
        <td><%= permit_activity.risks %></td>
        <td><%= link_to 'Show', permit_activity %></td>
        <td><%= link_to 'Edit', edit_permit_activity_path(permit_activity) %></td>
        <td><%= link_to 'Destroy', permit_activity, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Permit Activity', new_permit_activity_path %>
