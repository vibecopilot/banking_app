<p id="notice"><%= notice %></p>

<h1>Inventories</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Inventory type</th>
      <th>Criticality</th>
      <th>Asset group</th>
      <th>Asset sub group</th>
      <th>Asset</th>
      <th>Code</th>
      <th>Serial number</th>
      <th>Quantity</th>
      <th>Min stock level</th>
      <th>Min order level</th>
      <th>Cgst rate</th>
      <th>Sgst rate</th>
      <th>Igst rate</th>
      <th>Active</th>
      <th>Hsn</th>
      <th>Expiry date</th>
      <th>Unit</th>
      <th>Cost</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @inventories.each do |inventory| %>
      <tr>
        <td><%= inventory.name %></td>
        <td><%= inventory.inventory_type %></td>
        <td><%= inventory.criticality %></td>
        <td><%= inventory.asset_group_id %></td>
        <td><%= inventory.asset_sub_group_id %></td>
        <td><%= inventory.asset_id %></td>
        <td><%= inventory.code %></td>
        <td><%= inventory.serial_number %></td>
        <td><%= inventory.quantity %></td>
        <td><%= inventory.min_stock_level %></td>
        <td><%= inventory.min_order_level %></td>
        <td><%= inventory.cgst_rate %></td>
        <td><%= inventory.sgst_rate %></td>
        <td><%= inventory.igst_rate %></td>
        <td><%= inventory.active %></td>
        <td><%= inventory.hsn_id %></td>
        <td><%= inventory.expiry_date %></td>
        <td><%= inventory.unit %></td>
        <td><%= inventory.cost %></td>
        <td><%= link_to 'Show', inventory %></td>
        <td><%= link_to 'Edit', edit_inventory_path(inventory) %></td>
        <td><%= link_to 'Destroy', inventory, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Inventory', new_inventory_path %>
