<p id="notice"><%= notice %></p>

<h1>Permit Extensions</h1>

<table>
  <thead>
    <tr>
      <th>Permit</th>
      <th>Site</th>
      <th>Reason</th>
      <th>Ext date</th>
      <th>Ext time</th>
      <th>Assign to ids</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @permit_extensions.each do |permit_extension| %>
      <tr>
        <td><%= permit_extension.permit_id %></td>
        <td><%= permit_extension.site_id %></td>
        <td><%= permit_extension.reason %></td>
        <td><%= permit_extension.ext_date %></td>
        <td><%= permit_extension.ext_time %></td>
        <td><%= permit_extension.assign_to_ids %></td>
        <td><%= link_to 'Show', permit_extension %></td>
        <td><%= link_to 'Edit', edit_permit_extension_path(permit_extension) %></td>
        <td><%= link_to 'Destroy', permit_extension, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Permit Extension', new_permit_extension_path %>
