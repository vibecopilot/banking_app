<p id="notice"><%= notice %></p>

<h1>Permit Types</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Site</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @permit_types.each do |permit_type| %>
      <tr>
        <td><%= permit_type.name %></td>
        <td><%= permit_type.site_id %></td>
        <td><%= link_to 'Show', permit_type %></td>
        <td><%= link_to 'Edit', edit_permit_type_path(permit_type) %></td>
        <td><%= link_to 'Destroy', permit_type, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Permit Type', new_permit_type_path %>
