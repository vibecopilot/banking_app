<p id="notice"><%= notice %></p>

<h1>Folders</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Parent</th>
      <th>Structure</th>
      <th>Date of upload</th>
      <th>Description</th>
      <th>Site</th>
      <th>Uploaded by</th>
      <th>Folder type</th>
      <th>Unit</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @folders.each do |folder| %>
      <tr>
        <td><%= folder.name %></td>
        <td><%= folder.parent_id %></td>
        <td><%= folder.structure %></td>
        <td><%= folder.date_of_upload %></td>
        <td><%= folder.description %></td>
        <td><%= folder.site_id %></td>
        <td><%= folder.uploaded_by %></td>
        <td><%= folder.folder_type %></td>
        <td><%= folder.unit_id %></td>
        <td><%= link_to 'Show', folder %></td>
        <td><%= link_to 'Edit', edit_folder_path(folder) %></td>
        <td><%= link_to 'Destroy', folder, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Folder', new_folder_path %>
