<%= form_with(model: registered_vehicle, local: true, multipart: true) do |form| %>
  <% if registered_vehicle.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(registered_vehicle.errors.count, "error") %> prohibited this registered_vehicle from being saved:</h2>

      <ul>
      <% registered_vehicle.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :slot_number %>
