  </div>

  <div class="field">
    <%= form.label :registration_number %>
    <%= form.text_field :registration_number, id: :registered_vehicle_registration_number %>
  </div>

  <div class="field">
    <%= form.label :insurance_number %>
    <%= form.text_field :insurance_number, id: :registered_vehicle_insurance_number %>
