<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Modal Example</title>
  <!-- Bootstrap CSS -->
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" rel="stylesheet">
  <!-- jQuery -->
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
  <!-- Bootstrap JavaScript -->
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</head>
<body>
<p id="notice"><%= notice %></p>
<div class="col-sm-12">
  <h4 class="pull-left" style="width: 100%; text-align: left;"> Buildings  <hr></h4>
</div>
<div class="ml-2 mr-2">
<div id="toolbar">
  <% if @user.user_type == 'pms_admin' %>
<%= link_to 'New Building', new_building_path,  :class => "create_user", :style => "float: left;" %>
    <button type="button" class="create_user mr-2" data-toggle="modal" data-target="#vendor-bulkupload">
    Import
  </button>
    <% end %>
</div>
<table class="table table-striped table-responsive " id="table" data-toggle="table" data-pagination="true" data-search="true" data-trim-on-search="false" data-show-columns="true" data-show-refresh="true" data-sortable="true" data-key-events="true" data-show-toggle="true" data-resizable="true" data-cookie="true" data-cookie-id-table="saveId" data-show-export="true" data-click-to-select="true" data-toolbar="#toolbar">
  <thead>
    <tr>
      <th>Name</th>
      <th>Site</th>
      <th>Floors</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @buildings.each do |building| %>
      <tr>
        <td><%= building.name %></td>
        <td><%= building.site.try(:name) %></td>
        <td><%= building.floors.try(:count) %></td>
        <td><%= link_to 'Show', building %></td>
        <td><%= link_to 'Edit', edit_building_path(building) %></td>
        <td><%= link_to 'Destroy', building, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<div class="modal fade" id="vendor-bulkupload" tabindex="-2" role="dialog" aria-labelledby="myModalLabel">
  <div class="modal-dialog" role="document"> 
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <h4 class="modal-title" id="myModalLabel">Bulk Upload</h4>
      </div>
      <div class="modal-body">
        <%= form_tag import_buildings_path, method: :post, multipart: true do %>
          <div class="form-group">
            <section class="upload-div"> Drag &amp; Drop or <%= file_field_tag :file, required: true %></section>
          </div>
      </div>
      <div class='modal-footer'>
        <div class="form-group">
          <%= link_to "Download Sample Format", "/assets/building_import.xlsx", {download: 'building_import.xlsx', target:"_blank", :class => "create_user mr-2"} %>
          <%= submit_tag "Import", class: 'create_user mr-2' %>
        </div>
      </div>
      <% end %>
    </div>
  </div>
</div>

</div>
<%= link_to 'Back', setup_path %>
<br>

