<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Ticket Assigned</title>
    <style>
    .flow-root{
      width: 100%;
      display: flow-root;
      text-align: center;
    }
    .reject{
      border: none;
    background: #f23004;
    color: white;
    padding: 6px 39px;
    border-radius: 5px;
    font-size: 14px;

    }
    .approve{
      border: none;
background: #058505;
color: white;
padding: 6px 29px;
border-radius: 5px;
font-size: 14px;

}

        @font-face {
            font-family: 'Product Sans';
            font-style: normal;
            font-weight: normal;
            src: url(product-sans-regular.ttf);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Product Sans';
        }

        body {
            font-size: 14px;
            color: #161616;
            overflow-x: hidden;
        }

        h2 {
            font-size: 16px;
        }

        .ticket-container {
            width: 73%;
            margin: 0 auto;
        }

        .assigned-ticket-info,
        .generated-ticket-info {
            background: #fff;
            border: 1px solid #00000029;
            border-radius: 10px;
            padding: 1.5rem;
            margin: 0 1.5rem;
        }

        .ticket-details {
            float: left;
            width: 33.33%;
            margin: 10px 0;
        }

        .footer {
            text-align: center;
            padding: 0.5rem;
        }

        .email-note {
            color: #a4a4a4;
            text-align: center;
            clear: both;
            margin-top: 25px;
        }

        /* Utility Classes */
        .text-underline {
            text-decoration: underline;
        }

        .text-center {
            text-align: center;
        }

        .text-bold {
            font-weight: bold;
        }

        .mt-10 {
            margin-top: 10px;
        }

        .mb-5 {
            margin-bottom: 5px;
        }

        .mb-10 {
            margin-bottom: 10px;
        }
        .img-flex{
          display: flex;
          justify-content: center;
        }
        .img-flex img{
          width: 96%;
        }
        @media only screen and (max-width: 768px) {
          .img-flex{
            height: 100%;
          }
            .ticket-container {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <div class="ticket-container">
        <div>
            <div class="assigned-ticket-info">
              <br>

                <div>
                    <span class="text-bold">Dear <%= @complaint_assigned_to.firstname %>,</span><br>
                    <span>A new ticket has been assigned to you,
                       below is the ticket summary
                    </span>
                </div>
                <br>

                      <div>
                          <h2 class="">Ticket Info</h2>
                      </div>
                      <div class="ticket-details" style="width: 100%">
                          <span class="text-bold mb-5">Title:</span><br>
                          <span><%= @complaint.heading.present? ? @complaint.heading : '-' %></span>
                      </div>
                <div>

                    <div class="ticket-details">
                        <span class="text-bold mb-5">Ticket Number:</span><br>
                        <span><%= @complaint.ticket_number %></span>
                    </div>
                    <div class="ticket-details">
                        <span class="text-bold mb-5"> Category:</span><br>
                        <span><%= @complaint.category_type.name %></span>
                    </div>
                    <div class="ticket-details">
                        <span class="text-bold mb-5">Sub Category:</span><br>
                        <span><%= @complaint.sub_category_id.present? ? HelpdeskSubCategory.find_by_id(@complaint.sub_category_id).try(:name): "-" %></span>
                    </div>
                    <div class="ticket-details">
                        <span class="text-bold mb-5">Status:</span><br>
                        <span><%= @complaint.issue_status.present? ? (ComplaintStatus.find_by_id(@complaint.issue_status).try(:name) || @complaint.issue_status ) : "pending" %></span>
                    </div>
                    <div class="ticket-details">
                        <span class="text-bold mb-5">Assigned To:</span><br>
                        <span><%= @complaint_assigned_to.full_name %></span>
                    </div>
                    <div class="ticket-details">
                        <span class="text-bold mb-5">Created On:</span><br>
                        <span><%= @complaint.created_at.strftime("%d/%m/%Y") %></span>
                    </div>

                </div>

<br> <br> <br>
<!-- creator info -->
                  <div style="  width: 100%;display: flow-root;margin-top: 132px;">
                      <h2 class="">Creator's Info</h2>
                  </div>

                  <div>
                  <div class="ticket-details">
                  <span class="text-bold mb-5">Name:</span><br>
                  <span><%= @complaint.user.full_name %></span>
                  </div>
                  <div class="ticket-details">
                    <span class="text-bold mb-5">Mobile:</span><br>
                    <span><%= @complaint.user.mobile.present? ? @complaint.user.mobile : '-'%></span>
                  </div>
                  <div class="ticket-details">
                    <span class="text-bold mb-5"> Site:</span><br>
                    <span><%= @complaint.user.site.present? ? @complaint.user.site.name : '-'%></span>
                  </div>
                  <div class="ticket-details" style="width: 100%;">
                    <span class="text-bold mb-5">Address:</span><br>
                    <span> - </span>
                  </div>

                </div> <br>
                  <div class="flow-root">
                    <button type="button" name="button" class="approve">Approve</button>
                    <button type="button" name="button" class="reject">Reject</button>
                  </div>
                <div class="email-note">Note: This is an automated email. Please do not reply.</div>
            </div>

            
        </div>
    </div>
</body>

</html>