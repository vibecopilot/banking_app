wb = xlsx_package.workbook

wb.add_worksheet(name: "Readings") do |sheet|
  sheet.add_row [
    "S.No",
    "Date",
    "Time",
    "Parameter",
    "Closing / Value",
    "Difference (Consumption)",
    "Submitted By",
    "Asset Name"
  ]

  @submissions.each_with_index do |submission, index|
    sheet.add_row [
      index + 1,
      submission.created_at.strftime("%d/%m/%Y"),
      submission.created_at.strftime("%I:%M %p"),
      submission.asset_param&.name || submission.question&.name,
      submission.value,
      @consumption_map[submission.id], 
      submission.user&.full_name,
      submission.site_asset&.name
    ]
  end
end