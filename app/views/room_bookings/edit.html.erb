<div class="container-fluid">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <div class="card">
        <div class="card-header">
          <h4 class="card-title mb-0">
            <i class="fas fa-edit mr-2"></i>
            Edit Booking: <%= @room_booking.booking_reference %>
          </h4>
        </div>
        
        <div class="card-body">
          <% if @room_booking.checked_in? || @room_booking.checked_out? %>
            <div class="alert alert-warning">
              <i class="fas fa-exclamation-triangle mr-2"></i>
              <strong>Note:</strong> This booking has already been checked in. Some fields may be restricted.
            </div>
          <% end %>
          
          <%= form_with model: @room_booking, local: true, id: "booking_form" do |f| %>
            <% if @room_booking.errors.any? %>
              <div class="alert alert-danger">
                <h6><%= pluralize(@room_booking.errors.count, "error") %> prohibited this booking from being saved:</h6>
                <ul class="mb-0">
                  <% @room_booking.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <!-- Room Information (Read-only for checked-in bookings) -->
            <div class="form-group">
              <%= f.label :room_id, "Room" %>
              <% if @room_booking.checked_in? || @room_booking.checked_out? %>
                <%= f.hidden_field :room_id %>
                <div class="form-control-plaintext">
                  <strong><%= @room_booking.room.display_name %></strong> - <%= @room_booking.room.room_type.humanize %>
                </div>
              <% else %>
                <%= f.select :room_id, 
                    options_from_collection_for_select(
                      Room.where(site: current_user.site).active.order(:room_number), 
                      :id, :display_name, @room_booking.room_id
                    ), 
                    {}, 
                    { class: "form-control", id: "room_select" } %>
              <% end %>
            </div>

            <!-- Date Selection (Read-only for checked-in bookings) -->
            <div class="row">
              <div class="col-md-6">
                <div class="form-group">
                  <%= f.label :check_in_date, "Check-in Date" %>
                  <% if @room_booking.checked_in? || @room_booking.checked_out? %>
                    <%= f.hidden_field :check_in_date %>
                    <div class="form-control-plaintext">
                      <%= @room_booking.check_in_date.strftime('%A, %d %B %Y') %>
                    </div>
                  <% else %>
                    <%= f.date_field :check_in_date, 
                        class: "form-control", 
                        min: Date.current,
                        id: "check_in_date" %>
                  <% end %>
                </div>
              </div>
              
              <div class="col-md-6">
                <div class="form-group">
                  <%= f.label :check_out_date, "Check-out Date" %>
                  <% if @room_booking.checked_out? %>
                    <%= f.hidden_field :check_out_date %>
                    <div class="form-control-plaintext">
                      <%= @room_booking.check_out_date.strftime('%A, %d %B %Y') %>
                    </div>
                  <% else %>
                    <%= f.date_field :check_out_date, 
                        class: "form-control", 
                        min: @room_booking.check_in_date || Date.current + 1.day,
                        id: "check_out_date" %>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- Guest Count -->
            <div class="row">
              <div class="col-md-6">
                <div class="form-group">
                  <%= f.label :number_of_adults, "Number of Adults" %>
                  <%= f.number_field :number_of_adults, 
                      class: "form-control", 
                      min: 1, max: 10,
                      id: "adults_count" %>
                </div>
              </div>
              
              <div class="col-md-6">
                <div class="form-group">
                  <%= f.label :number_of_children, "Number of Children" %>
                  <%= f.number_field :number_of_children, 
                      class: "form-control", 
                      min: 0, max: 10,
                      id: "children_count" %>
                </div>
              </div>
            </div>

            <!-- Guest Information -->
            <div class="row">
              <div class="col-md-6">
                <div class="form-group">
                  <%= f.label :guest_name, "Guest Name" %>
                  <%= f.text_field :guest_name, class: "form-control" %>
                </div>
              </div>
              
              <div class="col-md-6">
                <div class="form-group">
                  <%= f.label :guest_phone, "Guest Phone" %>
                  <%= f.telephone_field :guest_phone, class: "form-control" %>
                </div>
              </div>
            </div>

            <div class="form-group">
              <%= f.label :guest_email, "Guest Email" %>
              <%= f.email_field :guest_email, class: "form-control" %>
            </div>

            <!-- Special Requests -->
            <div class="form-group">
              <%= f.label :special_requests, "Special Requests" %>
              <%= f.text_area :special_requests, 
                  class: "form-control", 
                  rows: 3 %>
            </div>

            <!-- Payment Status (Admin only) -->
            <% if current_user.admin? || current_user.manager? %>
              <div class="form-group">
                <%= f.label :payment_status, "Payment Status" %>
                <%= f.select :payment_status, 
                    options_for_select([
                      ['Unpaid', 'unpaid'],
                      ['Partial', 'partial'],
                      ['Paid', 'paid'],
                      ['Refunded', 'refunded']
                    ], @room_booking.payment_status), 
                    {}, 
                    { class: "form-control" } %>
              </div>
            <% end %>

            <!-- Current Pricing Summary -->
            <div class="card bg-light mt-4">
              <div class="card-header">
                <h6 class="mb-0">Current Booking Summary</h6>
              </div>
              <div class="card-body">
                <div class="row">
                  <div class="col-md-6">
                    <table class="table table-sm">
                      <tr>
                        <td><strong>Duration:</strong></td>
                        <td><%= @room_booking.duration_nights %> night<%= 's' if @room_booking.duration_nights > 1 %></td>
                      </tr>
                      <tr>
                        <td><strong>Subtotal:</strong></td>
                        <td>$<%= @room_booking.subtotal_amount %></td>
                      </tr>
                      <tr>
                        <td><strong>Tax:</strong></td>
                        <td>$<%= @room_booking.tax_amount %></td>
                      </tr>
                      <tr class="table-primary">
                        <td><strong>Total:</strong></td>
                        <td><strong>$<%= @room_booking.total_amount %></strong></td>
                      </tr>
                    </table>
                  </div>
                  <div class="col-md-6">
                    <table class="table table-sm">
                      <tr>
                        <td><strong>Status:</strong></td>
                        <td>
                          <span class="badge <%= case @room_booking.status
                                                when 'pending' then 'badge-warning'
                                                when 'confirmed' then 'badge-info'
                                                when 'checked_in' then 'badge-success'
                                                when 'checked_out' then 'badge-secondary'
                                                when 'cancelled' then 'badge-danger'
                                                else 'badge-light'
                                                end %>">
                            <%= @room_booking.status.humanize %>
                          </span>
                        </td>
                      </tr>
                      <tr>
                        <td><strong>Payment:</strong></td>
                        <td>
                          <span class="badge <%= case @room_booking.payment_status
                                                when 'unpaid' then 'badge-danger'
                                                when 'partial' then 'badge-warning'
                                                when 'paid' then 'badge-success'
                                                when 'refunded' then 'badge-secondary'
                                                else 'badge-light'
                                                end %>">
                            <%= @room_booking.payment_status.humanize %>
                          </span>
                        </td>
                      </tr>
                      <tr>
                        <td><strong>Created:</strong></td>
                        <td><%= @room_booking.created_at.strftime('%d %b %Y') %></td>
                      </tr>
                    </table>
                  </div>
                </div>
              </div>
            </div>

            <!-- Updated Pricing Summary (for date/room changes) -->
            <div id="pricing_summary" class="card bg-success text-white mt-4" style="display: none;">
              <div class="card-header">
                <h6 class="mb-0">Updated Booking Summary</h6>
              </div>
              <div class="card-body">
                <div id="pricing_details">
                  <!-- Updated pricing will be loaded here via JavaScript -->
                </div>
              </div>
            </div>

            <!-- Submit Buttons -->
            <div class="form-group mt-4">
              <div class="row">
                <div class="col-md-4">
                  <%= f.submit "Update Booking", class: "btn btn-primary btn-block" %>
                </div>
                <div class="col-md-4">
                  <%= link_to "View Booking", @room_booking, class: "btn btn-success btn-block" %>
                </div>
                <div class="col-md-4">
                  <%= link_to "Cancel", @room_booking, class: "btn btn-secondary btn-block" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const roomSelect = document.getElementById('room_select');
  const checkInField = document.getElementById('check_in_date');
  const checkOutField = document.getElementById('check_out_date');
  const pricingSummary = document.getElementById('pricing_summary');
  const pricingDetails = document.getElementById('pricing_details');
  
  const originalRoomId = '<%= @room_booking.room_id %>';
  const originalCheckIn = '<%= @room_booking.check_in_date.strftime('%Y-%m-%d') %>';
  const originalCheckOut = '<%= @room_booking.check_out_date.strftime('%Y-%m-%d') %>';
  
  // Update check-out minimum date when check-in changes
  if (checkInField) {
    checkInField.addEventListener('change', function() {
      const checkInDate = new Date(this.value);
      const nextDay = new Date(checkInDate);
      nextDay.setDate(nextDay.getDate() + 1);
      
      if (checkOutField) {
        checkOutField.min = nextDay.toISOString().split('T')[0];
        
        if (new Date(checkOutField.value) <= checkInDate) {
          checkOutField.value = nextDay.toISOString().split('T')[0];
        }
      }
      
      updatePricing();
    });
  }
  
  // Update pricing when relevant fields change
  [checkOutField, roomSelect].forEach(field => {
    if (field) {
      field.addEventListener('change', updatePricing);
    }
  });
  
  function updatePricing() {
    const currentRoomId = roomSelect?.value || originalRoomId;
    const currentCheckIn = checkInField?.value || originalCheckIn;
    const currentCheckOut = checkOutField?.value || originalCheckOut;
    
    // Check if anything has changed
    const hasChanges = currentRoomId !== originalRoomId || 
                      currentCheckIn !== originalCheckIn || 
                      currentCheckOut !== originalCheckOut;
    
    if (hasChanges && currentRoomId && currentCheckIn && currentCheckOut && currentCheckIn < currentCheckOut) {
      // Make AJAX call to get updated pricing
      fetch(`/room_bookings/pricing_info?room_id=${currentRoomId}&check_in=${currentCheckIn}&check_out=${currentCheckOut}`)
        .then(response => response.json())
        .then(data => {
          updatePricingDisplay(data);
          pricingSummary.style.display = 'block';
        })
        .catch(error => {
          console.error('Error fetching pricing:', error);
          pricingSummary.style.display = 'none';
        });
    } else {
      pricingSummary.style.display = 'none';
    }
  }
  
  function updatePricingDisplay(data) {
    const nights = data.nights;
    const nightText = nights === 1 ? 'night' : 'nights';
    
    const html = `
      <div class="row">
        <div class="col-md-6">
          <table class="table table-sm text-white">
            <tr>
              <td><strong>Updated Duration:</strong></td>
              <td>${nights} ${nightText}</td>
            </tr>
            <tr>
              <td><strong>Updated Subtotal:</strong></td>
              <td>$${data.subtotal.toFixed(2)}</td>
            </tr>
          </table>
        </div>
        <div class="col-md-6">
          <table class="table table-sm text-white">
            <tr>
              <td><strong>Updated Tax:</strong></td>
              <td>$${data.tax_amount.toFixed(2)}</td>
            </tr>
            <tr>
              <td><strong>New Total:</strong></td>
              <td><strong>$${data.total_amount.toFixed(2)}</strong></td>
            </tr>
          </table>
        </div>
      </div>
      <div class="alert alert-light">
        <small><i class="fas fa-info-circle mr-1"></i>
        Pricing will be updated when you save the booking.</small>
      </div>
    `;
    
    pricingDetails.innerHTML = html;
  }
});
</script>

<style>
.form-group label {
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.form-control-plaintext {
  padding: 0.375rem 0;
  margin-bottom: 0;
  font-size: 1rem;
  line-height: 1.5;
  background-color: transparent;
  border: solid transparent;
  border-width: 1px 0;
}
</style>
