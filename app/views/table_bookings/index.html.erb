<p id="notice"><%= notice %></p>

<h1>Table Bookings</h1>

<table>
  <thead>
    <tr>
      <th>Restaurant</th>
      <th>Ondate</th>
      <th>Ontime</th>
      <th>User</th>
      <th>No of person</th>
      <th>Status</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @table_bookings.each do |table_booking| %>
      <tr>
        <td><%= table_booking.restaurant_id %></td>
        <td><%= table_booking.ondate %></td>
        <td><%= table_booking.ontime %></td>
        <td><%= table_booking.user_id %></td>
        <td><%= table_booking.no_of_person %></td>
        <td><%= table_booking.status %></td>
        <td><%= link_to 'Show', table_booking %></td>
        <td><%= link_to 'Edit', edit_table_booking_path(table_booking) %></td>
        <td><%= link_to 'Destroy', table_booking, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Table Booking', new_table_booking_path %>
