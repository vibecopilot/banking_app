<p id="notice"><%= notice %></p>

<h1>Poll Votes</h1>

<table>
  <thead>
    <tr>
      <th>Poll user</th>
      <th>Poll</th>
      <th>Poll option</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @poll_votes.each do |poll_vote| %>
      <tr>
        <td><%= poll_vote.poll_user_id %></td>
        <td><%= poll_vote.poll.id %></td>
        <td><%= poll_vote.poll_option.id %></td>
        <td><%= link_to 'Show', poll_vote %></td>
        <td><%= link_to 'Edit', edit_poll_vote_path(poll_vote) %></td>
        <td><%= link_to 'Destroy', poll_vote, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Poll Vote', new_poll_path %>
