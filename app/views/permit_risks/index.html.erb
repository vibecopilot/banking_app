<p id="notice"><%= notice %></p>

<h1>Permit Risks</h1>

<table>
  <thead>
    <tr>
      <th>Permit type</th>
      <th>Activity</th>
      <th>Sub activity</th>
      <th>Hazard category</th>
      <th>Risk description</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @permit_risks.each do |permit_risk| %>
      <tr>
        <td><%= permit_risk.permit_type_id %></td>
        <td><%= permit_risk.activity_id %></td>
        <td><%= permit_risk.sub_activity_id %></td>
        <td><%= permit_risk.hazard_category_id %></td>
        <td><%= permit_risk.risk_description %></td>
        <td><%= link_to 'Show', permit_risk %></td>
        <td><%= link_to 'Edit', edit_permit_risk_path(permit_risk) %></td>
        <td><%= link_to 'Destroy', permit_risk, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Permit Risk', new_permit_risk_path %>
