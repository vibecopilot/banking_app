      <strong>Checklist:</strong>
      <%= @checklist.try(:name) %>
    </div>
    <div class="col-sm-4">  
      <strong>Asset:</strong>
      <%= asset.try(:name) %>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-sm-12">
