<div class="wrapper wrapper-content" style="height: 500px; overflow-y: scroll;">
  <section class="content">
    <div class="ibox">
      <div class="ibox-content">
        <div class="row" id="myDiv" style="display: block;">
          <% 
          if params[:q].present? && params[:q][:date_range].present?
           @date_range = params[:q][:date_range].split(" - ")
           params[:q][:start_time_lteq] = Date.strptime(@date_range[1], "%m/%d/%Y").strftime("%d/%m/%Y")
           params[:q][:start_time_gteq] = Date.strptime(@date_range[0], "%m/%d/%Y").strftime("%d/%m/%Y")
          end
          params[:q] = params[:q].present? ? params[:q] : {start_time_gteq: Date.today.beginning_of_month.strftime('%d/%m/%Y'), start_time_lteq: Date.today.end_of_month.strftime('%d/%m/%Y')} %>
          <%= form_tag request.original_fullpath, :method => 'get', :id=>"filters" do %>
            <div class="col-sm-8" style="padding-left: 0px;">
              <div class="form-group col-sm-4 helpdesk-filter" >
                <div class="input-group">
                  <div class="input-group-addon"> <i class="fa fa-calendar"></i> </div>
                  <input type="hidden" name="asset_id" value="<%= params[:asset_id]%>">
                  <input type="text" name='q[date_range]' id ="date_range" class="reservation form-control pull-right" placeholder="Select Date Range" value="<%= params[:q][:date_range] %>">
                </div>
              </div>
              <div class="col-sm-4 form-group">
                <button type="button" class="applyfilter btn btn-success btn-sm"> Apply</button>
                <a href="<%= request.original_fullpath %>"><button type="button" id="" class="btn btn-info btn-sm"> Reset</button></a>
                <button type="button" class="applyfilter2 btn btn-success btn-sm"> Export</button>
              </div>
            </div>
        
          <% end %>
        </div>
        <div  id="table-scroll" class="table-scroll">
          <div class="table-wrap">
            <table class="main-table">
              <thead>
                <tr>
                  <td class="w36 fixed-side"></td>
                  <%
                  params[:q][:checklist_id_eq] = @checklist.id
                  params[:q][:asset_id_eq] = asset.id
                  @occurrences = Activity.ransack(params[:q]).result
                  sd = params[:q][:start_time_gteq].split("/")
                  ed = params[:q][:start_time_lteq].split("/")
                  st_date = Date.new(sd[2].to_i, sd[1].to_i, sd[0].to_i)
                  en_date = Date.new(ed[2].to_i, ed[1].to_i, ed[0].to_i)
                   (st_date..en_date).each do |sdate| 
                    occ = @occurrences.where("DATE(activities.start_time)=?", sdate)  %>
                  <td colspan="<%= occ.count %>" class="text-center border_black" >
                    <div class="" style="5px solid #0a0a0a !important;">
                     <%= sdate.strftime('%d %b %Y') %>
                    </div>
                  </td>
                  <% end %>
                </tr>
                <tr>
                  <th  style="background: #44546a !important;" class="w36 fixed-side" > Activity </th>
                   <% (st_date..en_date).each do |sdate| 
                    occ = @occurrences.where("DATE(activities.start_time)=?", sdate)
                    if occ.count > 0 
                      occ.each do |oc|%>
                        <th> <%= Submission.find_by(activity_id: oc.id).try(:created_at).try(:strftime, "%l:%M %p") || oc.start_time.strftime('%l:%M %p') %> </th>
                      <% end %>
                    <% else %>
                        <th>  </th>
                    <% end %>
                  <% end %>
                </tr>
              </thead>
              <tbody>
                <% user_dates = Hash.new %>
                <% @checklist.questions.each_with_index do |cp, i| %> 
                <tr>
                  <td class="w36 fixed-side"><%= cp.name if cp.present? %></td>
                  <% (st_date..en_date).each do |sdate| 
                    occ = @occurrences.where("DATE(activities.start_time)=?", sdate)
                    if occ.count > 0  
                      occ.each do |oc| 
                        submissions = Submission.where(activity_id: oc.id, question_id: cp.id) %>
                         <% if submissions.present?
                            submissions.each do |response| %>
                              <td>
                                <%= response.value  %>
                                <% user_dates["#{sdate}"]= response.user.try(:fullname) %>
                              </td>
                            <% end %>
                           <% else %>
                          <td>  </td>
                         <% end %>
                      <% end %>
                    <% else %>
                        <td>  </td>
                    <%  end %>
                  <%  end %>
                </tr>
                <%  end %>
                <tr>
                <td>User Name</td>
                <% (st_date..en_date).each do |sdate| %> 
                <td> <%= user_dates["#{sdate}"] %></td>
                <% end%>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
<% end%>

<script>
$(document).ready(function(){
  $('.reservation').daterangepicker({
      startDate: moment().startOf('month'),
      endDate: moment().endOf('month'),
    });
});
$('.applyfilter').click(function(){
  $("#filters").submit();
});
$('.applyfilter2').click(function(){
  window.location = "/checklists/<%= @checklist.id %>.xlsx?asset_id=<%= params[:asset_id]%>&date_range=" + $("#date_range").val();
});

</script>
