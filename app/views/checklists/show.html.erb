    </div>
    <div class="col-sm-4">
      <strong>Start date:</strong>
      <%= @checklist.start_date %>
    </div>
    <div class="col-sm-4">
      <strong>End date:</strong>
      <%= @checklist.end_date %>
    </div>
  </div>
</div>

<% if asset.present? %>
