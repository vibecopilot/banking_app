<p id="notice"><%= notice %></p>

<h1>Color Codes</h1>

<table>
  <thead>
    <tr>
      <th>Code</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @color_codes.each do |color_code| %>
      <tr>
        <td><%= color_code.code %></td>
        <td><%= link_to 'Show', color_code %></td>
        <td><%= link_to 'Edit', edit_color_code_path(color_code) %></td>
        <td><%= link_to 'Destroy', color_code, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Color Code', new_color_code_path %>
