<p id="notice"><%= notice %></p>

<h1>Fitout Documents</h1>

<table>
  <thead>
    <tr>
      <th>Fitout category</th>
      <th>Active</th>
      <th>Name</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @fitout_documents.each do |fitout_document| %>
      <tr>
        <td><%= fitout_document.fitout_category %></td>
        <td><%= fitout_document.active %></td>
        <td><%= fitout_document.name %></td>
        <td><%= link_to 'Show', fitout_document %></td>
        <td><%= link_to 'Edit', edit_fitout_document_path(fitout_document) %></td>
        <td><%= link_to 'Destroy', fitout_document, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Fitout Document', new_fitout_document_path %>
