<p id="notice"><%= notice %></p>

<h1>Poll Options</h1>

<table border="1" cellpadding="5" cellspacing="0" style="width: 50%; margin: 0 auto;">
  <thead>
    <tr>
      <th>Content</th>
      <th>Poll</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @poll_options.each do |poll_option| %>
      <tr>
        <td><%= poll_option.content %></td>
        <td><%= poll_option.poll.id %></td>
        <td><%= link_to 'Show', poll_option %></td>
        <td><%= link_to 'Edit', edit_poll_option_path(poll_option) %></td>
        <td><%= link_to 'Destroy', poll_option, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Poll Option', new_poll_path %>
