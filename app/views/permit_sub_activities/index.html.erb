<p id="notice"><%= notice %></p>

<h1>Permit Sub Activities</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Permit type</th>
      <th>Permit activity setup</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @permit_sub_activities.each do |permit_sub_activity| %>
      <tr>
        <td><%= permit_sub_activity.name %></td>
        <td><%= permit_sub_activity.permit_type %></td>
        <td><%= permit_sub_activity.permit_activity_setup %></td>
        <td><%= link_to 'Show', permit_sub_activity %></td>
        <td><%= link_to 'Edit', edit_permit_sub_activity_path(permit_sub_activity) %></td>
        <td><%= link_to 'Destroy', permit_sub_activity, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Permit Sub Activity', new_permit_sub_activity_path %>
