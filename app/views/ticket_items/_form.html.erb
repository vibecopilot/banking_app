<%= form_with(model: ticket_item, local: true) do |form| %>
  <% if ticket_item.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(ticket_item.errors.count, "error") %> prohibited this ticket_item from being saved:</h2>

      <ul>
      <% ticket_item.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :ticket_id %>
    <%= form.number_field :ticket_id, id: :ticket_item_ticket_id %>
  </div>

  <div class="field">
    <%= form.label :item_id %>
    <%= form.number_field :item_id, id: :ticket_item_item_id %>
  </div>

  <div class="field">
    <%= form.label :rate %>
    <%= form.text_field :rate, id: :ticket_item_rate %>
  </div>

  <div class="field">
    <%= form.label :item_count %>
    <%= form.number_field :item_count, id: :ticket_item_item_count %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
