<style type="text/css">
      body{
        background: #e4e4e4 !important;
      }
      
      @media screen and (max-width: 768px) {
        body {
          width: 100vw !important;
          background: #e4e4e4 !important;
        }

        .container {
          width: 100%;
          margin: 0;
          padding: 0;
        }

        .complaint-type {
          display: none;
        }

        #page-wrapper {
          width: 100vw !important;
          height: auto !important;
        }

        .ui.menu.top-menu {
          justify-content: space-between !important;
        }

        .nav.navbar-top-links {
          display: flex;
        }

        .navbar-top-links li {
          padding: 0 10px !important;
        }

        .navbar-top-links .dropdown {
          width: 125px !important;
          display: flex;
          justify-content: flex-end;
        }

        .navbar-top-links .dropdown-messages {
          width: 175px !important;
        }

        .right {
          width: 125px;
          display: flex;
          justify-content: flex-end;
        }

        .navbar-top-links .dropdown-messages li {
          margin: 0 !important;
          padding: 4px !important;
        }

         .navbar-top-links .dropdown-messages li a {
          margin: 0 !important;
          padding: 5px !important;
        }

        .nav.navbar-top-links li {
          align-self: center;
        }

        .navbar-top-links li:last-child {
          margin-right: 0 !important;
        }

       .img-circle {
          margin-right: 0 !important;
        }
        
        .navbar-default {
          display: none !important;
        }

        .main-footer {
          margin-left: 0 !important;
          left: 0 !important;
        }

        .modal{
          top: 60px;
        }

        .company_logo {
          display: flex !important;
          justify-content: center;
          align-items: center;
        }
      }

      .ui.menu.top-menu {
        display: flex !important;
        justify-content: flex-end;
      }

      .nav.navbar-top-links {
        display: flex;
      }

      .nav.navbar-top-links li {
        align-self: center;
      }

      .white-bg {
        background: #fff;
      }

      .sidenav {
          height: 100%; /* 100% Full-height */
          width: 0; /* 0 width - change this with JavaScript */
          position: fixed; /* Stay in place */
          z-index: 1; /* Stay on top */
          top: 0; /* Stay at the top */
          left: 0;
          background-color: #111; /* Black*/
          overflow-x: hidden; /* Disable horizontal scroll */
          padding-top: 60px; /* Place content 60px from the top */
          transition: 0.5s; /* 0.5 second transition effect to slide in the sidenav */
        }

      /* The navigation menu links */
      .sidenav a {
        padding: 8px 8px 8px 32px;
        text-decoration: none;
        font-size: 18px !important;
        color: #fff !important;
        display: block;
        transition: 0.3s;
      }

      /* When you mouse over the navigation links, change their color */
      .sidenav a:hover {
        color: #f1f1f1;
      }

      /* Position and style the close button (top right corner) */
      .sidenav .closebtn {
        position: absolute;
        top: 0;
        right: 25px;
        font-size: 36px;
        margin-left: 50px;
      }

      .main-footer {
          background: #fff;
          border-top: 1px solid #e7eaec;
          margin-left: 115px;
          display: block;
          position: sticky;
          bottom: 0;
          padding: 0.5rem;
          display: flex;
          flex-direction: column;
          justify-content: center;
          align-items: center;
          left: 7px;
        }

      .main-footer img {
        height: 50px;
        width: 50px;
      }

      .img-circle {
        width: 30px !important;
        height: 30px !important;
        margin-right: 10px !important;
      }

      .company_logo {
        display: none;
      }

       .dropdown-menu > li > a {
        padding: 5px !important;
        text-align: left !important;
      }

      .dropdown-menu > li > a:hover{
        background-color: transparent !important;
        border-bottom: 2px solid #18a689;
      }

      .navbar-top-links .dropdown-menu li{
        margin: 0;
      }

      .dropdown-menu > li > a{
        border-bottom: none;
      }

      .dropdown-messages{
        padding: 0;
      }

      .navbar-top-links li {
        border: none;
      }
    </style>
</head>

<body>

  <div class="mobile-view">
    <%=  render :partial => "layouts/new_sidebar" %>

