      <% if flash.present? %>
        <script type="text/javascript">
          $(document).ready(function(){
          <% flash.each do |key, value| %>
            <% if flash[:success] || flash[:success_message] || flash[:notice]%> 
               toastr.info("<%= value %>" ) ;
            <% else %>
              toastr.error("<%= value %> ") ;
            <% end %>  
          <% end %>
          });
        </script>
      <% end %>

