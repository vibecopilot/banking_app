<p id="notice"><%= notice %></p>

<h1>Incidents</h1>

<table>
  <thead>
    <tr>
      <th>Time and date</th>
      <th>Primary incident category</th>
      <th>Secondary incident category</th>
      <th>Incident severity</th>
      <th>Incident level</th>
      <th>Building</th>
      <th>Probability</th>
      <th>Description</th>
      <th>Created by</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @incidents.each do |incident| %>
      <tr>
        <td><%= incident.time_and_date %></td>
        <td><%= incident.primary_incident_category %></td>
        <td><%= incident.secondary_incident_category %></td>
        <td><%= incident.incident_severity %></td>
        <td><%= incident.incident_level %></td>
        <td><%= incident.building_id %></td>
        <td><%= incident.probability %></td>
        <td><%= incident.description %></td>
        <td><%= incident.created_by_id %></td>
        <td><%= link_to 'Show', incident %></td>
        <td><%= link_to 'Edit', edit_incident_path(incident) %></td>
        <td><%= link_to 'Destroy', incident, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Incident', new_incident_path %>
