<p id="notice"><%= notice %></p>

<h1>Blocked Days</h1>

<table>
  <thead>
    <tr>
      <th>Restaurant</th>
      <th>Start date</th>
      <th>Start date</th>
      <th>Reason</th>
      <th>Booking allowed</th>
      <th>Order allowed</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @blocked_days.each do |blocked_day| %>
      <tr>
        <td><%= blocked_day.restaurant_id %></td>
        <td><%= blocked_day.start_date %></td>
        <td><%= blocked_day.start_date %></td>
        <td><%= blocked_day.reason %></td>
        <td><%= blocked_day.booking_allowed %></td>
        <td><%= blocked_day.order_allowed %></td>
        <td><%= link_to 'Show', blocked_day %></td>
        <td><%= link_to 'Edit', edit_blocked_day_path(blocked_day) %></td>
        <td><%= link_to 'Destroy', blocked_day, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Blocked Day', new_blocked_day_path %>
