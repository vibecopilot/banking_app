<style type="text/css">
  .grid-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-gap: 2px;
  }
  .ibox-title{
    border:0px !important;
  }
  .attach-img{
    display: inline-block !important;
  }
  .attach-img img {
    width: 100px !important;
    height: 100px !important;
  }

  .users-feedback {
    display: grid;
    grid-template-columns: repeat(5, 50px);
    grid-gap: 25px;
    margin: 10px 0;
    justify-content: center;
  }

  .individual-feedback {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .feedback-icons {
    width: 30px;
    height: 30px;
    margin-bottom: 5px;
  }
  .ibox-content{
    border-style: none;
  }
</style>
<p id="notice"><%= notice %></p>

<div class="ibox">
  <div class="ibox-content">
    <a href="/submissions?q[asset_id_eq]=<%= @site_asset.id%>&<%= 'wv=1' if params[:wv].present? %>"><button class="btn btn-primary btn-md custom-button"> Checklists</i>  </button></a>
    <a href="/show_readings?asset_id=<%= @site_asset.id%>&<%= 'wv=1' if params[:wv].present? %>"><button class="btn btn-primary btn-md custom-button">Logbook</button></a>
    <a href="/take_reading?asset_id=<%= @site_asset.id%>&<%= 'wv=1' if params[:wv].present? %>"><button class="btn btn-primary btn-md custom-button">Take Reading</button></a>
    <button type="button" style="display: none;" class="btn btn-info btn-md custom-button width-auto"><a href="#" data-toggle="modal" data-target="#upload_schedule"><i class="fa fa-upload margin-r-5" aria-hidden="true"></i>Import Reading</a></button>
<br>
<br>
