<% if @user.user_type == "pms_admin"%>
<h5>Asset Parameters</h5>
<hr>
<div class="col-sm-12">
  <div class="row help">
  <%= form_for(AssetParam.new, :html => { :class => "form-horizontal"}) do |f| %>
      <li><%= notice %></li>
      <%= f.hidden_field :asset_id, :value => @site_asset.id %>
      <div class="col-sm-2">
        <label>Name</label>
        <%= f.text_field :name, id: :comment_ctext %>
      </div>
      <div class="col-sm-2">
        <%= f.label :order %>
        <%= f.number_field :order %>
      </div>

      <div class="col-sm-2">
        <label>Charactor Limit</label>
        <%= f.number_field :digit %>
      </div>

      <div class="col-sm-2">
        <%= f.label :dashboard_view %>
        <%= f.check_box :dashboard_view %>
      </div>

      <div class="col-sm-2">
        <%= f.label :consumption_view %>
        <%= f.check_box :consumption_view %>
      </div>

    <div class="form-group col-sm-2">
      <button type="submit" class="btn btn-success btn-xs add-complaint"> <i class="fa fa-plus" aria-hidden="true"></i> Add</button>
    </div>
    </div>
  <% end %>
</div>
<br><br><br>
<br>

<div class="col-sm-12" style="margin: 10px">
<table class="col-sm-8">
  <thead>
    <tr>
      <th width="50%">Name</th>
      <th>Order</th>
      <th>Charactor Limit</th>
      <th>Dashboard view</th>
      <th>Consumption view</th>
      <th>Edit</th>
      <th>Delete</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @site_asset.asset_params.order(:order).each do |asset_param| %>
      <tr>
        <td><%= asset_param.name %></td>
        <td><%= asset_param.order %></td>
        <td><%= asset_param.digit %></td>
        <td><%= asset_param.dashboard_view %></td>
        <td><%= asset_param.consumption_view %></td>
        <td><%= link_to 'Edit', edit_asset_param_path(asset_param) %></td>
        <td><%= link_to 'Destroy', asset_param, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

  <% end %>
</div>

<div class="modal fade" id="upload_schedule" role="dialog">
  <div class="modal-dialog">
    <div class="modal-content">
      <%= form_tag import_reading_site_assets_path(asset_id: @site_asset.id), multipart: true, method: :post do %>
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">&times;</button>
        <h4 class="modal-title">Upload</h4>
      </div>
      <div class="modal-body">
        <div class="row">
            <div class="form-group">
              <label class="col-sm-4 control-label">File  <span class="require"></span></label>
              <div class="col-sm-8">
                <input name="upl_file" type="file" class="form-control" accept=".xls,.xlsx" required>
              </div>
            </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="submit" id="submitbtn" class="btn btn-success" >Submit</button>
      </div>
      <% end %>
    </div>
  </div>
</div>