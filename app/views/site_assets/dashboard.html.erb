            color: 'rgb(102, 102, 102)'
          },
          activeDataLabelStyle: {
              textDecoration: 'none',
              color: 'rgb(0, 0, 0)'
          }
        };


  var highchart_canvas4 = 'highchart_canvas4';

  var report4 = prepare_highchart1(highchart_canvas4,'column', highchart_title4, yaxistext4,series4,drilldown4);
  


