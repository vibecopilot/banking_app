        };

  var highchart_canvas2 = 'highchart_canvas2';

  var report2 = prepare_highchart1(highchart_canvas2,'column', highchart_title2, yaxistext2,series2,drilldown2);


  var highchart_data_array3 = <%= raw @highchart_data_array3.to_json %>;


  var highchart_title3 = "Source wise site visit";

