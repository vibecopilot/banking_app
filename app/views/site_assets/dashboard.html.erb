  var report3 = prepare_highchart1(highchart_canvas3,'column', highchart_title3, yaxistext3,series3,drilldown3);



  var highchart_data_array4 = <%= raw @highchart_data_array4.to_json %>;


  var highchart_title4 = "Classification wise lead count";

  var yaxistext4 = '<p style="font-weight:550;">Classification wise lead counts (in nos)</p>';

  var series4 = [
        {
          colorByPoint: true,
