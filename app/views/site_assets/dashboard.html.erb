  var highchart_title6 = "Lead Call Source Report";
  var yaxistext6 = '<p style="font-weight:550;">Total Lead Counts Source wise (in nos)</p>';
  var series6 = [
        {
          colorByPoint: true,
          data: highchart_data_array6
        }
      ];

  var drilldown6 = {
          series:  <%= raw @highchart_drilldown6.to_json %>,
          activeAxisLabelStyle: {
