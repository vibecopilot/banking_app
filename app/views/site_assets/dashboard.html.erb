  var report6 = prepare_highchart1(highchart_canvas6,'column', highchart_title6, yaxistext6,series6,drilldown6);


var highchart_data_array7 = <%= raw @highchart_data_array7.to_json %>;

  var highchart_title7 = "Sales Conversion Ratio";
  var yaxistext7 = '<p style="font-weight:550;">Count</p>';
  var highchart_canvas7 = 'highchart_canvas7';

  prepare_stack_highchart(highchart_canvas7,highchart_title7,yaxistext7,highchart_data_array7);


 </script>