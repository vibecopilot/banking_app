<!DOCTYPE html>
<html lang="en">
<head>
  <title>QR Asset Labels</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">

  <style>
    body {
      background: #fff;
      margin: 0;
      padding: 0;
    }

    page {
      background: white;
      display: block;
      margin: 0 auto;
      width: 21cm;
      min-height: 29.7cm;
      padding: 20px;
    }
    .cards {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

    /* CARD */
    .card {
      border: 1px solid #ccc;
      margin: 22px 0;
      margin-bottom: 22px;
      padding: 18px 24px 12px;
      width: 48%;
      background: #fff;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }

    /* QR */
    .qr {
      width: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
      margin-bottom: 12px;
    }

    .qr img {
      width: 120px;
      height: 120px;
      object-fit: contain;
      display: block;
    }

    /* DETAILS */
    .details {
      width: 100%;
    }

    .details p {
      margin: 0 0 6px;
      font-size: 15px;
    }

    .details b {
      font-weight: bold;
    }

    /* PRINT CONTROL */
    @media print {
      .card {
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .page-break {
        page-break-after: always;
        break-after: page;
      }

      page {
        box-shadow: none;
        margin: 0;
      }
    }
  </style>
</head>

<body>

<page size="A4">
  <div class="cards">

    <% @site_assets.each_with_index do |asset, index| %>

      <% if index % 8 == 0 && index != 0 %>
        </div>
        </page>
        <div class="page-break"></div>
        <page size="A4">
        <div class="cards">
      <% end %>

      <div class="card">

        <div class="qr">
          <img src="<%= asset.qr_code_image.whole_path.to_s %>" alt="QR Code">
        </div>

        <div class="details">
          <p>
            <b>Name:</b>
            <%= asset.name %>
            (<%= asset.serial_number.presence || "NA" %>)
          </p>

          <p>
            <b>Model Number:</b>
            <%= asset.model_number.presence || "NA" %>
          </p>

          <p>
            <b>Location:</b>
            <%= asset.try(:site).try(:name) || "NA" %> /
            <%= asset.try(:building).try(:name) || "NA" %> /
            <%= asset.try(:floor).try(:name) || "NA" %> /
            <%= asset.try(:unit).try(:name) || "NA" %>
          </p>
        </div>

      </div>

    <% end %>

  </div>
</page>


</body>
</html>
