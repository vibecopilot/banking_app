<!DOCTYPE html>
<html>
  <head>
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        margin: 0;
        padding: 0;
      }
      .email-container {
        max-width: 600px;
        margin: 20px auto;
        border: 1px solid #ddd;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .header {
        background-color: #4CAF50;
        color: white;
        padding: 15px;
        text-align: center;
      }
      .content {
        padding: 20px;
      }
      .content h2 {
        margin-top: 0;
        color: #4CAF50;
      }
      .footer {
        background-color: #f9f9f9;
        text-align: center;
        padding: 10px;
        font-size: 0.9em;
        color: #666;
      }
    </style>
  </head>
  <body>
    <div class="email-container">
      <div class="header">
        <h1>You're Invited!</h1>
      </div>
      <div class="content">
        <h2><%= @event.event_name %></h2>
        <p><strong>Description:</strong> <%= raw @event.discription %></p>
        <p><strong>Venue:</strong> <%= @event.event_name %></p>
        <p>Scan this QR code to check in:</p>
        <% if @event.qr_code.present? %>
          <img src="https://admin.vibecopilot.ai/<%= @event.qr_code.document_url %>" target="_inline" alt="QR Code" />
        <% end %>
        <p><strong>Start Time:</strong> <%= @event.start_date_time.strftime('%A, %d %B %Y, %I:%M %p') if @event.start_date_time %></p>
        <p><strong>End Time:</strong> <%= @event.end_date_time.strftime('%A, %d %B %Y, %I:%M %p') if @event.end_date_time %></p>
        <p>We hope you can join us!</p>
        
        <% if @view_event_url %>
        <p style="text-align: center; margin-top: 20px;">
          <a href="<%= @view_event_url %>" style="display: inline-block; background-color: #4CAF50; color: white; padding: 12px 24px; text-decoration: none; border-radius: 5px; font-weight: bold;">View Event Details</a>
        </p>
        <% end %>
      </div>
      <div class="footer">
        <p>&copy; 2025 Myciti.life. All rights reserved.</p>
      </div>
    </div>
    
    <!-- Email open tracking pixel -->
    <% if @tracking_pixel_url %>
    <img src="<%= @tracking_pixel_url %>" width="1" height="1" style="display:none;" alt="" />
    <% end %>
  </body>
</html>
