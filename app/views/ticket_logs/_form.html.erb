<%= form_with(model: ticket_log, local: true) do |form| %>
  <% if ticket_log.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(ticket_log.errors.count, "error") %> prohibited this ticket_log from being saved:</h2>

      <ul>
      <% ticket_log.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :ticket_id %>
    <%= form.number_field :ticket_id, id: :ticket_log_ticket_id %>
  </div>

  <div class="field">
    <%= form.label :created_by_id %>
    <%= form.number_field :created_by_id, id: :ticket_log_created_by_id %>
  </div>

  <div class="field">
    <%= form.label :status %>
    <%= form.text_field :status, id: :ticket_log_status %>
  </div>

  <div class="field">
    <%= form.label :log_type %>
    <%= form.text_field :log_type, id: :ticket_log_log_type %>
  </div>

  <div class="field">
    <%= form.label :remarks %>
    <%= form.text_area :remarks, id: :ticket_log_remarks %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
