<!DOCTYPE html>
<html>
  <head>
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        margin: 0;
        padding: 0;
      }
      .email-container {
        max-width: 600px;
        margin: 20px auto;
        border: 1px solid #ddd;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .header {
        background-color: #4CAF50;
        color: white;
        padding: 15px;
        text-align: center;
      }
      .content {
        padding: 20px;
      }
      .content h2 {
        margin-top: 0;
        color: #4CAF50;
      }
      .footer {
        background-color: #f9f9f9;
        text-align: center;
        padding: 10px;
        font-size: 0.9em;
        color: #666;
      }
    </style>
  </head>
  <body>
    <div class="email-container">
      <div class="header">
        <h1>You're Invited to Poll!</h1>
      </div>
      <div class="content">
        <h2><%= @poll.title %></h2>
        <p><strong>Description:</strong> <%= raw @poll.description %></p>
        <p><strong>Start Date:</strong> <%= @poll.start_time.strftime('%A, %d %B %Y, %I:%M %p') %></p>
        <p><strong>End Date:</strong> <%= @poll.end_time.strftime('%A, %d %B %Y, %I:%M %p') %></p>
      </div>
      <div class="footer">
        <p>&copy; 2025 MyCiti.life. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>