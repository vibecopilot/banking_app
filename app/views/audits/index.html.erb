<p id="notice"><%= notice %></p>

<h1>Audits</h1>

<table>
  <thead>
    <tr>
      <th>Audit for</th>
      <th>Activity name</th>
      <th>Description</th>
      <th>Allow observations</th>
      <th>Checklist type</th>
      <th>Asset name</th>
      <th>Service name</th>
      <th>Vendor name</th>
      <th>Training name</th>
      <th>Assign to</th>
      <th>Scan type</th>
      <th>Plan duration</th>
      <th>Priority</th>
      <th>Email trigger rule</th>
      <th>Supervisors</th>
      <th>Category</th>
      <th>Look overdue task</th>
      <th>Frequency</th>
      <th>Start from</th>
      <th>End at</th>
      <th>Select supplier</th>
      <th>Created by</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @audits.each do |audit| %>
      <tr>
        <td><%= audit.audit_for %></td>
        <td><%= audit.activity_name %></td>
        <td><%= audit.description %></td>
        <td><%= audit.allow_observations %></td>
        <td><%= audit.checklist_type %></td>
        <td><%= audit.asset_name %></td>
        <td><%= audit.service_name %></td>
        <td><%= audit.vendor_name %></td>
        <td><%= audit.training_name %></td>
        <td><%= audit.assign_to %></td>
        <td><%= audit.scan_type %></td>
        <td><%= audit.plan_duration %></td>
        <td><%= audit.priority %></td>
        <td><%= audit.email_trigger_rule %></td>
        <td><%= audit.supervisors %></td>
        <td><%= audit.category %></td>
        <td><%= audit.look_overdue_task %></td>
        <td><%= audit.frequency %></td>
        <td><%= audit.start_from %></td>
        <td><%= audit.end_at %></td>
        <td><%= audit.select_supplier %></td>
        <td><%= audit.created_by_id %></td>
        <td><%= link_to 'Show', audit %></td>
        <td><%= link_to 'Edit', edit_audit_path(audit) %></td>
        <td><%= link_to 'Destroy', audit, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Audit', new_audit_path %>
