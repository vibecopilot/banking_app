<div class="modal fade" id="feedback" role="dialog">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h4 class="modal-title">Feedback</h4>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>
      <%= form_for(Approval.new) do |form| %>
      <%f = form %>
        <div class="modal-body">
          <div class="row">
            <div class="col-sm-12">
          <%= f.hidden_field :cusdirect, :name => "cusdirect", :value => "/show_readings?asset_id=#{params[:asset_id]}" %>
          <%= f.hidden_field :resource_type, :value => "SiteAsset" %>
          <%= f.hidden_field :resource_id, :value => params[:asset_id] %>
          <%= form.hidden_field :site_id, :value => @user.current_site_id %>
          <%= f.hidden_field :user_id, :value => @user.id %>
          <%= form.hidden_field :level_id, :value => level.id %>

          <div class="form-group">
            <%= form.label :start_date %>
            <%= form.text_field :start_date, id: :approval_end_date, :placeholder => "Start Date", class: "datepicker", :required => true  %>
          </div>

          <div class="form-group">
            <%= form.label :end_date %>
            <%= form.text_field :end_date, id: :approval_end_date, :placeholder => "End Date", class: "datepicker", :required => true  %>
          </div>

          <div class="form-group">
            <%= form.label :comments %>
            <%= form.text_area :comments, id: :approval_comments %>
          </div>
        </div>
        </div>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-success btn-sm" >Submit</button>
        </div>
      <% end %>
    </div>
  </div>
</div>
