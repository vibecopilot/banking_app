<p id="notice"><%= notice %></p>

<h1>Flight Requests</h1>

<table>
  <thead>
    <tr>
      <th>Employee name</th>
      <th>Employee</th>
      <th>Departure city</th>
      <th>Arrival city</th>
      <th>Departure date</th>
      <th>Return date</th>
      <th>Preferred airlines</th>
      <th>Flight class</th>
      <th>Passenger name</th>
      <th>Passport information</th>
      <th>Ticket confirmation number</th>
      <th>Booking status</th>
      <th>Manager approval</th>
      <th>Booking confirmation email</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @flight_requests.each do |flight_request| %>
      <tr>
        <td><%= flight_request.employee_name %></td>
        <td><%= flight_request.employee_id %></td>
        <td><%= flight_request.departure_city %></td>
        <td><%= flight_request.arrival_city %></td>
        <td><%= flight_request.departure_date %></td>
        <td><%= flight_request.return_date %></td>
        <td><%= flight_request.preferred_airlines %></td>
        <td><%= flight_request.flight_class %></td>
        <td><%= flight_request.passenger_name %></td>
        <td><%= flight_request.passport_information %></td>
        <td><%= flight_request.ticket_confirmation_number %></td>
        <td><%= flight_request.booking_status %></td>
        <td><%= flight_request.manager_approval %></td>
        <td><%= flight_request.booking_confirmation_email %></td>
        <td><%= link_to 'Show', flight_request %></td>
        <td><%= link_to 'Edit', edit_flight_request_path(flight_request) %></td>
        <td><%= link_to 'Destroy', flight_request, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Flight Request', new_flight_request_path %>
