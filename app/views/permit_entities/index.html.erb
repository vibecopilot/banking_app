<p id="notice"><%= notice %></p>

<h1>Permit Entities</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Permit</th>
      <th>Active</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @permit_entities.each do |permit_entity| %>
      <tr>
        <td><%= permit_entity.name %></td>
        <td><%= permit_entity.permit_id %></td>
        <td><%= permit_entity.active %></td>
        <td><%= link_to 'Show', permit_entity %></td>
        <td><%= link_to 'Edit', edit_permit_entity_path(permit_entity) %></td>
        <td><%= link_to 'Destroy', permit_entity, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Permit Entity', new_permit_entity_path %>
