<p id="notice"><%= notice %></p>

<h1>Cam Bills</h1>

<table>
  <thead>
    <tr>
      <th>Unit</th>
      <th>User</th>
      <th>Bill date</th>
      <th>Due date</th>
      <th>Total amount</th>
      <th>Created by</th>
      <th>Sub amount</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @cam_bills.each do |cam_bill| %>
      <tr>
        <td><%= cam_bill.unit_id %></td>
        <td><%= cam_bill.user_id %></td>
        <td><%= cam_bill.bill_date %></td>
        <td><%= cam_bill.due_date %></td>
        <td><%= cam_bill.total_amount %></td>
        <td><%= cam_bill.created_by %></td>
        <td><%= cam_bill.sub_amount %></td>
        <td><%= link_to 'Show', cam_bill %></td>
        <td><%= link_to 'Edit', edit_cam_bill_path(cam_bill) %></td>
        <td><%= link_to 'Destroy', cam_bill, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Cam Bill', new_cam_bill_path %>
