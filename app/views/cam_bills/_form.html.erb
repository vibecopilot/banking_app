<%= form_with(model: cam_bill, local: true) do |form| %>
  <% if cam_bill.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(cam_bill.errors.count, "error") %> prohibited this cam_bill from being saved:</h2>

      <ul>
      <% cam_bill.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :unit_id %>
    <%= form.number_field :unit_id, id: :cam_bill_unit_id %>
