  <div class="field">
    <%= form.label :user_id %>
    <%= form.number_field :user_id, id: :cam_bill_user_id %>
  </div>

  <div class="field">
    <%= form.label :bill_date %>
    <%= form.date_select :bill_date, id: :cam_bill_bill_date %>
  </div>

  <div class="field">
    <%= form.label :due_date %>
    <%= form.date_select :due_date, id: :cam_bill_due_date %>
  </div>

  <div class="field">
    <%= form.label :total_amount %>
    <%= form.text_field :total_amount, id: :cam_bill_total_amount %>
  </div>

  <div class="field">
    <%= form.label :created_by %>
    <%= form.number_field :created_by, id: :cam_bill_created_by %>
  </div>

  <div class="field">
    <%= form.label :sub_amount %>
    <%= form.number_field :sub_amount, id: :cam_bill_sub_amount %>
